{"remainingRequest":"/Users/mac/Documents/code/iot/pms-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/pms-ui/src/views/modules/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/pms-ui/src/views/modules/index.vue","mtime":1694618820711},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;AAWA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA","file":"index.vue","sourceRoot":"src/views/modules","sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container style=\"height: 100%; border: 1px solid #eee\">\n        <h1 style=\"margin:  0 auto\">欢迎访问 《物联网项目结算平台》  <span>现在是北京时间: {{newTime}} </span></h1>\n      <div></div>\n    </el-container>\n\n  </div>\n</template>\n<script>\n\n  export default {\n    data() {\n      return {\n        newTime: \"\"\n      }\n    },\n    mounted(){\n      this.getNowTime();//进入页面调用该方法获取当前时间\n      clearInterval(myTimeDisplay );//销毁之前定时器\n      var myTimeDisplay = setInterval(() => {\n        this.getNowTime(); //每秒更新一次时间\n      }, 1000);\n    },\n    methods: {\n      getNowTime() {\n        var date = new Date();\n        var time = date.getFullYear() + '-' + (date.getMonth() + 1) + '-' + date.getDate() + ' ' + date.getHours() + ':' + date.getMinutes() + ':' + date.getSeconds();\n        this.newTime = time;\n      },\n      //根据自己的需求，看要不要在时间不大于10的时候在前面补0，如果需要直接this.addZero(date.getMinutes()),其它与之相同，如果不需要删掉addZero（）方法即可。\n      //小于10的拼接上0字符串\n      addZero(s) {\n        return s < 10 ? ('0' + s) : s;\n      },\n\n    }\n  }\n</script>\n"]}]}