rm.userName\" type=\"daterange\" placeholder=\"账号\" style=\"width: 100%\"/>\n            </el-form-item>\n            <div style=\"display: contents;\">\n              <el-button type=\"primary\" @click=\"refresh()\" icon=\"el-icon-search\" style=\"margin-right: 20px\">查询\n              </el-button>\n              <el-button type=\"primary\" @click=\"resetForm()\" icon=\"el-icon-search\">重置</el-button>\n            </div>\n          </div>\n        </el-form>\n      </el-header>\n      <baseTable :tableData=\"tableData\" ref=\"table\" :multiSelect=\"true\"></baseTable>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseTable from '../../base/baseTable.vue'\nimport baseDialog from '../../base/baseDialog.vue'\nexport default {\n  data() {\n    return {\n      passwordType: true,\n      signedDate: '',\n      titles: '',\n      dataForm: {\n        account: '',\n        phone: '',\n        mail: '',\n        createTime: '',\n        status: ''\n      },\n      tableData: {\n        theads: [\n          { label: '账号', prop: 'userId' },\n          { label: '账号名称', prop: 'userName' },\n          { label: '合同打标次数', prop: 'saveContactLabel' },\n          { label: '订单导入次数', prop: 'saveOrders' },\n          { label: '发票导入次数', prop: 'saveInvoices' },\n          { label: '合同关键页导入次数', prop: 'importContract' },\n          { label: '添加标签次数', prop: 'saveLabel' },\n          { label: '添加资质次数', prop: 'companyQualificationsInsert' },\n          { label: '上传文档次数', prop: 'tenderDocumentsInsert' },\n          { label: '补充材料导入次数', prop: 'replenishFileImport' },\n        ],\n        url: '/userLog/statisticalResult'\n      }\n    }\n  },\n  components: {\n    baseTable, baseDialog\n  },\n  mounted() {\n    this.$refs.table.refresh(this.dataForm)\n  },\n  methods: {\n    refresh() {\n      if(this.signedDate){\n        this.dataForm.stateDate=this.signedDate[0]\n        this.dataForm.endDate=this.signedDate[1]\n      }else{\n        this.dataForm.stateDate=''\n        this.dataForm.endDate=''\n      }\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n      this.signedDate=''\n    }\n  }\n}\n</script>\n<style scoped>\n.el-header {\n  color: #333;\n  padding: 0 0;\n}\n\n.el-form--inline > .inputlist {\n  padding-top: 20px;\n  padding-left: 20px;\n  display: flex;\n}\n\n.el-form--inline > .inputlist > .el-form-item {\n  width: 26%;\n  margin-bottom: 20px;\n}\n\n.el-form-item__content {\n  width: 200px;\n}\n\n.el-button {\n  width: 80px;\n  height: 35px;\n}\n\n.el-button-func {\n  width: 86px;\n  height: 30px;\n  text-align: center;\n}\n::v-deep .el-table__cell{\n  text-align: center;\n}\n::v-deep .el-form-item__content{\n  width: 63% ;\n}\n</style>\n<style>\n::-webkit-scrollbar { /*滚动条整体样式*/\n  width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n  height: 8px;\n}\n\n::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n  border-radius: 10px;\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  background: #e1f1f1;\n}\n\n::-webkit-scrollbar-track { /*滚动条里面轨道*/\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  border-radius: 10px;\n  background: #fff;\n}\n</style>\n"]}]}