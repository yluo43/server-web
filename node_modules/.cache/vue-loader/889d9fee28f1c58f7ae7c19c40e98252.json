{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/base/basePicUpload.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/base/basePicUpload.vue","mtime":1694618820702},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["basePicUpload.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA+BA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"basePicUpload.vue","sourceRoot":"src/views/modules/base","sourcesContent":["<template>\n  <div class=\"base-pic-upload\">\n    <el-upload\n      action=\"#\"\n      multiple\n      ref=\"upload\"\n      list-type=\"picture-card\"\n      :on-change=\"handleOnChange\"\n      :on-remove=\"handleOnRemove\"\n      :accept=\"accept\"\n      :file-list=\"fileList\"\n      :auto-upload=\"false\">\n      <i slot=\"default\" class=\"el-icon-plus\"></i>\n      <div slot=\"file\" slot-scope=\"{file}\">\n        <img class=\"el-upload-list__item-thumbnail\" :src=\"file.url\" alt=\"\">\n        <span class=\"el-upload-list__item-actions\">\n          <span class=\"el-upload-list__item-preview\">\n            <i class=\"el-icon-zoom-in\" @click=\"handlePictureCardPreview(file)\"></i>\n            <span class=\"el-upload-list__item-delete\" @click=\"handleRemove(file)\">\n              <i class=\"el-icon-delete\" style=\"margin-left: 20px;\"></i>\n            </span>\n          </span>\n        </span>\n      </div>\n    </el-upload>\n    <el-dialog :visible.sync=\"dialogVisible\">\n      <img width=\"100%\" :src=\"dialogImageUrl\" alt=\"\">\n    </el-dialog>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      dialogImageUrl: '',\n      dialogVisible: false,\n      nowFileList: this.fileList\n    }\n  },\n  props: {\n    name: {\n      type: String,\n      defualt: 'file'\n    },\n    propName:{\n      type: String,\n      defualt: ''\n    },\n    onValid: {\n      type: Function\n    },\n    fileList: {\n      type: Array,\n      default: function() {\n        return []\n      }\n    },\n    accept: {\n      type: String,\n      default: '.jpg,.png,.JPG,.PNG,.gif'\n    },\n    hideAllBtn: {\n      type: Boolean,\n      default: false\n    }\n  },\n  methods: {\n    handlePictureCardPreview(file) {\n      console.log(file);\n      this.dialogImageUrl = file.url\n      this.dialogVisible = true\n    },\n    cancelFiles() {\n      if (this.getFileList().length > 0) {\n        this.$refs.upload.clearFiles()\n      }\n    },\n    handleOnChange(file, fileList) {\n      let filetype = file.name.substr(file.name.lastIndexOf('.') + 1, file.name.length)\n      let flag = true\n      if (this.accept) {\n        let types = this.accept.replaceAll('.', '').split(',')\n        types.forEach((item, i) => {\n          if (item === filetype) {\n            flag = false\n          }\n        })\n      } else {\n        flag = false\n      }\n      if (flag) {\n        fileList.pop()\n        this.$message.warning('图片格式不正确')\n        return\n      } else {\n        if (this.onValid != null && !this.onValid(file, fileList)) {\n          fileList.pop()\n          // fileList.splice(0, fileList.length)\n          return\n        }\n      }\n      this.nowFileList = fileList\n      this.getFileList()\n    },\n    handleOnRemove(file, fileList) {\n      this.nowFileList = fileList\n      this.getFileList()\n    },\n    handleRemove(file, fileList) {\n      fileList = this.nowFileList\n      let index = fileList.indexOf(file);\n      fileList.splice(index, 1)\n    },\n    hasFile() {\n      return this.$refs.upload.fileList.length > 0\n    },\n    getFileList() {\n      let data = {propName:this.propName,file:this.nowFileList}\n      this.$emit(\"getFileList\",data)\n      // this.$refs.upload.fileList=this.nowFileList\n      // this.fileList=this.nowFileList\n      return this.nowFileList\n    }\n  }\n}\n</script>\n<style scoped>\n/* 取消eb-upload默认的按钮栏样式，用于按钮隐藏多余突出白块 */\n.base-pic-upload .el-upload{\n  display: block;\n  text-align: center;\n  line-height: 100px;\n  width: 100px;\n  height: 100px;\n}\n.el-upload-list--picture-card .el-upload-list__item{\n  width: 100px;\n  height: 100px;\n}\n.base-pic-upload>div{\n  display: inline-flex;\n}\n</style>\n"]}]}