y:flex;justify-content: right;margin-right: 15%;\">\n            <el-button type=\"primary\" v-if=\"vipMember\" @click=\"modify()\">修改</el-button>\n          </div>\n          <div class=\"detailInfo\">\n            <div class=\"detailInfo_right\">\n              <div class=\"detailInfo_rt\">\n                <ul>\n                  <li><span>企业名称</span>\n                    <input type=\"text\" v-model=\"dataForm.companyName\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.companyNameNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>企业名称变更记录</span>\n                    <input type=\"text\" v-model=\"dataForm.nameChangeRecord\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.nameChangeRecordNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>成立时间</span>\n                    <input type=\"text\" v-model=\"dataForm.establishmentTime\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.establishmentTimeNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>注册资金（元）</span>\n                    <input type=\"text\" v-model=\"dataForm.registeredCapital\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.registeredCapitalNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>营业执照号</span>\n                    <input type=\"text\" v-model=\"dataForm.businessLicenseNO\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.businessLicenseNONote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>营业执照有效期</span>\n                    <input type=\"text\" v-model=\"dataForm.businessLicenseLifespan\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.businessLicenseLifespanNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>工商登记号</span>\n                    <input type=\"text\" v-model=\"dataForm.businessRegistrationNumber\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.businessRegistrationNumberNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>法定代表人</span>\n                    <input type=\"text\" v-model=\"dataForm.legalRepresentative\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.legalRepresentativeNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>法人类型</span>\n                    <input type=\"text\" v-model=\"dataForm.legalEntityType\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.legalEntityTypeNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li style=\"width:100%;height:200px;display: flex;\"><span style=\"height: 100%;line-height: 200px;\">经营范围</span>\n                    <el-input type=\"textarea\" :rows=\"9\" style=\"width: 65%;color:#000;\" show-word-limit v-model=\"dataForm.businessScope\" :disabled=\"!vipMember\"></el-input>\n                    <span style=\"height: 100%;line-height: 200px;\">备注</span>\n                    <input style=\"height: 100%;line-height: 200px;\" type=\"text\" class=\"inpnode\" v-model=\"dataForm.businessScopeNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>税务登记号</span>\n                    <input type=\"text\" v-model=\"dataForm.taxRegistrationNO\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.taxRegistrationNONote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>增值税纳税人标识</span>\n                    <input type=\"text\" v-model=\"dataForm.taxpayerIdentification\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.taxpayerIdentificationNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>组织机构代码</span>\n                    <input type=\"text\" v-model=\"dataForm.organizationCode\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.organizationCodeNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>注册地址</span>\n                    <input type=\"text\" v-model=\"dataForm.registeredAddress\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.registeredAddressNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                  <li><span>企业高管</span>\n                    <div v-for=\"item,index in dataForm.corporateExecutives\" :key=\"index\">\n<!--                      <span style=\"width:8.2%;\">{{ item.position }}</span>-->\n                      <input style=\"width:8.2%;\" type=\"text\" v-model=\"item.position\" :disabled=\"!vipMember\"/>\n                      <input style=\"width:8.05%;\" type=\"text\" v-model=\"item.executiveName\" :disabled=\"!vipMember\"/>\n                    </div>\n                    <span>备注</span>\n                    <span style=\"border-right-width: 0px;\">\n                    <input type=\"text\" style=\"width: 88%;\" v-model=\"dataForm.corporateExecutivesIdNote\" :disabled=\"!vipMember\"/>\n                    </span>\n                  </li>\n                  <li style=\"border-bottom:1px solid #ddd;\"><span>员工规模（人）</span>\n                    <input type=\"text\" v-model=\"dataForm.employeeSize\" :disabled=\"!vipMember\"/>\n                    <span>备注</span>\n                    <input type=\"text\" v-model=\"dataForm.employeeSizeNote\" :disabled=\"!vipMember\"/>\n                  </li>\n                </ul>\n              </div>\n            </div>\n          </div>\n        </el-tab-pane>\n        <el-tab-pane label=\"财务相关信息\" name=\"second\">\n          <finance @resetForm=\"resetForm\" ref=\"finance\"></finance>\n        </el-tab-pane>\n        <el-tab-pane label=\"制造商信息\" name=\"third\">\n          <manufacturer @resetForm=\"resetForm\" ref=\"manufacturer\"></manufacturer>\n        </el-tab-pane>\n      </el-tabs>\n    </el-container>\n  </div>\n</template>\n<script>\nimport finance from './finance.vue'\nimport manufacturer from './manufacturer.vue'\nexport default {\n  data() {\n    return {\n      activeName: 'first',\n      titles: '',\n      vipMember: false,\n      dataForm: {\n        companyId: ''\n      }\n    }\n  },\n  components: {\n    finance, manufacturer\n  },\n  mounted() {\n    this.$http({\n      url: this.$http.adornUrl('/tenderinformation/CompanyInformation'),\n      method: 'get'\n    }).then(({ data }) => {\n      if (data && data.success) {\n        this.dataForm.companyId = data.payload.companyId\n        this.dataForm = data.payload\n      }\n    })\n    this.$http({\n      url: this.$http.adornUrl('/tenderinformation/isSuperMan'),\n      method: 'get'\n    }).then(({ data }) => {\n      if (data && data.success) {\n        this.vipMember = data.payload\n      }\n    })\n  },\n  methods: {\n    handleClick(tab, event) {\n      // console.log(tab, event)\n    },\n    modify() {\n      let loading = this.$loading({\n        lock: true, // lock的修改符--默认是false\n        text: '拼命修改中，请稍候...', // 显示在加载图标下方的加载文案\n        background: 'rgba(0,0,0,0.8)', // 遮罩层颜色\n        spinner: 'el-icon-loading' // 自定义加载图标类名\n      })\n      this.$http({\n        url: this.$http.adornUrl('/tenderinformation/CompanyInformationUpdate'),\n        method: 'put',\n        data: this.dataForm\n      }).then(({ data }) => {\n        if (data && data.success) {\n          loading.close()\n          this.$message({\n            message: '修改成功',\n            type: 'success'\n          })\n        } else {\n          loading.close()\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    }\n  }\n}\n</script>\n<style scoped>\n.detailInfo{\n  width: 70%;\n  margin: 0 auto;\n}\n.detailInfo span {\n  width: 100px;\n\tfloat: left;\n\ttext-align: center;\n\theight: 40px;\n\tline-height: 40px;\n  border-right:1px solid #ddd;\n  border-left:1px solid #ddd;\n}\n\n.detailInfo_rt li {\n\twidth: 100%;\n\tfloat: left;\n\tborder: solid #ddd 1px;\n  border-bottom: none;\n\theight: 40px;\n\tline-height: 40px;\n\toverflow: hidden;\n}\n.inpnode{\n  width: 10% !important;\n\tfloat: left;\n\tborder: none;\n  background-color: #F5F7FA;\n\theight: 38px;\n\tline-height: 36px;\n\toverflow: hidden;\n}\n.detailInfo_rt input:nth-of-type(1) {\n\twidth: 65%;\n\tfloat: left;\n\tborder: none;\n  background-color: #F5F7FA;\n\theight: 38px;\n\tline-height: 36px;\n\toverflow: hidden;\n}\n.detailInfo_rt input:nth-of-type(2) {\n\twidth: 10%;\n\tfloat: left;\n\tborder: none;\n  background-color: #F5F7FA;\n\theight: 38px;\n\tline-height: 36px;\n\toverflow: hidden;\n}\n::v-deep li>div .el-textarea__inner{\n  background-color: #F5F7FA !important;\n}\n</style>\n<style>\n::-webkit-scrollbar { /*滚动条整体样式*/\n  width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n  height: 8px;\n}\n\n::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n  border-radius: 10px;\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  background: #e1f1f1;\n}\n\n::-webkit-scrollbar-track { /*滚动条里面轨道*/\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  border-radius: 10px;\n  background: #fff;\n}\n</style>\n"]}]}