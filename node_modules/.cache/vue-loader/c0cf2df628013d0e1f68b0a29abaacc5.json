esetForm() {\n        this.$refs.dataForm.resetFields()\n        this.signedDate=''\n      }\n    }\n  }\n</script>\n<style scoped>\n  .el-header {\n    color: #333;\n    padding: 0 0;\n  }\n\n  .el-form--inline > .inputlist {\n    padding-top: 20px;\n    padding-left: 20px;\n    display: flex;\n  }\n\n  .el-form--inline > .inputlist > .el-form-item {\n    width: 26%;\n    margin-bottom: 20px;\n  }\n\n  .el-form-item__content {\n    width: 200px;\n  }\n\n  .el-button {\n    width: 80px;\n    height: 35px;\n  }\n\n  .el-button-func {\n    width: 86px;\n    height: 30px;\n    text-align: center;\n  }\n  ::v-deep .el-table__cell{\n    text-align: center;\n  }\n  ::v-deep .el-form-item__content{\n    width: 63% ;\n  }\n</style>\n<style>\n  ::-webkit-scrollbar { /*滚动条整体样式*/\n    width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n    height: 8px;\n  }\n\n  ::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n    border-radius: 10px;\n    -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n    background: #e1f1f1;\n  }\n\n  ::-webkit-scrollbar-track { /*滚动条里面轨道*/\n    -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n    border-radius: 10px;\n    background: #fff;\n  }\n</style>\n"]}]}