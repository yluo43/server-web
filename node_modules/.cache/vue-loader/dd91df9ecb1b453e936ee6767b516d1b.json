{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/labelDatabaseManagement/batchadd.vue?vue&type=style&index=0&id=30237406&scoped=true&lang=css&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/labelDatabaseManagement/batchadd.vue","mtime":1694618820711},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCi8qOjp2LWRlZXAgLmVsLWZvcm0taXRlbXsqLwovKiAgd2lkdGg6IDEwMCU7Ki8KLyp9Ki8KOjp2LWRlZXAgLmVsLWZvcm17CiAgd2lkdGg6IDEwMCU7Cn0KCg=="},{"version":3,"sources":["batchadd.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA8FA;AACA;AACA;AACA;AACA;AACA","file":"batchadd.vue","sourceRoot":"src/views/modules/labelDatabaseManagement","sourcesContent":["<!-- 自动发书管理-新增图书-新增 -->\n<template>\n  <div class=\"mdgContent\">\n    <el-container class=\"el-container__mdgContent\">\n      <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n        <div>\n          <el-form-item label=\"标签文件\" prop=\"status\">\n            <baseUpload\n              name=\"uploadFile\"\n              ref=\"uploadFile\"\n              :accept=\"'.xls,.xlsx'\"\n              :file-list=\"uploadFile\"\n              :hideAllBtn=\"true\"\n            ></baseUpload>\n          </el-form-item>\n<!--          <el-form-item label=\"下载模板\" prop=\"bookThreshold\">-->\n<!--            <el-button type=\"primary\" @click=\"download\">下载文件</el-button>-->\n<!--          </el-form-item>-->\n          <div style=\"margin-top:20px;text-align:center;\">\n            <el-form-item>\n              <el-button type=\"success\" @click=\"addOrUpdateHandle()\">提交</el-button>\n              <el-button type=\"danger\" @click=\"cancelDialog()\">取消</el-button>\n            </el-form-item>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseDialog from '../base/baseDialog.vue'\nimport baseUpload from '../base/baseUpload.vue'\nexport default {\n  data() {\n    return {\n      textarea: '',\n      status: '',\n      titles: '',\n      uploadFile: [],\n      dataForm: {\n      }\n    }\n  },\n  components: { baseDialog, baseUpload },\n  methods: {\n    init() {\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    buildFormData(dom) {\n      let formData = new FormData(dom)\n      for (let i = 0; i < dom.length; i++) {\n        let element = dom[i]\n        if (element['type'] === 'uploadFile' && element.files.length === 0) {\n          formData.delete(element.name)\n        }\n      }\n      return formData\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let formData = this.buildFormData(this.$refs.dataForm.$el)\n      this.$refs.dataForm.validate((valid) => {\n        this.$http({\n          url: this.$http.adornUrl('/label/upload'),\n          method: 'post',\n          data: formData\n        }).then(({ data }) => {\n          if (data.success) {\n            this.$message({\n              dangerouslyUseHTMLString: true,\n              message: '上传成功，总计：'+data.payload.total +'个，成功：'+data.payload.success+ '个，跳过：'+data.payload.fail+'个，<br/><br/>'+'系统已存在如下标签：'+data.payload.skip,\n              type: 'success'\n            })\n            this.$parent.hide()\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    },\n    download() {\n      this.$http.download(this.$http.adornUrl('/label/download'))\n      //window.location.href = 'http://10.1.32.44:8081/label/download'\n    },\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n<style scoped>\n  /*::v-deep .el-form-item{*/\n  /*  width: 100%;*/\n  /*}*/\n  ::v-deep .el-form{\n    width: 100%;\n  }\n\n</style>\n"]}]}