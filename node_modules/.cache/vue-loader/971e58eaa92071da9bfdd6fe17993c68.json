{"remainingRequest":"/Users/mac/Documents/code/iot/pms-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/pms-ui/src/views/modules/resourceManagement/deptManagement/addOrUpdata.vue?vue&type=style&index=0&id=e0d3ce64&scoped=true&lang=css&","dependencies":[{"path":"/Users/mac/Documents/code/iot/pms-ui/src/views/modules/resourceManagement/deptManagement/addOrUpdata.vue","mtime":1704298366256},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCjo6di1kZWVwIC5lbC1mb3JtLWl0ZW1fX2xhYmVsewogIHdpZHRoOiAxMDBweDsKfQo="},{"version":3,"sources":["addOrUpdata.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAuJA;AACA;AACA","file":"addOrUpdata.vue","sourceRoot":"src/views/modules/resourceManagement/deptManagement","sourcesContent":["<template>\n  <div class=\"mdgContent\">\n    <el-container class=\"el-container__mdgContent\">\n      <el-form :inline=\"true\" :rules=\"dataRule\" :model=\"dataForm\" ref=\"dataForm\">\n        <div>\n          <el-form-item label=\"部门ID\" prop=\"id\" >\n            <el-input v-model=\"dataForm.id\"  clearable :disabled=\"true\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"部门名称\" prop=\"phone\">\n            <el-input v-model=\"dataForm.deptName\"  placeholder=\"请输入部门名称\" clearable></el-input>\n          </el-form-item>\n          <el-form-item label=\"部门负责人\" prop=\"managerId\">\n            <el-select  v-model=\"managerId\" placeholder=\"请选择部门负责人\" >\n              <el-option      v-for=\"item in managerList\"\n                              :key=\"item.managerId\"\n                              :label=\"item.managerName\"\n                              :value=\"item.managerId\">\n              </el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item label=\"上级部门\" prop=\"parentId\">\n            <el-select  v-model=\"parentId\" placeholder=\"请选择上级部门\" >\n              <el-option      v-for=\"item in deptList\"\n                              :key=\"item.id\"\n                              :label=\"item.deptName\"\n                              :value=\"item.id\">\n              </el-option>\n            </el-select>\n          </el-form-item>\n          <div style=\"margin-top:20px;text-align:center;\">\n            <el-form-item>\n              <el-button type=\"primary\" @click=\"addOrUpdateHandle()\">提交</el-button>\n              <el-button  @click=\"cancelDialog()\">取消</el-button>\n            </el-form-item>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    // 邮箱验证\n    var validEmail = (rule, value, callback) => {\n      let reg = /^([A-Za-z0-9_\\-\\.])+\\@([A-Za-z0-9_\\-\\.])+\\.([A-Za-z]{2,4})(,([A-Za-z0-9_\\-\\.])+\\@([A-Za-z0-9_\\-\\.])+\\.([A-Za-z]{2,4}))*$/\n      if (value === '' || value === undefined || value === null) {\n        callback()\n      } else {\n        if (reg.test(value)) {\n          callback()\n        } else {\n          callback(new Error('邮箱格式错误'))\n        }\n      }\n    }\n    return {\n      query: false,\n      managerList:[],\n      deptList:[],\n      managerId:\"\",\n      parentId:\"\",\n      dataForm: {\n        id:'',\n        deptName: '',\n        managerName: '',\n        managerId: '',\n        parentId: ''\n      },\n      dataRule: {\n        deptName: [\n          { required: false, message: '部门名称不能为空', trigger: 'blur' }\n        ],\n        managerId: [\n          { required: false, message: '请选择部门负责人', trigger: 'blur' }\n          ]\n      }\n    }\n  },\n  methods: {\n    init(list, query, managerList) {\n      this.managerList = managerList\n      this.query = query\n      this.dataForm.id = list.id\n      this.dataForm.deptName = list.deptName\n      this.managerId = list.managerId\n      this.parentId = list.parentId\n\n      //初始化deptList\n      this.$http({\n        url: this.$http.adornUrl('/deptInfo/listAll'),\n        method: 'get'\n      }).then(({data}) => {\n        if (data && data.code === 200) {\n          this.deptList = data.payload.list\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n\n\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let url\n      if(this.query){\n        url = '/deptInfo/update'\n      }else{\n        url = '/deptInfo/add'\n      }\n\n\n      this.managerList.forEach(manager =>{\n        if(manager.managerId == this.managerId){\n          this.managerName = manager.managerName\n        }\n      })\n      this.$http({\n        url: this.$http.adornUrl(url),\n        method: 'post',\n        data: this.$http.adornData({\n          'deptName': this.dataForm.deptName,\n          'managerName': this.managerName,\n          'managerId': this.managerId,\n          'parentId': this.parentId,\n        })\n      }).then(({ data }) => {\n        if (data.success) {\n          this.$emit('refreshDataList')\n          this.$parent.hide()\n          this.$message({\n            message: '操作成功',\n            type: 'success'\n          })\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n\n<style scoped>\n  ::v-deep .el-form-item__label{\n    width: 100px;\n  }\n</style>\n"]}]}