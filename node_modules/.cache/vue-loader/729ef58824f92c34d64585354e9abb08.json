{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/CompanyQualificationInquiry/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/CompanyQualificationInquiry/index.vue","mtime":1694618820694},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAwFA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;;AAGA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/modules/CompanyQualificationManagement/CompanyQualificationInquiry","sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container style=\"height: 100%; border: 1px solid #eee\">\n      <el-header style=\"height: auto;\">\n        <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n          <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n            <el-form-item label=\"文件名称:\" prop=\"fileName\">\n              <el-input v-model=\"dataForm.fileName\" placeholder=\"请输入文件名称\" clearable></el-input>\n            </el-form-item>\n\n            <el-form-item label=\"文件说明:\" prop=\"fileDescription\">\n              <el-input v-model=\"dataForm.fileDescription\" placeholder=\"请输入文件说明\" clearable></el-input>\n            </el-form-item>\n            <el-form-item label=\"上传时间:\" prop=\"signedDate\">\n              <el-date-picker v-model=\"signedDate\" type=\"daterange\" value-format=\"yyyy-MM-dd\" placeholder=\"选择日期\" style=\"width: 100%\"/>\n            </el-form-item>\n            <el-form-item label=\"文件类型:\" prop=\"filetype\">\n              <el-autocomplete\n                value-key=\"name\"\n                v-model=\"dataForm.filetype\"\n                placeholder=\"请选择文件类型\"\n                clearable\n                :fetch-suggestions=\"handleSelect\"\n                @select=\"getSelect($event,'filetype')\"\n                @change=\"change\"\n              >\n                <template slot-scope=\"{ item }\">\n                  <div class=\"name\">{{ item.filetype }}</div>\n                </template>\n              </el-autocomplete>\n            </el-form-item>\n            <div style=\"display: contents;\">\n              <el-button type=\"primary\" @click=\"refresh()\" icon=\"el-icon-search\" style=\"margin-right: 20px\">查询</el-button>\n              <el-button type=\"primary\" @click=\"resetForm()\" icon=\"el-icon-search\">重置</el-button>\n            </div>\n          </div>\n        </el-form>\n      </el-header>\n      <div style=\"background: rgb(236, 245, 255);padding:5px 0 2px 2px;\">\n        <el-button type=\"primary\" @click=\"typeList()\" class=\"el-button-func\" style=\"width: 110px\">文件类型管理</el-button>\n        <el-button class=\"el-button-func\" type=\"primary\" @click=\"addOrAlter()\">添加资质</el-button>\n        <el-button class=\"el-button-func\" type=\"primary\" @click=\"moredownload()\">批量下载</el-button>\n      </div>\n      <baseTable :tableData=\"tableData\" ref=\"table\" :multiSelect=\"true\">\n        <template v-slot:clientType=\"row\">\n          <!--类型插槽-->\n          <template>\n            <svg-icon :icon-class=\"'download'\" style=\"height:1.5em;width:1.5em; margin-right: 2em;\" @click=\"downloadList(row)\"/>\n            <svg-icon :icon-class=\"'eye-blackopen'\" style=\"height:1.5em;width:1.5em; margin-right: 2em;\" @click=\"showImage(row)\"/>\n            <svg-icon :icon-class=\"'delete'\" style=\"height:1.5em;width:1.5em;\" @click=\"deleteList(row)\"/>\n          </template>\n        </template>\n      </baseTable>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"addOrUpdateDialog\" :width=\"'450px'\" :height=\"'600px'\">\n      <template>\n        <addOrUpdate @refreshDataList=\"refresh\" ref=\"addOrUpdate\"></addOrUpdate>\n      </template>\n    </baseDialog>\n\n    <baseDialog :title=\"titles\" ref=\"typeDialog\" :width=\"'450px'\" :height=\"'600px'\">\n      <template>\n        <div style=\"background: rgb(236, 245, 255);padding:5px 0 2px 2px;\">\n          <el-button class=\"el-button-func\" style=\"width: 110px\" type=\"primary\" @click=\"editType()\">添加文件类型</el-button>\n        </div>\n        <baseTableNoSelect :tableData=\"typeTableData\" ref=\"typeTable\">\n          <template v-slot:clientType=\"row\">\n            <!--类型插槽-->\n            <template>\n              <svg-icon :icon-class=\"'edit'\" style=\"height:1.5em;width:1.5em; margin-right: 2em;\" @click=\"editType(row)\"/>\n              <svg-icon :icon-class=\"'delete'\" style=\"height:1.5em;width:1.5em;\" @click=\"deleteType(row)\"/>\n            </template>\n          </template>\n        </baseTableNoSelect>\n      </template>\n    </baseDialog>\n    <baseDialog :title=\"titles\" ref=\"imageDialog\" :width=\"'550px'\">\n      <el-image :src=\"item\" v-for=\"item in imageBaseUrl\" style=\"height: 100%;max-width: 550px;\" :preview-src-list=\"[item]\"></el-image>\n    </baseDialog>\n    <baseDialog  :title=\"typeTitle\" ref=\"typeEditDialog\" :width=\"'550px'\">\n      <el-input style=\"height: 100%;max-width: 550px;\" v-model=\"typeName\"/>\n      <div style=\"width: 100%;text-align: right\">\n        <el-button type=\"primary\" @click=\"submit()\">提交</el-button>\n      </div>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport baseTable from '../../base/baseTable.vue'\nimport baseTableNoSelect from '../../base/baseTableNoSelect.vue'\nimport baseDialog from '../../base/baseDialog.vue'\nimport addOrUpdate from './addOrUpdata.vue'\n\nexport default {\n  data() {\n    return {\n      typeTitle:'',\n      typeId:undefined,\n      typeName:'',\n      passwordType: true,\n      signedDate: [],\n      tagTypeList: [],\n      sortsList: [],\n      titles: '',\n      imageBaseUrl: '',\n      dataForm: {\n        fileName: '',\n        filetype: '',\n        fileTypeId: '',\n        fileDescription: '',\n        startUploadTime: '',\n        endUploadTime: ''\n      },\n      tableData: {\n        theads: [\n          { label: '文件名称', prop: 'fileName' },\n          { label: '文件类型', prop: 'filetype' },\n          { label: '文件说明', prop: 'fileDescription' },\n          { label: '上传时间', prop: 'uploadTime' },\n          { label: '上传人', prop: 'uploader' },\n          { label: '操作', prop: 'clientType', slotName: 'clientType' }\n        ],\n        url: '/companyqualifications/list'\n      },\n      typeTableData:{\n        theads: [\n          { label: '文件类型', prop: 'filetype' },\n          { label: '操作', prop: 'clientType', slotName: 'clientType' }\n        ],\n        url: '/companyqualifications/typeList'\n      }\n    }\n  },\n  components: {\n    baseTable, baseDialog, addOrUpdate,baseTableNoSelect\n  },\n  mounted() {\n    if (this.signedDate[0]) {\n      this.dataForm.startUploadTime = this.signedDate[0]\n      this.dataForm.endUploadTime = this.signedDate[1]\n    }else{\n      this.dataForm.startUploadTime = ''\n      this.dataForm.endUploadTime = ''\n    }\n    this.$refs.table.refresh(this.dataForm)\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        if (this.signedDate[0]) {\n          this.dataForm.startUploadTime = this.signedDate[0]\n          this.dataForm.endUploadTime = this.signedDate[1]\n        }else{\n          this.dataForm.startUploadTime = ''\n          this.dataForm.endUploadTime = ''\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    addOrAlter() {\n      this.titles = '添加资质'\n      this.$refs.addOrUpdateDialog.show()\n      this.$nextTick(() => {\n        this.$refs.addOrUpdate.init('add', false)\n      })\n    },\n    typeList() {\n      this.$refs.typeDialog.show()\n      this.$nextTick(() => {\n        this.$refs.typeTable.refresh()\n      })\n    },\n    moredownload() {\n      let list = this.$refs.table.getSelectRow()\n      var ids = list.map(item => {\n        return item.id\n      })\n      var idss = ids.join(',')\n      this.$http.download(this.$http.adornUrl('/companyqualifications/moreDownload'), this.$http.adornParams({'ids' : idss }), this).then(function(b) {}).catch(function(error){\n        setTimeout(function() {\n\t\t\t    alert('找不到文件')\n        }, 500)\n      })\n    },\n    submit(){\n      if(this.typeId) {\n        this.$http({\n          url: this.$http.adornUrl(`/companyqualifications/typeUpdate`),\n          method: 'PUT',\n          data: {typeId: this.typeId, filetype: this.typeName}\n        }).then(({data}) => {\n          if (data && data.code === 200) {\n            this.$message({\n              message: '修改成功',\n              type: 'success'\n            })\n            this.$refs.typeEditDialog.hide()\n            this.$refs.typeTable.refresh()\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      }else{\n        this.$http({\n          url: this.$http.adornUrl(`/companyqualifications/typeInsert`),\n          method: 'post',\n          data: {typeId: this.typeId, filetype: this.typeName}\n        }).then(({data}) => {\n          if (data && data.code === 200) {\n            this.$message({\n              message: '添加成功',\n              type: 'success'\n            })\n            this.$refs.typeEditDialog.hide()\n            this.$refs.typeTable.refresh()\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      }\n    },\n    downloadList(row) {\n      let userIds = row.item.id\n      this.$http.download(this.$http.adornUrl('/companyqualifications/download'), this.$http.adornParams({ 'id': userIds }), this).then(function(b) {}).catch(function(error){\n        setTimeout(function() {\n\t\t\t    alert('找不到文件')\n        }, 500)\n      })\n    },\n    alter(row) {\n      this.titles = '修改用户'\n      this.$refs.addOrUpdateDialog.show()\n      this.$nextTick(() => {\n        this.$refs.addOrUpdate.init(row.item, true)\n      })\n    },\n    deleteList(row) {\n      this.$confirm(`您确定删除吗?`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.$http({\n          url: this.$http.adornUrl(`/companyqualifications/delete?id=`+row.item.id),\n          method: 'DELETE'\n        }).then(({data}) => {\n          if (data && data.code === 200) {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            })\n            this.refresh()\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    editType(row){\n      if(row) {\n        this.typeId = row.item.typeId\n        this.typeName = row.item.filetype\n        this.typeTitle = '文件类型编辑'\n      }else{\n        this.typeId = undefined\n        this.typeName = ''\n        this.typeTitle = '文件类型添加'\n      }\n      this.$refs.typeEditDialog.show()\n    },\n    deleteType(row){\n      this.$confirm(`您确定删除吗?`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.$http({\n          url: this.$http.adornUrl(`/companyqualifications/typeDel?id=`+ row.item.typeId),\n          method: 'DELETE'\n        }).then(({data}) => {\n          if (data && data.code === 200) {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            })\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n        this.$refs.typeTable.refresh()\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    handleSelect(queryString, cb) {\n      this.$http({\n        url: this.$http.adornUrl('/companyqualifications/typeList'),\n        method: 'get',\n        params: this.$http.adornParams({ 'filetype': this.dataForm.filetype })\n      }).then(({ data }) => {\n        if (data && data.code === 200) {\n          cb(data.payload.list)\n        } else {\n          cb([])\n        }\n      })\n    },\n    getSelect(item) {\n      if (this.dataForm.filetype === '') {\n        this.dataForm.filetype = ''\n        this.dataForm.fileTypeId = ''\n      } else {\n        this.dataForm.filetype = item.filetype\n        this.dataForm.fileTypeId = item.typeId\n      }\n    },\n    change() {\n      if (this.dataForm.filetype === '') {\n        this.dataForm.fileTypeId = ''\n      }\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n      this.signedDate=[]\n    },\n    showImage(row) {\n      let id = row.item.id\n      this.$http({\n        url: this.$http.adornUrl(`/companyqualifications/getImages`),\n        method: 'get',\n        params: this.$http.adornParams({\n          'id': id\n        })\n\n\n        // data: this.$http.adornParams({ 'id': userIds })\n      }).then(({ data }) => {\n        if (data && data.success && data.payload.length > 0) {\n          this.imageBaseUrl = data.payload\n          this.$refs.imageDialog.show()\n        } else {\n          this.$message.warning('该文件非图片，无法预览，请下载后查看。')\n        }\n      })\n    }\n  }\n}\n</script>\n<style scoped>\n.el-header {\n  color: #333;\n  padding: 0 0;\n}\n\n.el-form--inline > .inputlist {\n  padding-top: 20px;\n  padding-left: 20px;\n  display: flex;\n}\n\n.el-form--inline > .inputlist > .el-form-item {\n  width: 26%;\n  margin-bottom: 20px;\n}\n\n.el-form-item__content {\n  width: 200px;\n}\n\n.el-button {\n  width: 80px;\n  height: 35px;\n}\n\n.el-button-func {\n  width: 86px;\n  height: 30px;\n  text-align: center;\n}\n::v-deep .el-table__cell{\n  text-align: center;\n}\n::v-deep .el-form-item__content{\n  width: 63% ;\n}\n</style>\n<style>\n::-webkit-scrollbar { /*滚动条整体样式*/\n  width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n  height: 1px;\n}\n\n::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n  border-radius: 10px;\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  background: #e1f1f1;\n}\n\n::-webkit-scrollbar-track { /*滚动条里面轨道*/\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  border-radius: 10px;\n  background: #fff;\n}\n</style>\n"]}]}