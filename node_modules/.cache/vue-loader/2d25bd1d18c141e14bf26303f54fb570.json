{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/bidDocumentLibrary/index.vue?vue&type=style&index=0&id=dbfcfe64&scoped=true&lang=css&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/bidDocumentLibrary/index.vue","mtime":1694618820696},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAmIA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;;AAEA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/modules/CompanyQualificationManagement/bidDocumentLibrary","sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container style=\"height: 100%; border: 1px solid #eee\">\n      <el-header style=\"height: auto;\">\n        <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n          <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n            <el-form-item label=\"文件名称:\" prop=\"documentName\">\n              <el-input v-model=\"dataForm.documentName\" placeholder=\"请输入文件名称\" clearable></el-input>\n            </el-form-item>\n            <div style=\"display: contents;\">\n              <el-button type=\"primary\" @click=\"refresh()\" icon=\"el-icon-search\" style=\"margin-right: 20px\">查询\n              </el-button>\n              <el-button type=\"primary\" @click=\"resetForm()\" icon=\"el-icon-search\">重置</el-button>\n            </div>\n          </div>\n        </el-form>\n      </el-header>\n      <div style=\"background: rgb(236, 245, 255);padding:5px 0 2px 2px;\">\n        <el-button class=\"el-button-func\" type=\"primary\" @click=\"addOrAlter()\">上传文档</el-button>\n      </div>\n      <baseTable :tableData=\"tableData\" ref=\"table\" type=\"\" :multiSelect=\"true\">\n        <template v-slot:clientType=\"row\">\n          <!--类型插槽-->\n          <template>\n            <svg-icon :icon-class=\"'download'\" style=\"height:1.5em;width:1.5em; margin-right: 2em;\" @click=\"downloadList(row)\"/>\n            <svg-icon :icon-class=\"'delete'\" style=\"height:1.5em;width:1.5em;\" @click=\"deleteList(row)\"/>\n          </template>\n        </template>\n      </baseTable>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"pictureListDialog\" :width=\"'500px'\" :height=\"'500px'\">\n      <template>\n        <pictureList @refreshDataList=\"refresh\" ref=\"pictureList\"></pictureList>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport baseTable from '../../base/baseTable.vue'\nimport baseDialog from '../../base/baseDialog.vue'\nimport pictureList from './picture.vue'\nexport default {\n  data() {\n    return {\n      passwordType: true,\n      signedDate: '',\n      titles: '',\n      dataForm: {\n        documentName: ''\n      },\n      tableData: {\n        theads: [\n          // { label: '序号', prop: 'documentId' },\n          { label: '文件名称', prop: 'documentName' },\n          { label: '上传时间', prop: 'uploadTime' },\n          { label: '上传人', prop: 'uploader' },\n          { label: '操作', prop: 'clientType', slotName: 'clientType' }\n        ],\n        url: '/tenderdocuments/list'\n      }\n    }\n  },\n  components: {\n    baseTable, baseDialog, pictureList\n  },\n  mounted() {\n    this.$refs.table.refresh(this.dataForm)\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    addOrAlter() {\n      this.titles = '上传文件'\n      this.$refs.pictureListDialog.show()\n    },\n    downloadList(row) {\n      let userIds = row.item.documentId\n      this.$http.download(this.$http.adornUrl('/tenderdocuments/download'), this.$http.adornParams({ 'documentId': userIds }), this).then(function(b) {}).catch(function(error){\n        setTimeout(function() {\n\t\t\t    alert('找不到文件')\n        }, 500)\n      })\n    },\n    alter(row) {\n      this.titles = '修改用户'\n      this.$refs.addOrUpdateDialog.show()\n      this.$nextTick(() => {\n        this.$refs.addOrUpdate.init(row.item, true)\n      })\n    },\n    deleteList(row) {\n      let userIds = row.item.documentId\n      this.$confirm(`您确定删除吗?`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.$http({\n          url: this.$http.adornUrl(`/tenderdocuments/delete?documentId=${userIds}`),\n          method: 'DELETE'\n        }).then(({ data }) => {\n          if (data && data.code === 200) {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            })\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n        this.refresh()\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        })\n      })\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    }\n  }\n}\n</script>\n<style scoped>\n.el-header {\n  color: #333;\n  padding: 0 0;\n}\n\n.el-form--inline > .inputlist {\n  padding-top: 20px;\n  padding-left: 20px;\n  display: flex;\n}\n\n.el-form--inline > .inputlist > .el-form-item {\n  width: 26%;\n  margin-bottom: 20px;\n}\n\n.el-form-item__content {\n  width: 200px;\n}\n\n.el-button {\n  width: 80px;\n  height: 35px;\n}\n\n.el-button-func {\n  width: 86px;\n  height: 30px;\n  text-align: center;\n}\n::v-deep .el-table__cell{\n  text-align: center;\n}\n::v-deep .el-form-item__content{\n  width: 63% ;\n}\n</style>\n<style>\n::-webkit-scrollbar { /*滚动条整体样式*/\n  width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n  height: 8px;\n}\n\n::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n  border-radius: 10px;\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  background: #e1f1f1;\n}\n\n::-webkit-scrollbar-track { /*滚动条里面轨道*/\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  border-radius: 10px;\n  background: #fff;\n}\n</style>\n"]}]}