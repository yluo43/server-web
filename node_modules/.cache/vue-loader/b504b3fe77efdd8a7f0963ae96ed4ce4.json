{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/labelDatabaseManagement/add.vue?vue&type=style&index=0&id=b3dbb6dc&scoped=true&lang=css&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/labelDatabaseManagement/add.vue","mtime":1694618820711},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCjo6di1kZWVwIC5lbC1mb3JtLWl0ZW1fX2xhYmVsewogIHdpZHRoOiAxMDBweDsKfQo="},{"version":3,"sources":["add.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA2FA;AACA;AACA","file":"add.vue","sourceRoot":"src/views/modules/labelDatabaseManagement","sourcesContent":["<!-- 自动发书管理-新增图书-新增 -->\n<template>\n  <div class=\"mdgContent\">\n    <el-container class=\"el-container__mdgContent\">\n      <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n        <div>\n          <el-form-item label=\"标签类型:\" prop=\"sorts\">\n            <el-select v-model=\"dataForm.sortId\" placeholder=\"请选择\" @change=\"sortslist\">\n              <el-option\n                v-for=\"(item, i) in sortsList\"\n                :key=\"i\"\n                :label=\"item.name\"\n                :value=\"item.id\"\n                ref=\"coverSize\"\n              ></el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item label=\"标签词:\" prop=\"keyword\">\n            <el-input v-model=\"dataForm.keyword\" maxlength=\"255\" style=\"width: 200px;\"></el-input>\n          </el-form-item>\n          <div style=\"margin-top:20px;text-align:center;\">\n            <el-form-item>\n              <el-button type=\"success\" @click=\"addOrUpdateHandle()\">提交</el-button>\n              <el-button type=\"danger\" @click=\"cancelDialog()\">取消</el-button>\n            </el-form-item>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      tagTypeList: [],\n      sortsList: [],\n      dataForm: {\n        sortId: '',\n        keyword: ''\n      }\n    }\n  },\n  mounted() {\n    this.$http({\n      url: this.$http.adornUrl('/label/sorts'),\n      method: 'get'\n    }).then(({ data }) => {\n      this.tagTypeList = data.payload\n      this.tagTypeList.forEach((item) => {\n        this.sortsList.push({ id: item.id, name: item.name })\n      })\n    })\n  },\n  methods: {\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    // 新增\n    addOrUpdateHandle() {\n      this.$http({\n        url: this.$http.adornUrl('/label/label'),\n        method: 'post',\n        data: this.$http.adornData({\n          'sortId': this.dataForm.sortId,\n          'name': this.dataForm.keyword\n        })\n      }).then(({ data }) => {\n        if (data.success) {\n          this.$emit('refreshDataList')\n          this.$parent.hide()\n          this.$message({\n            message: '添加成功',\n            type: 'success'\n          })\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    sortslist(value) {\n      this.dataForm.sorts = value\n    },\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n<style scoped>\n  ::v-deep .el-form-item__label{\n    width: 100px;\n  }\n</style>\n"]}]}