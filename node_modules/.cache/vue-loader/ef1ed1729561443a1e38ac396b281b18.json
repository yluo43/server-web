{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/contractManagement/wordsSearch/index.vue?vue&type=style&index=0&id=421a7ffc&scoped=true&lang=css&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/contractManagement/wordsSearch/index.vue","mtime":1694618820710},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAsHA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/modules/contractManagement/wordsSearch","sourcesContent":["<template>\n  <div style=\"height: 100%;width: 100%;\">\n    <el-container style=\"height: 100%;width: 100%;\">\n      <el-header style=\"height: auto;margin-bottom:1.5%\">\n      <el-form :inline=\"true\" :model=\"dataForm\"  ref=\"dataForm\" style=\"width:100%;\">\n        <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n          <div class=\"orManagement\" style=\"margin: 0 auto;display: block;width: 600px;\">\n            <el-form-item label=\"历史关键词:\" prop=\"words\">\n              <el-input v-model=\"dataForm.words\" placeholder=\"请输入关键词\"  clearable></el-input>\n            </el-form-item>\n            <el-form-item label=\"任务状态:\" prop=\"status\">\n              <el-select v-model=\"dataForm.status\" placeholder=\"请选择角色类型\">\n                <el-option label=\"全部\" value=\"\"></el-option>\n                <el-option      v-for=\"item in statusList\"\n                                :key=\"item.id\"\n                                :label=\"item.name\"\n                                :value=\"item.id\">\n                </el-option>\n              </el-select>\n            </el-form-item>\n          </div>\n          <div style=\"display: block;width: 493px; margin: 0 auto\">\n            <el-button type=\"primary\" @click=\"refresh()\" style=\"width: 100px\" icon=\"el-icon-search\" >查询</el-button>\n            <el-button type=\"danger\"  @click=\"cancel()\">重置</el-button>\n            <el-button type=\"primary\"  @click=\"batchAdd()\" style=\"width: 110px\">新增检索任务</el-button>\n          </div>\n        </div>\n      </el-form>\n      </el-header>\n      <baseTable :tableData=\"tableData\" ref=\"table\" :multiSelect=\"true\"  >\n        <template v-slot:clientType=\"row\">\n          <!--类型插槽-->\n          <template>\n            <el-tag type=\"primary\" @click=\"download(row.item)\">下载</el-tag>\n          </template>\n        </template>\n      </baseTable>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"batchAddDialog\" :width=\"'500px'\" :height=\"'300px'\">\n      <template>\n        <batchAdd :refreshDataList=\"refresh\" ref=\"batchAdd\" ></batchAdd>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport baseTable from '../../base/baseTableNoSelect.vue'\nimport baseDialog from '../../base/baseDialog.vue'\nimport batchAdd from \"./add\";\nexport default {\n  data() {\n    return {\n      titles: '',\n      statusList: [\n        {id:0,name:'进行中'},\n        {id:1,name:'成功'},\n        {id:2,name:'失败'}\n      ],\n      dataForm: {\n        words: '',\n        status: ''\n      },\n      tableData: {\n        theads: [\n          { label: '搜索词',  prop: 'words' },\n          { label: '状态', prop: 'statusName' ,formatter: function (row){\n            switch (row.status){\n              case 0: return '进行中'\n              case 1: return '成功'\n              case 2: return '失败'\n            }\n            } },\n          { label: '结果', prop: 'result' ,formatter: function (row){\n              if(row.status===0){\n                return '匹配中'\n              }\n              switch (row.result){\n                case 0: return '无文件'\n                case 1: return '有文件'\n              }\n            } },\n          { label: '搜索人', prop: 'chineseName'},\n          { label: '创建时间', prop: 'createTime'},\n          { label: '操作', prop: '', slotName: 'clientType'}\n        ],\n        url: '/contractManager/word/search/list'\n      },\n    }\n  },\n  mounted() {\n    this.$refs.table.refresh(this.dataForm);\n  },\n  components: {\n     baseDialog,batchAdd,baseTable\n  },\n  methods: {\n    refresh(){\n      this.$refs.table.refresh(this.dataForm);\n    },\n    download(row) {\n      if(row.status!==1){\n        this.$message.warning('该任务仍在进行中或已失败，不存在结果execl文件')\n      }else {\n        this.$http.download(this.$http.adornUrl('/contractManager/words/download'), this.$http.adornParams({taskId: row.taskId}), this)\n      }\n    },\n    batchAdd() {\n      this.titles = '全文检索'\n      this.$refs.batchAddDialog.show()\n    },\n    cancel(){\n      this.dataForm.status=''\n      this.dataForm.words=''\n    }\n  }\n}\n</script>\n<style scoped>\n  .el-form--inline>.inputlist>.orManagement>.el-form-item{\n    margin-top: 20px;\n  }\n  .el-form--inline>.inputlist>.orderInformation>.el-form-item{\n    width: 25%;\n  }\n  .el-input{\n    width: 200px\n  }\n  .el-button{\n    width: 90px;\n    height: 40px;\n    margin-right: 50px;\n  }\n  .base-pic-upload .el-upload{\n    text-align: center;\n    display: inline-block;\n  }\n</style>\n"]}]}