" @remove-tag=\"deledata\">\n              <el-option\n                v-for=\"items in item\"\n                :key=\"items.id\"\n                :label=\"items.name\"\n                :value=\"items.id\"\n                disabled>\n              </el-option>\n            </el-select>\n          </el-form-item>\n        </div>\n      </div>\n    </el-form>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      datalist: [],\n      dataslist: false,\n      dataForm: {\n\n      },\n      options: [\n      ],\n    }\n  },\n  props: {\n      dialogName: {\n        type: String\n      },\n      parentRefresh: {\n        type: Function\n      }\n    },\n  mounted() {\n    this.$http({\n      url: this.$http.adornUrl('/label/labels'),\n      method: 'get'\n    }).then(({ data }) => {\n      this.datalist = data.payload\n    })\n  },\n  methods: {\n    init(list) {\n      this.$http({\n        url: this.$http.adornUrl('/label/labels'),\n        method: 'get'\n      }).then(({ data }) => {\n        if (data.success) {\n          this.datalist = list\n        }\n      })\n    },\n    refresh() {\n      this.$refs.table.refresh()\n    },\n    deledata(item) {\n      this.$confirm(`您确定删除该标签吗?`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.$http({\n          url: this.$http.adornUrl(`/label/label/${item}`),\n          method: 'DELETE'\n        }).then(({ data }) => {\n          if (data.success) {\n            this.$emit('reftoo')\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            })\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        })\n      })\n    },\n    closeIt(index) {\n      this.$nextTick(() => {\n        this.$refs['selectIt${index}'][0].blur()\n        this.$refs['selectIt${index}'][1].blur()\n        this.$refs['selectIt${index}'][2].blur()\n        this.$refs['selectIt${index}'][3].blur()\n      })\n    }\n  }\n}\n</script>\n<style scoped>\n  .base-pic-upload{\n    background: rgb(236, 245, 255);\n    min-height: 490px;\n  }\n /*取消eb-upload默认的按钮栏样式，用于按钮隐藏多余突出白块 */\n.base-pic-upload .el-upload{\n  display: block;\n  text-align: center;\n  line-height: 100px;\n}\n.base-pic-upload .selectlist{\n  width: 100%;\n  height: 200px;\n}\n.el-form--inline .el-form-item{\n  display: block;\n  width: 100%;\n\n\n}\n::v-deep .el-input--suffix>.el-input__inner{\n  width: 100%;\n  height: 200px;\n}\n::v-deep .selectlist>.el-select__tags{\n  overflow: auto;\n  height: 180px;\n}\n ::v-deep .el-input--suffix>.el-input__suffix{\n  display: none;\n}\n/* ::v-deep .el-form--inline>.inputlist>.el-form-item{*/\n/*  width: 42%;*/\n/*}*/\n .list-div{\n   width: 32%;\n   float: left;\n }\n.labellists{\n  padding-left: 20px;\n}\n.labellists::v-deep .el-form-item>.el-form-item__label{\n  font-weight: 600;\n  font-size: 15px;\n  width: 83%;\n  text-align: center;\n}\n  ::v-deep .el-form-item__content{\n    width: 80%;\n  }\n</style>\n\n<style>\n  /* .el-form--inline>.inputlist>.el-form-item{*/\n  /*  width: 100%;*/\n  /*}*/\n</style>\n"]}]}