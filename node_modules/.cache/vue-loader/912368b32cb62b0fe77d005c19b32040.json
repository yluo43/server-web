{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/contractManagement/upload/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/contractManagement/upload/index.vue","mtime":1694618820710},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;AAuBA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/modules/contractManagement/upload","sourcesContent":["<template>\n  <div style=\"height: 200px\">\n    <el-container >\n        <div  style=\"width: 100%;vertical-align: middle;display: flex;align-items: center;justify-content: center\">\n          <el-upload\n            action=\"#\"\n            :auto-upload=\"false\"\n            :on-change=\"handleOnChange\"\n            :on-remove=\"handleOnRemove\"\n            :file-list=\"fileList\"\n            accept=\".zip\"\n            ref=\"upload\"\n          >\n            <div  class=\"test\">\n              <el-button slot=\"trigger\" size=\"small\" type=\"primary\">选择文件</el-button>\n              <!--        <el-button size=\"small\" type=\"danger\" @click.stop=\"cancelFiles()\">删除文件</el-button>-->\n            </div>\n          </el-upload>\n        </div>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseUpload from '../../base/baseUpload.vue'\nexport default {\n  data() {\n    return {\n      fileList: [],\n      dataForm: {\n        name: '',\n        pageSize: ''\n      }\n    }\n  },\n  components: {\n    baseUpload\n  },\n  props: {\n    dialogName: {\n      type: String\n    },\n    parentRefresh: {\n      type: Function\n    }\n  },\n  methods: {\n    getUrl(){\n      return this.$http.adornUrl('/contractManager/upload');\n    },\n    handleOnChange(file, fileList) {\n      let filetype = file.name.substr(file.name.lastIndexOf('.') + 1, file.name.length)\n      let flag = true\n      if (this.accept) {\n        let types = this.accept.replaceAll('.', '').split(',')\n        types.forEach((item, i) => {\n          if (item === filetype) {\n            flag = false\n          }\n        })\n      } else {\n        flag = false\n      }\n      if (flag) {\n        fileList.pop()\n        this.$message.warning('格式不正确')\n        return\n      } else {\n        if (this.onValid != null && !this.onValid(file, fileList)) {\n          fileList.pop()\n          // fileList.splice(0, fileList.length)\n          return\n        }\n      }\n      if (fileList.length > 1) {\n        fileList.shift()\n      }\n      this.isChanged = true\n      this.nowFileList = fileList\n      let formData = new FormData();\n      formData.append(\"file\",file.raw)\n      let loading = this.$loading({\n        lock: true, // lock的修改符--默认是false\n        text: '拼命导入中，请稍候...', // 显示在加载图标下方的加载文案\n        background: 'rgba(0,0,0,0.8)', // 遮罩层颜色\n        spinner: 'el-icon-loading' // 自定义加载图标类名\n      })\n      this.$parent.hide()\n      this.$http({\n        url: this.getUrl(),\n        method: \"post\",\n        data:formData,\n        headers: {\n          \"content-type\": \"multipart/form-data\",\n        }\n      }).then(({data}) => {\n        if(data.success){\n          loading.close()\n          this.$message({\n            message: '合同关键页导入成功',\n            type: 'success'\n          })\n\n        }else{\n          loading.close()\n          this.$message.warning(data.msg)\n        }})\n        .catch((e) => {\n          loading.close()\n          if (e !== null && e.toString().endsWith('exceeded')) {\n            this.$message.warning('请求超时')\n          } else {\n            this.$message.warning('请求异常')\n          }\n        })\n    },\n    handleOnRemove(file, fileList) {\n      this.isChanged = true\n      this.nowFileList = fileList\n    },\n  }\n}\n</script>\n<style scoped>\n  .el-header {\n    color: #333;\n    padding: 0 0;\n  }\n  .el-form--inline>.inputlist{\n    padding-top: 20px;\n    padding-left: 20px;\n    display: flex;\n  }\n  .el-form--inline>.inputlist>.el-form-item{\n    width: 340px;\n    margin-bottom: 20px;\n  }\n  .el-form-item__content{\n    width: 200px;\n  }\n  .el-button{\n    width: 90px;\n    height: 40px;\n  }\n</style>\n<style>\n  /*::-webkit-scrollbar { !*滚动条整体样式*!*/\n  /*  width: 8px; !*高宽分别对应横竖滚动条的尺寸*!*/\n  /*  height: 0px;*/\n  /*}*/\n  ::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n    border-radius: 10px;\n    -webkit-box-shadow: inset 0 0 0 rgba(0, 0, 0, 0.2);\n    background: #e1f1f1;\n  }\n  ::-webkit-scrollbar-track { /*滚动条里面轨道*/\n    -webkit-box-shadow: inset 0 0 0 rgba(0, 0, 0, 0.2);\n    border-radius: 10px;\n    background: #fff;\n  }\n</style>\n"]}]}