{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/authorityManagement/examineAndApprove/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/authorityManagement/examineAndApprove/index.vue","mtime":1694618820698},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA8DA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;;AAGA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;;AAEA;;AAEA","file":"index.vue","sourceRoot":"src/views/modules/authorityManagement/examineAndApprove","sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container style=\"height: 100%; border: 1px solid #eee\">\n      <el-header style=\"height: auto;\">\n        <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n          <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n            <el-form-item label=\"申请账号:\" prop=\"applicationAccount\">\n              <el-input v-model=\"dataForm.applicationAccount\" placeholder=\"请输入申请账号\" clearable></el-input>\n            </el-form-item>\n            <el-form-item label=\"审批状态:\" prop=\"approvalStatus\">\n              <el-select v-model=\"dataForm.approvalStatus\" placeholder=\"请选择\">\n                <el-option label=\"全部\" value=\"\"></el-option>\n                <el-option label=\"未审批\" value=\"0\"></el-option>\n                <el-option label=\"审批通过\" value=\"1\"></el-option>\n                <el-option label=\"审批不通过\" value=\"2\"></el-option>\n              </el-select>\n            </el-form-item>\n            <div>\n              <el-button type=\"primary\" @click=\"refresh()\" icon=\"el-icon-search\">查询</el-button>\n            </div>\n          </div>\n        </el-form>\n      </el-header>\n      <baseTable :tableData=\"tableData\" ref=\"table\" :multiSelect=\"true\">\n        <template v-slot:clientType=\"row\">\n          <!--类型插槽-->\n          <template>\n            <a  v-if=\"row.item.contractNum>0\" href=\"javascript:void(0)\" @click.prevent=\"contract(row)\" style=\"text-decoration:underline;color: blue\">{{row.item.contractNum+'个'||''}}</a>\n          </template>\n        </template>\n        <template v-slot:approvalStatus=\"row\">\n          <template v-if=\"row.item.approvalStatus == 0\">\n            <el-tag type=\"success\">未审批</el-tag>\n          </template>\n          <template v-if=\"row.item.approvalStatus == 1\">\n            <el-tag type=\"primary\">审批通过</el-tag>\n          </template>\n          <template v-if=\"row.item.approvalStatus == 2\">\n            <el-tag type=\"danger\">审批不通过</el-tag>\n          </template>\n        </template>\n        <template v-slot:exportType=\"row\">\n          <template>\n            <el-tag type=\"primary\" @click=\"exportType(row)\">导出</el-tag>\n          </template>\n        </template>\n      </baseTable>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"contractDownDialog\" :width=\"'1500px'\" :height=\"'800px'\">\n      <template>\n        <contractDown @refreshDataList=\"refresh\" ref=\"contractDown\"></contractDown>\n      </template>\n    </baseDialog>\n    <baseDialog title=\"下载选项\" ref=\"downloadContentDialog\" :width=\"'800px'\">\n      <template>\n        <downloadContent v-model=\"checkList\" @submit=\"submit()\" :labelList=\"labelList\" ref=\"downloadContent\"></downloadContent>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n\n<script>\nimport baseTable from '../../base/baseTable.vue'\nimport baseDialog from '../../base/baseDialog.vue'\nimport contractDown from './contractDown.vue'\nimport downloadContent from './downloadContent.vue'\nexport default {\n  data() {\n    return {\n      dataForm: {\n        approvalStatus: ''\n      },\n      tableData: {\n        theads: [\n          { label: '申请账号', prop: 'applicationAccount' },\n          { label: '申请时间', prop: 'applicationTime' },\n          { label: '下载内容', prop: 'downloadContent' },\n          { label: '合同编号', prop: 'contractNumber' },\n          { label: '合同详情', prop: 'contractNum', slotName: 'clientType' },\n          { label: '申请理由', prop: 'applicationReason' },\n          { label: '审批人', prop: 'approver' },\n          { label: '审批时间', prop: 'approvalTime' },\n          { label: '审批状态', prop: 'approvalStatus', slotName: 'approvalStatus' },\n          { label: '操作', prop: 'contractNumber', slotName: 'exportType' }\n        ],\n        url: '/applicationManager/list'\n      },\n      labelList:{\n        homePage:  {prop : \"homePage\", label : '合同首页'},\n        targetPage:  {prop : \"targetPage\", label : '合同标的页'},\n        amountPage:  {prop : \"amountPage\", label : '合同金额页'},\n        stampPage:  {prop : \"stampPage\", label : '签字盖章页'},\n        contentPage:  {prop : \"contentPage\", label : '合同内容页'},\n        orders:  {prop : \"orders\", label : '订单'},\n        invoices:  {prop : \"invoices\", label : '发票'},\n        acceptanceReport:  {prop : \"acceptanceReport\", label : '验收报告'},\n        teamMemberCertification:  {prop : \"teamMemberCertification\", label : '团队人员证明'},\n        partyACertification:  {prop : \"partyACertification\", label : '甲方证明'},\n      },\n        checkList: {\n          homePage: true,\n          targetPage: true,\n          amountPage: true,\n          stampPage: true,\n          contentPage: true,\n          orders: true,\n          invoices: true,\n          acceptanceReport: true,\n          teamMemberCertification: true,\n          partyACertification: true,\n        },\n      ContractDownDto: {\n\n      },\n\n    }\n  },\n  components: {\n    baseTable,baseDialog,contractDown,downloadContent\n  },\n  mounted() {\n    this.$refs.table.refresh(this.dataForm)\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    contract(row) {\n      this.titles = '查看详细信息'\n      this.$refs.contractDownDialog.show()\n      this.$nextTick(() => {\n        this.$refs.contractDown.init(row.item.applicationSign)\n      })\n    },\n\n    exportType(row) {\n      this.contractNumber = row.item.contractNumber\n      this.downloadContent = row.item.downloadContent\n      this.approvalStatus = row.item.approvalStatus\n      if(this.approvalStatus === '1') {\n        if (this.downloadContent === '合同整本') {\n          let contractNos = ''\n          let loading = this.$loading({\n            lock: true, // lock的修改符--默认是false\n            text: '拼命下载中，请稍候...', // 显示在加载图标下方的加载文案\n            background: 'rgba(0,0,0,0.8)', // 遮罩层颜色\n            spinner: 'el-icon-loading' // 自定义加载图标类名\n          })\n          contractNos = this.contractNumber\n          let that = this\n          this.$http.download(this.$http.adornUrl('/contractManager/exportWholeContract'), this.$http.adornParams({contractNos: contractNos}), this)\n            .then(function (b) {\n              loading.close()\n            }).catch(function (error) {\n            loading.close()\n            setTimeout(function () {\n              alert('请求超时')\n            }, 500)\n          })\n        }else{\n          this.$refs.table.selectone(row.item)\n\n          this.$refs.downloadContentDialog.show()\n          this.$nextTick(() => {\n            this.$refs.downloadContent.init(this.checkList)\n          })\n        }\n      }\n      else{\n        this.$message.error('审批通过后才能导出哦')\n      }\n    },\n    submit(){\n      let list = []\n      let row = this.$refs.table.getSingleSelectRow()\n      let selectWordContentDto=this.checkList\n      let result =Object.values(selectWordContentDto).every(val=>val ===false)\n      if(result){\n        this.$message.error('请选择至少选择一个导出选项')\n        return\n      }\n      this.ContractDownDto.downNo=row.applicationSign;\n      let that = this\n\n\n      this.$http({\n        method: \"get\",\n        url: that.$http.adornUrl(\"/applicationManager/selectAllContract\"),\n        params: that.$http.adornParams(Object.assign(this.ContractDownDto))\n      }).then(({data}) => {\n        if(data && data.code === 200){\n          list = data.payload\n          getWordPackage(list,selectWordContentDto,that)\n        }else{\n          that.$message.warning(data.msg)\n        }})\n\n      function getWordPackage(list, selectWordContentDto,that) {\n        let listId = list.map(item => {\n          if (item.labelNo = undefined) {\n            var data = {\n              'contractNo' : item.contractNo,\n              'labelIds' : item.labelNo.split(','),\n              'selectWordContentDto':selectWordContentDto\n            }\n          } else {\n            var data = {\n              'contractNo' : item.contractNo,\n              'selectWordContentDto':selectWordContentDto\n            }\n          }\n          return data\n        })\n        if (list.length < 1) {\n          this.$message.error('请选择导出合同')\n          return\n        }\n        let loading = that.$loading({\n          lock: true, // lock的修改符--默认是false\n          text: '拼命下载中，请稍候...', // 显示在加载图标下方的加载文案\n          background: 'rgba(0,0,0,0.8)', // 遮罩层颜色\n          spinner: 'el-icon-loading' // 自定义加载图标类名\n        })\n\n        that.$http.downloadPost(that.$http.adornUrl('/contractManager/generateWords'), listId, that)\n          .then(function (b){\n            loading.close()\n          }).catch(function(error) {\n          loading.close()\n          setTimeout(function() {\n            alert('请求超时')\n          }, 500)\n        })\n      }\n    },\n\n  }\n\n}\n</script>\n<style scoped>\n  .el-header {\n    color: #333;\n    padding: 0 0;\n  }\n  .el-form--inline>.inputlist{\n    padding-top: 20px;\n    padding-left: 20px;\n    display: flex;\n  }\n  .el-form--inline>.inputlist>.el-form-item{\n    width: 450px;\n    margin-bottom: 20px;\n  }\n  .el-form-item__content{\n    width: 200px;\n  }\n  .el-button{\n    width: 90px;\n    height: 40px;\n  }\n</style>\n"]}]}