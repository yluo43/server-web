nexport default {\n  data() {\n    return {\n      isSubmit:false\n    }\n  },\n  props:{\n    value: {\n      type: Object,\n      default:()=>{}\n    },\n    labelList: {\n      type: Object,\n      default:()=>{}\n    },\n  },\n  components: {\n  },\n  methods: {\n    init(object){\n      this.value=object\n    },\n    btnSubmit(){\n      this.$emit('input',this.value)\n      this.isSubmit=true\n      this.$emit('submit')\n      this.$parent.hide()\n    },\n    cancelBtn(){\n      this.$emit('input',this.value)\n      this.isSubmit=false\n      this.$parent.hide()\n      return false;\n    },\n    getSubmitValue(){\n      return this.isSubmit;\n    }\n  }\n}\n</script>\n<style scoped>\n\n</style>\n"]}]}