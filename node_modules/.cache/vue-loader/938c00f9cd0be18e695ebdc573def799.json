<span>流动负债（元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.currentliabilities\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>本年度利润总额（元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.totalprofitfortheyear\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>上年度利润总额（元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.totalprofitofthepreviousyear\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>本年度净利润（元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.netprofitfortheyear\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>本年度营业收入（元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.currentyearoperatingincome\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>上年度营业收入（元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.previousyearoperatingincome\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>年度研发金额投入（元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.annualrdinvestment\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>慈善公益事业支出（元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.publicwelfareexpenditure\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>总资产平均余额（万元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.averageoftotalassets\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>营业收入（万元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.operatingrevenue\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>利润总额（万元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.totalprofit\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>经营性净现金流量（万元）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.netoperatingcashflow\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>资产负债率（%）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" :value=\"item.assetliabilityratio\" v-model=\"item.assetliabilityratio\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>现金比率（%）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.cashratio\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>利润增长率（%）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.profitgrowthrate\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>收入增长率（%）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.revenuegrowthrate\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li><span>销售净利率（%）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.netprofitmarginonsales\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n              <li style=\"border-bottom:1px solid #ddd;\"><span>流动比率（%）</span>\n                <div class=\"tagList\">\n                  <el-input type=\"text\" v-model=\"item.currentratio\" v-for=\"(item,index) in arrList\" :key=\"index\" :disabled=\"!vipMember\"></el-input>\n                </div>\n              </li>\n            </ul>\n          </div>\n        </div>\n      </div>\n      <div>\n        <el-button type=\"primary\" v-if=\"vipMember\" @click=\"addList()\">添加</el-button>\n        <el-button type=\"primary\" v-if=\"vipMember\" @click=\"modify()\">修改</el-button>\n      </div>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"addOrUpdateDialog\" :width=\"'600px'\" :height=\"'600px'\">\n      <template>\n        <addOrUpdate @refreshDataList=\"refresh\" ref=\"addOrUpdate\"></addOrUpdate>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport baseDialog from '../../base/baseDialog.vue'\nimport addOrUpdate from './add.vue'\nexport default {\n  data() {\n    return {\n      arrList: [],\n      vipMember: false,\n      titles: '',\n      dataForm: {}\n    }\n  },\n  components: {\n    baseDialog, addOrUpdate\n  },\n  mounted() {\n    this.$http({\n      url: this.$http.adornUrl('/tenderinformation/FinancialInformationList'),\n      method: 'get'\n    }).then(({ data }) => {\n      this.arrList = data.payload\n      if (data && data.success) {\n        this.arrList = data.payload\n      }\n    })\n    this.$http({\n      url: this.$http.adornUrl('/tenderinformation/isSuperMan'),\n      method: 'get'\n    }).then(({ data }) => {\n      if (data && data.success) {\n        this.vipMember = data.payload\n      }\n    })\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    modify() {\n      let loading = this.$loading({\n        lock: true, // lock的修改符--默认是false\n        text: '拼命修改中，请稍候...', // 显示在加载图标下方的加载文案\n        background: 'rgba(0,0,0,0.8)', // 遮罩层颜色\n        spinner: 'el-icon-loading' // 自定义加载图标类名\n      })\n      console.log(this.arrList)\n      this.$http({\n        url: this.$http.adornUrl('/tenderinformation/FinancialInformationUpdate'),\n        method: 'put',\n        data: this.arrList\n      }).then(({ data }) => {\n        if (data && data.success) {\n          loading.close()\n          this.$message({\n            message: '修改成功',\n            type: 'success'\n          })\n        } else {\n          loading.close()\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    addList() {\n      this.titles = '添加财务信息'\n      this.$refs.addOrUpdateDialog.show()\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    }\n  }\n}\n</script>\n<style scoped>\n.detailInfo{\n  width: 80%;\n  margin: 0 auto;\n}\n.detailInfo span {\n  width: 180px;\n\tfloat: left;\n\ttext-align: center;\n\theight: 40px;\n\tline-height: 40px;\n  border-right:1px solid #ddd;\n  border-left:1px solid #ddd;\n}\n\n.detailInfo_rt li {\n\twidth: 100%;\n\tfloat: left;\n\tborder: 1px solid #ddd;\n  border-bottom: none;\n\theight: 40px;\n\tline-height: 40px;\n\toverflow: hidden;\n}\n.tagList{\n  display: flex;\n}\n.tagList>i{\n  text-align: center;\n  width: 20%;\n  font-style: normal;\n  border-right:1px solid #ddd;\n}\n.tagList>.el-input{\n  text-align: center;\n\n\theight: 38px;\n\tline-height: 36px;\n\toverflow: hidden;\n}\n.tagList>.el-input>.el-input__inner{\n  border: none;\n  border-radius: 0px;\n  text-align: center;\n  background-color: #F5F7FA !important;\n}\n::v-deep .tagList>.el-input>.el-input__inner{\n  color:#000;\n  background-color: #F5F7FA !important;\n}\n</style>\n<style>\n::-webkit-scrollbar { /*滚动条整体样式*/\n  width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n  height: 1px;\n}\n\n::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n  border-radius: 10px;\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  background: #e1f1f1;\n}\n\n::-webkit-scrollbar-track { /*滚动条里面轨道*/\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  border-radius: 10px;\n  background: #fff;\n}\n</style>\n"]}]}