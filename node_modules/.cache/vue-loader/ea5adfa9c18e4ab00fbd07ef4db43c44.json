{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/layout/components/AppMain.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/layout/components/AppMain.vue","mtime":1694625106918},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["AppMain.vue"],"names":[],"mappings":";;;;;;;;;;;;AAYA;AACA;;AAEA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"AppMain.vue","sourceRoot":"src/layout/components","sourcesContent":["<template>\n  <section class=\"app-main\">\n    <transition name=\"fade-transform\" mode=\"out-in\">\n      <div id=\"water-mark-show\">\n        <router-view/>\n      </div>\n\n    </transition>\n  </section>\n</template>\n\n<script>\nimport { removeWatermark, setWaterMark } from '@/utils/waterMark'\nimport { getCName} from '@/utils/auth'\n\nlet elementResizeDetectorMaker = require('element-resize-detector')\nexport default {\n  name: 'AppMain',\n  mounted() {\n    // 当屏幕大小进行缩放时，重新生成水印  window.onresize() 屏幕大小改变时触发、用了，登录页面也有水印\n    // window.onresize = () => {\n    //   this.set('noPdf', '')\n    // }\n    // 监听左侧树元素的变化,重新生成水印\n    let erd = elementResizeDetectorMaker()\n    let that = this\n    erd.listenTo(document.getElementById('left-tree'), function(element) {\n      that.$nextTick(function() {\n        // 重新加载水印\n        setWaterMark(getCName(), '')\n      })\n    })\n  },\n  destroyed() {\n    removeWatermark()\n  },\n  computed: {\n    key() {\n      return this.$route.path\n    }\n  }\n}\n</script>\n\n<style scoped>\n.app-main {\n  min-height: calc(100vh - 127px);\n  width: 100%;\n  position: relative;\n  border-radius: 12px;\n}\n\n.fixed-header + .app-main {\n  padding-top: 50px;\n}\n</style>\n\n<style lang=\"scss\">\n// fix css style bug in open el-dialog\n.el-popup-parent--hidden {\n  .fixed-header {\n    padding-right: 15px;\n  }\n}\n\n#water-mark-show {\n  z-index: 0;\n}\n</style>\n"]}]}