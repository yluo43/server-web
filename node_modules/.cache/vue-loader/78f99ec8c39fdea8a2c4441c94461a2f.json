{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/bidDocumentLibrary/picture.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/bidDocumentLibrary/picture.vue","mtime":1694618820697},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["picture.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;AAsBA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"picture.vue","sourceRoot":"src/views/modules/CompanyQualificationManagement/bidDocumentLibrary","sourcesContent":["<template>\n  <div class=\"mdgContent\">\n    <el-container class=\"el-container__mdgContent\">\n      <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n        <div>\n          <baseUpload\n            name=\"multipartFile\"\n            ref=\"multipartFile\"\n            :accept=\"'.zip,.rar,.png,.jpg,.xlsx,.doc,.txt,.docx,.xls,.pdf'\"\n            :file-list=\"multipartFile\"\n            :hideAllBtn=\"true\"\n            ></baseUpload>\n          <div style=\"margin-top:20px;text-align:center;margin-bottom: 20px;\">\n            <el-button type=\"success\" @click=\"addOrUpdateHandle()\">上传</el-button>\n            <el-button type=\"danger\" @click=\"cancelDialog()\">取消</el-button>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseUpload from '../../base/baseUpload.vue'\nexport default {\n  data() {\n    return {\n      multipartFile: [],\n      dataForm: {\n      }\n    }\n  },\n  components: { baseUpload },\n  methods: {\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    buildFormData(dom) {\n      let formData = new FormData(dom)\n      for (let i = 0; i < dom.length; i++) {\n        let element = dom[i]\n        if (element['type'] === 'multipartFile' && element.files.length === 0) {\n          formData.delete(element.name)\n        }\n      }\n      return formData\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let formData = this.buildFormData(this.$refs.dataForm.$el)\n      this.$refs.dataForm.validate((valid) => {\n        this.$http({\n          url: this.$http.adornUrl('/tenderdocuments/insert'),\n          method: 'post',\n          data: formData\n        }).then(({ data }) => {\n          if (data.success) {\n            this.$message({\n              message: '成功上传',\n              type: 'success'\n            })\n            this.$emit('refreshDataList')\n            this.$parent.hide()\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    },\n    download() {\n      this.$http.download(this.$http.adornUrl('/label/download'))\n    },\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n<style scoped>\n  ::v-deep .el-form{\n    width: 100%;\n  }\n</style>\n"]}]}