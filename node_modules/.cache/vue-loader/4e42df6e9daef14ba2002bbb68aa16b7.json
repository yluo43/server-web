m label=\"展示数量:\" prop=\"pageSize\">\n            <el-input v-model=\"dataForm.pageSize\"></el-input>\n          </el-form-item>\n          <div>\n            <el-button type=\"primary\" @click=\"refresh()\">查询</el-button>\n<!--            <el-button type=\"danger\" @click=\"resetForm()\">重置</el-button>-->\n          </div>\n        </div>\n      </el-form>\n      <labelshow ref=\"labelshow\"></labelshow>\n    </el-container>\n  </div>\n</template>\n<script>\nimport labelshow from './labelshow.vue'\nexport default {\n  data() {\n    return {\n      labelsList: [],\n      dataForm: {\n        name: '',\n        pageSize: ''\n      }\n    }\n  },\n  components: {\n    labelshow\n  },\n  props: {\n    dialogName: {\n      type: String\n    },\n    parentRefresh: {\n      type: Function\n    }\n  },\n  mounted() {\n    this.refresh()\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        if(this.dataForm.pageSize===\"\"){\n          this.dataForm.pageSize = 40\n        }\n\n        this.$http({\n          url: this.$http.adornUrl('/label/labelCount'),\n          method: 'get',\n          params: this.$http.adornParams({ 'name': this.dataForm.name, 'pageSize': this.dataForm.pageSize })\n        }).then(({ data }) => {\n          if (data && data.code === 200) {\n            this.labelsList = data.payload\n            this.$nextTick(() => {\n              this.$refs.labelshow.init(this.labelsList)\n            })\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    }\n  }\n}\n</script>\n<style scoped>\n  .el-header {\n    color: #333;\n    padding: 0 0;\n  }\n  .el-form--inline>.inputlist{\n    padding-top: 20px;\n    padding-left: 20px;\n    display: flex;\n  }\n  .el-form--inline>.inputlist>.el-form-item{\n    width: 340px;\n    margin-bottom: 20px;\n  }\n  .el-form-item__content{\n    width: 200px;\n  }\n  .el-button{\n    width: 90px;\n    height: 40px;\n  }\n</style>\n"]}]}