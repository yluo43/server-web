{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/contractManagement/supplementaryMaterials/excel.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/contractManagement/supplementaryMaterials/excel.vue","mtime":1694618820709},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["excel.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;AAiBA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"excel.vue","sourceRoot":"src/views/modules/contractManagement/supplementaryMaterials","sourcesContent":["<template>\n  <div class=\"base-pic-upload\" style=\"width: 100%;\">\n    <el-upload\n      class=\"upload-demo\"\n      action=\"#\"\n      :auto-upload=\"false\"\n      :on-change=\"handleOnChangeExcxel\"\n      :on-remove=\"handleOnRemoveExcxel\"\n      :file-list=\"excelFileList\"\n      accept=\".xlsx,.xls\"\n    >\n      <el-button slot=\"trigger\" size=\"small\" type=\"primary\">添加文件</el-button>\n      <el-button style=\"margin-left: 10px;height: 30px;margin-top: 34px;width: 75px\" size=\"small\" type=\"success\" @click=\"submitUpload\">上传</el-button>\n    </el-upload>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      dialogImageUrl: '',\n      dialogVisible: false,\n      disabled: false,\n      isChanged: false,\n      index: 0,\n      max :'',\n      excelFileList: []\n    }\n  },\n  props: {\n    name: {\n      type: String,\n      default: 'file'\n    },\n    onValid: {\n      type: Function\n    },\n    file: {\n      type: Object\n    },\n    accept: {\n      type: String,\n      default: '.xlsx,.xls'\n    },\n    hideAllBtn: {\n      type: Boolean,\n      default: false\n    }\n  },\n  methods: {\n    init(file,index,max) {\n      this.excelFileList = file\n      this.index = index\n      this.max=max\n    },\n    cancelFiles() {\n      if (this.getFileList().length > 0) {\n        this.$refs.upload.clearFiles()\n        this.isChanged = true\n      }\n    },\n    handleOnChangeExcxel(file, fileList) {\n      if(this.max){\n        if(fileList.length>this.max){\n          fileList.splice(fileList.length-1,1)\n          this.$message.warning(`当前最多仅可上传`+this.max+\"图片\");\n          return;\n        }\n      }\n      let filetype = file.name.substr(file.name.lastIndexOf('.') + 1, file.name.length)\n      let flag = true\n      if (this.accept) {\n        let types = this.accept.replaceAll('.', '').split(',')\n        types.forEach((item, i) => {\n          if (item === filetype) {\n            flag = false\n          }\n        })\n      } else {\n        flag = false\n      }\n      if (flag) {\n        fileList.pop()\n        this.$message.warning('格式不正确')\n        return\n      } else {\n        if (this.onValid != null && !this.onValid(file, fileList)) {\n          fileList.pop()\n          // fileList.splice(0, fileList.length)\n          return\n        }\n      }\n      this.isChanged = true\n      this.excelFileList = fileList\n      this.$emit('uploadExcel',fileList,this.index)\n    },\n    submitUpload() {\n      this.$parent.hide()\n    },\n    handleOnRemoveExcxel(file, fileList) {\n      this.isChanged = true\n      this.excelFileList = fileList\n      this.$emit('uploadExcel',this.excelFileList,this.index)\n    },\n    hasFile() {\n      return this.$refs.upload.uploadFiles.length > 0\n    },\n    getFileList() {\n      return this.$refs.upload.uploadFiles\n    }\n  }\n}\n</script>\n<style scoped>\n/* 取消eb-upload默认的按钮栏样式，用于按钮隐藏多余突出白块 */\n.base-pic-upload .el-upload{\n  display: block;\n  text-align: left;\n}\n::v-deep .el-dialog__body{\n  height: 130px;\n}\n.base-pic-upload{\n  height: 130px;\n}\n::v-deep .el-upload-list__item:first-child{\n  margin-top: 38px;\n  width: 300px;\n}\n::v-deep .el-upload-list--text{\n    display: inline-grid;\n  width: 150px;\n  }\n</style>\n"]}]}