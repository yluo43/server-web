{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/base/basePicUpWord.vue?vue&type=style&index=0&id=410115fc&lang=css&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/base/basePicUpWord.vue","mtime":1694618820701},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["basePicUpWord.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAgHA;AACA;AACA;AACA;AACA","file":"basePicUpWord.vue","sourceRoot":"src/views/modules/base","sourcesContent":["<template>\n  <div class=\"base-pic-upload\">\n    <el-upload\n      action=\"#\"\n      :on-preview=\"handlePictureCardPreview\"\n      :auto-upload=\"false\"\n      :name=\"name\"\n      :on-change=\"handleOnChange\"\n      :on-remove=\"handleOnRemove\"\n      :file-list=\"fileList\"\n      :accept=\"accept\"\n      ref=\"upload\">\n      <el-button size=\"small\" type=\"primary\" style=\"display: block;\">选择文件</el-button>\n    </el-upload>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      dialogImageUrl: '',\n      dialogVisible: false,\n      disabled: false,\n      isChanged: false,\n      nowFileList: this.fileList\n    }\n  },\n  props: {\n    name: {\n      type: String,\n      defualt: 'file'\n    },\n    onValid: {\n      type: Function\n    },\n    fileList: {\n      type: Array,\n      default: function() {\n        return []\n      }\n    },\n    accept: {\n      type: String,\n      default: '.jpg,.png,.JPG,.PNG,.gif'\n    },\n    propName:{\n      type: String,\n      defualt: ''\n    },\n    hideAllBtn: {\n      type: Boolean,\n      default: false\n    }\n  },\n  methods: {\n    handlePictureCardPreview(file) {\n      this.dialogImageUrl = file.url\n      this.dialogVisible = true\n    },\n    cancelFiles() {\n      if (this.getFileList().length > 0) {\n        this.$refs.upload.clearFiles()\n        this.isChanged = true\n      }\n    },\n    handleOnChange(file, fileList) {\n      let filetype = file.name.substr(file.name.lastIndexOf('.') + 1, file.name.length)\n      let flag = true\n      if (this.accept) {\n        let types = this.accept.replaceAll('.', '').split(',')\n        types.forEach((item, i) => {\n          if (item === filetype) {\n            flag = false\n          }\n        })\n      } else {\n        flag = false\n      }\n      if (flag) {\n        fileList.pop()\n        this.$message.warning('图片格式不正确')\n        return\n      } else {\n        if (this.onValid != null && !this.onValid(file, fileList)) {\n          fileList.pop()\n          // fileList.splice(0, fileList.length)\n          return\n        }\n      }\n      this.isChanged = true\n      this.nowFileList = fileList\n      this.getFileList()\n    },\n    handleOnRemove(file, fileList) {\n      this.isChanged = true\n      this.nowFileList = fileList\n      this.getFileList()\n    },\n    hasFile() {\n      return this.$refs.upload.uploadFiles.length > 0\n    },\n    getFileList() {\n      let data = {propName:this.propName,file:this.nowFileList}\n      this.$emit(\"getFileList\",data)\n      // this.$refs.upload.fileList=this.nowFileList\n      // this.fileList=this.nowFileList\n      return this.nowFileList\n    }\n  }\n}\n</script>\n<style>\n/* 取消eb-upload默认的按钮栏样式，用于按钮隐藏多余突出白块 */\n/*.base-pic-upload .el-upload{*/\n/*  display: block;*/\n/*  text-align: center;*/\n/*}*/\n</style>\n"]}]}