{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/labelDatabaseManagement/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/labelDatabaseManagement/index.vue","mtime":1694618820712},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["index.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAoDA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA;AACA","file":"index.vue","sourceRoot":"src/views/modules/labelDatabaseManagement","sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container style=\"height: 100%; border: 1px solid #eee\">\n      <el-header style=\"height: auto;\">\n        <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n          <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n<!--            <div>-->\n<!--              <el-button type=\"primary\" @click=\"addTagType()\">+添加标签</el-button>-->\n<!--              <el-button type=\"warning\" @click=\"batchAdd()\">批量添加</el-button>-->\n<!--            </div>-->\n          </div>\n        </el-form>\n      </el-header>\n      <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\" >\n        <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n          <el-form-item label=\"标签类型:\" prop=\"sorts\" style=\"margin-left: 10%\">\n            <el-select v-model=\"dataForm.sortId\" placeholder=\"请选择\" @change=\"sortslist\">\n              <el-option label='全选' value=''  v-if=\"sortsList.length\" ></el-option>\n              <el-option\n                v-for=\"(item, i) in sortsList\"\n                :key=\"i\"\n                :label=\"item.name\"\n                :value=\"item.id\"\n                ref=\"coverSize\"></el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item label=\"标签名称:\" prop=\"keyword\">\n            <el-input v-model=\"dataForm.keyword\" maxlength=\"255\"></el-input>\n          </el-form-item>\n          <div>\n            <el-button type=\"primary\" @click=\"refresh()\">查询</el-button>\n            <el-button type=\"primary\" @click=\"addTagType()\">+添加标签</el-button>\n            <el-button type=\"primary\" @click=\"batchAdd()\">批量添加</el-button>\n            <el-button style=\"width: 125px\" type=\"primary\" @click=\"exportlist()\">未分类标签导出</el-button>\n          </div>\n        </div>\n      </el-form>\n      <labelshow ref=\"labelshow\" @reftoo=\"reftoo\"></labelshow>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"addOrUpdateDialog\" :width=\"'450px'\">\n      <template>\n        <addOrUpdate @refreshDataList=\"refresh\" ref=\"addOrUpdate\"></addOrUpdate>\n      </template>\n    </baseDialog>\n    <baseDialog :title=\"titles\" ref=\"batchAddDialog\" :width=\"'400px'\">\n      <template>\n        <batchAdd @refreshDataList=\"refresh\" ref=\"batchAdd\"></batchAdd>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport labelshow from './labelshow.vue'\nimport baseDialog from '../base/baseDialog.vue'\nimport addOrUpdate from './add.vue'\nimport batchAdd from './batchadd.vue'\nexport default {\n  data() {\n    return {\n      titles: '',\n      tagTypeList: [],\n      sortsList: [],\n      labelsList: [],\n      dataForm: {\n        keyword: '',\n        sortId: ''\n      }\n    }\n  },\n  components: {\n    labelshow,\n    baseDialog,\n    addOrUpdate,\n    batchAdd\n  },\n  props: {\n    dialogName: {\n      type: String\n    },\n    parentRefresh: {\n      type: Function\n    }\n    },\n  mounted() {\n    this.$http({\n      url: this.$http.adornUrl('/label/sorts'),\n      method: 'get'\n    }).then(({ data }) => {\n      this.tagTypeList = data.payload\n      this.tagTypeList.forEach((item) => {\n        this.sortsList.push({ id: item.id, name: item.name })\n      })\n    })\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$http({\n          url: this.$http.adornUrl('/label/labels'),\n          method: 'get',\n          params: this.$http.adornParams({ 'keyword': this.dataForm.keyword, 'sortId': this.dataForm.sortId })\n        }).then(({ data }) => {\n          console.log(data);\n          if (data && data.code === 200) {\n            this.labelsList = data.payload\n            this.$nextTick(() => {\n              this.$refs.labelshow.init(this.labelsList)\n            })\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    },\n    reftoo() {\n      this.refresh()\n    },\n    addTagType() {\n      this.titles = '添加标签'\n      this.$refs.addOrUpdateDialog.show()\n    },\n    batchAdd() {\n      this.titles = '批量添加'\n      this.$refs.batchAddDialog.show()\n    },\n    sortslist(value) {\n      this.dataForm.sorts = value\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    exportlist() {\n      this.$http.download(this.$http.adornUrl('/clbatch/deriveLabel'), this.$http.adornParams(this.dataForm), this)\n    }\n  }\n}\n</script>\n<style scoped>\n  .el-header {\n    color: #333;\n    padding: 0 0;\n  }\n  .el-form--inline>.inputlist{\n    padding-top: 20px;\n    padding-left: 20px;\n    display: flex;\n  }\n  .el-form--inline>.inputlist>.el-form-item{\n    width: 340px;\n    margin-bottom: 20px;\n  }\n  .el-form-item__content{\n    width: 200px;\n  }\n  .el-button{\n    width: 90px;\n    height: 40px;\n  }\n\n\n</style>\n<style>\n  ::-webkit-scrollbar { /*滚动条整体样式*/\n    width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n    height: 8px;\n  }\n  ::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n    border-radius: 10px;\n    -webkit-box-shadow: inset 0 0 0 rgba(0, 0, 0, 0.2);\n    background: #e1f1f1;\n  }\n  ::-webkit-scrollbar-track { /*滚动条里面轨道*/\n    -webkit-box-shadow: inset 0 0 0 rgba(0, 0, 0, 0.2);\n    border-radius: 10px;\n    background: #fff;\n  }\n</style>\n"]}]}