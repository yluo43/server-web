{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/bidBasicsInformationBase/manufacturer.vue?vue&type=style&index=1&id=6d8d9a0d&lang=css&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/bidBasicsInformationBase/manufacturer.vue","mtime":1694618820696},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"sources":["manufacturer.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAyTA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA;;AAEA;AACA;AACA;AACA;AACA","file":"manufacturer.vue","sourceRoot":"src/views/modules/CompanyQualificationManagement/bidBasicsInformationBase","sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container style=\"height: 100%;\">\n      <div class=\"detailInfo\">\n        <h2 style=\"text-align:center;\">制造商资格声明</h2>\n        <div class=\"detailInfo_rt\">\n          <ul>\n            <li>\n              <span>1.名称及概况:</span>\n              <ul style=\"display:flex;\">\n                <li><span>(1)制造商名称:</span>\n                  <input type=\"text\" v-model=\"dataForm.manufacturerName\" :disabled=\"!vipMember\"/>\n                </li>\n                <li style=\"flex-direction: column;\">\n                  <div>\n                    <span>(2)总部地址:</span>\n                    <input type=\"text\" v-model=\"dataForm.headquartersAddress\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>电传/传真/电话号码:</span>\n                    <input type=\"text\" v-model=\"dataForm.fax+'/'+dataForm.phone\" disabled/>\n                  </div>\n                </li>\n                <li><span>(3)成立和/或注册日期:</span>\n                  <input type=\"text\" v-model=\"dataForm.registrationDate\" :disabled=\"!vipMember\"/>\n                </li>\n                <li><span>(4)实收资本（元）:</span>\n                  <input type=\"text\" v-model=\"dataForm.paidinCapital\" :disabled=\"!vipMember\"/>\n                </li>\n                <li style=\"flex-direction: column;\">\n                  <span>(5)近期资产负债表(到 2022 年12 月31 日止)</span>\n                  <div>\n                    <span>固定资产（元）：</span>\n                    <input type=\"text\" v-model=\"dataForm.fixedAssets\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>流动资产（元）：</span>\n                    <input type=\"text\" v-model=\"dataForm.currentAssets\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>长期负债（元）：</span>\n                    <input type=\"text\" v-model=\"dataForm.longTermLiabilities\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>流动负债（元）：</span>\n                    <input type=\"text\" v-model=\"dataForm.currentLiabilities\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>净值（元）：</span>\n                    <input type=\"text\" v-model=\"dataForm.netWorth\" :disabled=\"!vipMember\"/>\n                  </div>\n                </li>\n                <li><span>(6)主要负责人姓名:(可选填)</span>\n                  <input type=\"text\" v-model=\"dataForm.contactPerson\" :disabled=\"!vipMember\"/>\n                </li>\n                <li><span>(7)制造商在中国的代表的姓名和地址，(如有的话)</span>\n                  <input type=\"text\" v-model=\"dataForm.manufacturersRepresentativeinChina\" :disabled=\"!vipMember\"/>\n                </li>\n              </ul>\n            </li>\n            <li><span>2.(1)关于制造申请货物的设施及其它情况:</span>\n              <ul>\n                <li style=\"flex-direction: column;\">\n                  <div>\n                    <span>工厂名称地址</span>\n                    <input type=\"text\" v-model=\"dataForm.factoryAddress\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>生产的项目</span>\n                    <input type=\"text\" v-model=\"dataForm.productionProjects\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>年生产能力（元）</span>\n                    <input type=\"text\" v-model=\"dataForm.annualProductionCapacity\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>职工人数（人）</span>\n                    <input type=\"text\" v-model=\"dataForm.employeesNO\" :disabled=\"!vipMember\"/>\n                  </div>\n                </li>\n                <li style=\"flex-direction: column;\">\n                  <div>\n                    <span>(2)本制造商不生产，而需从其它制造商购买的主要零部件：</span>\n                  </div>\n                  <div>\n                    <span>制造商名称和地址:</span>\n                    <input type=\"text\" v-model=\"dataForm.manufacturerNameorAddress\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>主要零部件名称:</span>\n                    <input type=\"text\" v-model=\"dataForm.MainComponentName\" :disabled=\"!vipMember\"/>\n                  </div>\n                </li>\n              </ul>\n            </li>\n            <li><span>3.本制造商生产申请货物的经验(包括年限、项目业主、额定能力、商业运营的起始日期等):</span>\n              <input type=\"text\" v-model=\"dataForm.manufacturerProductionExperience\" :disabled=\"!vipMember\"/>\n            </li>\n            <li><span>4.近3 年该货物主要销售给国内、外主要客户的名称地址：</span>\n              <ul>\n                <li style=\"flex-direction: column;\">\n                  <div>\n                    <span>(1)出口销售</span>\n                    <input type=\"text\" v-model=\"dataForm.exportSales\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>(2)国内销售</span>\n                    <input type=\"text\" v-model=\"dataForm.domesticSales\" :disabled=\"!vipMember\"/>\n                  </div>\n                </li>\n              </ul>\n            </li>\n            <li><span>5.近4年的年营业额：</span>\n              <ul>\n                <li style=\"flex-direction: row;justify-content: space-around;\">\n                  <div style=\"display:flex;flex-direction: column;text-align: center;\">\n                    <span>年份</span>\n                    <input type=\"text\" v-model=\"item.turnoverTime\" v-for=\"item,index in dataForm.annualTurnovers\" :key=\"index\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div style=\"display:flex;flex-direction: column;\">\n                    <span>国内（元）</span>\n                    <input type=\"text\" v-model=\"item.domesticTurnover\" v-for=\"item,index in dataForm.annualTurnovers\" :key=\"index\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div style=\"display:flex;flex-direction: column;\">\n                    <span>出口（元）</span>\n                    <input type=\"text\" v-model=\"item.exportTurnover\" v-for=\"item,index in dataForm.annualTurnovers\" :key=\"index\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div style=\"display:flex;flex-direction: column;\">\n                    <span>总额（元）</span>\n                    <input type=\"text\" v-model=\"item.total\" v-for=\"item,index in dataForm.annualTurnovers\" :key=\"index\" :disabled=\"!vipMember\"/>\n                  </div>\n                </li>\n              </ul>\n            </li>\n            <li><span>6.易损件供应商的名称和地址：</span>\n              <ul>\n                <li style=\"flex-direction: column;\">\n                  <div>\n                    <span>部件名称</span>\n                    <input type=\"text\" v-model=\"dataForm.componentName\" :disabled=\"!vipMember\"/>\n                  </div>\n                  <div>\n                    <span>供应商</span>\n                    <input type=\"text\" v-model=\"dataForm.supplier\" :disabled=\"!vipMember\"/>\n                  </div>\n                </li>\n              </ul>\n            </li>\n            <li style=\"flex-direction: row;\"><span>7.最近 4 年直接或通过贸易公司向中国提供的申请货物：</span>\n              <input type=\"text\" v-model=\"dataForm.goods\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>8.有关开户银行的名称和地址：</span>\n              <input type=\"text\" v-model=\"dataForm.depositBank\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>9.制造商所属的集团公司，如有的话：</span>\n              <input type=\"text\" v-model=\"dataForm.belongGroup\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>10.其他情况：</span>\n              <input type=\"text\" v-model=\"dataForm.otherSituations\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>  兹证明上述声明是真实、正确的，并提供了全部能提供的资料和数据，我们同意遵照贵方要求出示有关证明文件。</span>\n            </li>\n            <li style=\"flex-direction: row;\"><span>制造商名称 </span>\n              <input type=\"text\" v-model=\"dataForm.manufacturerName\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>签字人姓名和职务 </span>\n              <input type=\"text\" v-model=\"dataForm.signers\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>签字人签字 </span>\n              <input type=\"text\" v-model=\"dataForm.signersimg\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>签字日期 </span>\n              <input type=\"text\" v-model=\"dataForm.signatureDate\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>传真 </span>\n              <input type=\"text\" v-model=\"dataForm.fax\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>电话 </span>\n              <input type=\"text\" v-model=\"dataForm.phone\" :disabled=\"!vipMember\"/>\n            </li>\n            <li style=\"flex-direction: row;\"><span>电子邮箱 </span>\n              <input type=\"text\" v-model=\"dataForm.email\" :disabled=\"!vipMember\"/>\n            </li>\n          </ul>\n        </div>\n      </div>\n      <div>\n        <el-button type=\"primary\" v-if=\"vipMember\" @click=\"modify()\">修改</el-button>\n      </div>\n    </el-container>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      vipMember: false,\n      dataForm: {}\n    }\n  },\n  mounted() {\n    this.$http({\n      url: this.$http.adornUrl('/tenderinformation/ManufacturerInformation'),\n      method: 'get'\n    }).then(({ data }) => {\n      if (data && data.success) {\n        this.dataForm = data.payload\n      }\n    })\n    this.$http({\n      url: this.$http.adornUrl('/tenderinformation/isSuperMan'),\n      method: 'get'\n    }).then(({ data }) => {\n      if (data && data.success) {\n        this.vipMember = data.payload\n      }\n    })\n  },\n  methods: {\n    modify() {\n      let loading = this.$loading({\n        lock: true, // lock的修改符--默认是false\n        text: '拼命修改中，请稍候...', // 显示在加载图标下方的加载文案\n        background: 'rgba(0,0,0,0.8)', // 遮罩层颜色\n        spinner: 'el-icon-loading' // 自定义加载图标类名\n      })\n      this.$http({\n        url: this.$http.adornUrl('/tenderinformation/ManufacturerInformationUpdate'),\n        method: 'put',\n        data: this.dataForm\n      }).then(({ data }) => {\n        if (data && data.success) {\n          loading.close()\n          this.$message({\n            message: '修改成功',\n            type: 'success'\n          })\n        } else {\n          loading.close()\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    }\n  }\n}\n</script>\n<style scoped>\n.detailInfo{\n  width: 80%;\n  margin: 0 auto;\n  border: 1px solid #ddd;\n  font-size: 18px;\n}\n.detailInfo span {\n\ttext-align: left;\n\theight: 40px;\n\tline-height: 40px;\n}\n\n.detailInfo_rt li {\n\twidth: 100%;\n\tdisplay: flex;\n  flex-direction: column;\n}\n.detailInfo_rt li>ul{\n\twidth: 100%;\n\tdisplay: flex;\n  flex-direction: column;\n}\n.detailInfo_rt li>ul>li{\n\twidth: 80%;\n\tdisplay: flex;\n  flex-direction: row;\n}\n.detailInfo_rt li>ul>li>div>input{\n\ttext-align: center;\n  width: 90%;\n  border: none;\n  background-color: #F5F7FA;\n  border-bottom: 1px solid #ddd;\n\theight: 38px;\n\tline-height: 36px;\n\toverflow: hidden;\n}\n.detailInfo_rt li>ul>li>div>span{\n\ttext-align: center;\n  width: 90%;\n}\n.detailInfo_rt li>ul>li>input{\n  text-align: center;\n  width: 50%;\n  border: none;\n  background-color: #F5F7FA;\n  border-bottom: 1px solid #ddd;\n\theight: 38px;\n\tline-height: 36px;\n\toverflow: hidden;\n}\n.detailInfo_rt li>input{\n  text-align: center;\n  width: 50%;\n  border: none;\n  background-color: #F5F7FA;\n  border-bottom: 1px solid #ddd;\n\theight: 38px;\n\tline-height: 36px;\n\toverflow: hidden;\n}\n</style>\n<style>\n::-webkit-scrollbar { /*滚动条整体样式*/\n  width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n  height: 1px;\n}\n\n::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n  border-radius: 10px;\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  background: #e1f1f1;\n}\n\n::-webkit-scrollbar-track { /*滚动条里面轨道*/\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  border-radius: 10px;\n  background: #fff;\n}\n</style>\n"]}]}