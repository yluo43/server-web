{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/authorityManagement/importAndExport/batchadd.vue?vue&type=style&index=0&id=010ada0a&scoped=true&lang=css&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/authorityManagement/importAndExport/batchadd.vue","mtime":1694618820698},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKOjp2LWRlZXAgLmVsLWZvcm0taXRlbXsKICB3aWR0aDogMTAwJTsKfQo6OnYtZGVlcCAuZWwtZm9ybXsKICB3aWR0aDogMTAwJTsKfQo="},{"version":3,"sources":["batchadd.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAgGA;AACA;AACA;AACA;AACA;AACA","file":"batchadd.vue","sourceRoot":"src/views/modules/authorityManagement/importAndExport","sourcesContent":["<!-- 自动发书管理-新增图书-新增 -->\n<template>\n  <div class=\"mdgContent\">\n    <el-container class=\"el-container__mdgContent\">\n      <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n        <div>\n          <el-form-item label=\"标签文件\" prop=\"status\">\n            <baseUpload\n              name=\"uploadFile\"\n              ref=\"uploadFile\"\n              :accept=\"'.xls,.xlsx'\"\n              :file-list=\"uploadFile\"\n              :hideAllBtn=\"true\"\n            ></baseUpload>\n          </el-form-item>\n          <div style=\"margin-top:20px;text-align:center;\">\n            <el-form-item>\n              <el-button type=\"success\" @click=\"addOrUpdateHandle()\">提交</el-button>\n              <el-button type=\"danger\" @click=\"cancelDialog()\">取消</el-button>\n            </el-form-item>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseDialog from '../../base/baseDialog.vue'\nimport baseUpload from '../../base/baseUpload.vue'\nexport default {\n  data() {\n    return {\n      textarea: '',\n      status: '',\n      titles: '',\n      amend: '',\n      uploadFile: [],\n      dataForm: {\n      }\n    }\n  },\n  components: { baseDialog, baseUpload },\n  methods: {\n    init(amend) {\n      this.amend = amend\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    buildFormData(dom) {\n      let formData = new FormData(dom)\n      for (let i = 0; i < dom.length; i++) {\n        let element = dom[i]\n        if (element['type'] === 'uploadFile' && element.files.length === 0) {\n          formData.delete(element.name)\n        }\n      }\n      return formData\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let formData = this.buildFormData(this.$refs.dataForm.$el)\n      this.$refs.dataForm.validate((valid) => {\n        this.$http({\n          url: this.$http.adornUrl(this.amend ? '/contractManager/partyAContactInfo' : '/clbatch/batchimport'),\n          method: 'post',\n          data: formData\n        }).then(({ data }) => {\n          if (data.success) {\n            if (this.amend) {\n              this.$message({\n                message: '成功导入',\n                type: 'success'\n              })\n            } else {\n              this.$message({\n                message: '上传成功，成功导入' + data.payload + '个',\n                type: 'success'\n              })\n            }\n            this.$parent.hide()\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    },\n\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n<style scoped>\n  ::v-deep .el-form-item{\n    width: 100%;\n  }\n  ::v-deep .el-form{\n    width: 100%;\n  }\n</style>\n"]}]}