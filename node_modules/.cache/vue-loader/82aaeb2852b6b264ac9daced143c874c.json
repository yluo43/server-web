  },\n      tableData: {\n        theads: [\n          { label: '合同编号', prop: 'contractNo' },\n          { label: '合同名称', prop: 'contractName' },\n          { label: '招标书标签', prop: 'labelName' }\n        ],\n        dataList: []\n      }\n    }\n  },\n  components: {\n    baseTable, baseDialog\n  },\n  mounted() {\n    // this.$refs.table.refresh(this.dataForm)\n  },\n  methods: {\n    init(applicationSign) {\n      this.dataForm.downNo=applicationSign;\n      this.refresh()\n    },\n    refresh() {\n      let that=this;\n      let searchParams = {\n        curPage:that.$refs.table.options.curPage,\n        pageSize:that.$refs.table.options.pageSize\n      }\n      this.$http({\n        method: \"get\",\n        url: that.$http.adornUrl(\"/applicationManager/selectContract\"),\n        params: that.$http.adornParams(Object.assign(this.dataForm,searchParams))\n      }).then(({data}) => {\n        if(data && data.code === 200){\n          that.tableData.dataList.length=0\n          that.tableData.dataList.push(...data.payload.list);\n          that.$refs.table.options.count=data.payload.totalCount\n          that.$refs.table.options.pageSize=data.payload.pageSize\n        }else{\n          that.$message.warning(data.msg)\n        }})\n      // this.$refs.table.refresh(this.dataForm)\n    },\n\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n\n  }\n}\n</script>\n<style scoped>\n.el-header {\n  color: #333;\n  padding: 0 0;\n}\n.el-form--inline>.inputlist{\n  padding-top: 20px;\n  padding-left: 20px;\n}\n.el-form--inline>.inputlist>.el-form-item{\n  width: 450px;\n  margin-bottom: 20px;\n}\n.el-button{\n  width: 90px;\n  height: 40px;\n}\n.el-table thead th{\n  background: #cbe5ff !important;\n  color: rgb(90, 89, 89);\n  height: 45px;\n  font-size: 15px;\n  font-weight: 600;\n}\n</style>\n"]}]}