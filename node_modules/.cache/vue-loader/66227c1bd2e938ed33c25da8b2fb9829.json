 }}</h1>\n      </div>\n    </transition>\n  </div>\n</template>\n\n<script>\nimport logoImg from '@/assets/logo.png'\n\nexport default {\n  name: 'SidebarLogo',\n  props: {\n    collapse: {\n      type: Boolean,\n      required: true\n    }\n  },\n  data() {\n    return {\n      title: '新讯 ',\n      logo: logoImg\n    }\n  }\n}\n</script>\n\n<style lang=\"scss\" scoped>\n.sidebarLogoFade-enter-active {\n  transition: opacity 1.5s;\n}\n\n.sidebarLogoFade-enter,\n.sidebarLogoFade-leave-to {\n  opacity: 0;\n}\n\n\n.sidebar-logo-container {\n  position: relative;\n  width: 100%;\n  height: 90px;\n  margin-bottom: 5px;\n  background: #ffffff;\n  text-align: center;\n  overflow: hidden;\n\n  & .sidebar-logo-link {\n    height: 100%;\n    width: 100%;\n\n    & .sidebar-logo {\n      width: 36px;\n      height: 36px;\n      margin: 25px 12px 12px 31px;\n      float: left;\n    }\n\n    & .hider {\n      width: 36px;\n      height: 36px;\n      margin: 25px 0px 0px 15px;\n      vertical-align: middle;\n    }\n\n    & .sidebar-title {\n      display: inline-block;\n      color: #333;\n      font-weight: 600;\n      line-height: 32px;\n      font-size: 32px;\n      font-family: Avenir, Helvetica Neue, Arial, Helvetica, sans-serif;\n      vertical-align: middle;\n      margin: 26px 0px 10px -20px;\n    }\n  }\n\n  &.collapse {\n    .sidebar-logo {\n      margin-right: 0px;\n    }\n  }\n}\n</style>\n"]}]}