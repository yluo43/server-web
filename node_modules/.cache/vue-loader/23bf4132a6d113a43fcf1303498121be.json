{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/CompanyQualificationInquiry/addOrUpdata.vue?vue&type=style&index=0&id=02744e17&scoped=true&lang=css&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/CompanyQualificationManagement/CompanyQualificationInquiry/addOrUpdata.vue","mtime":1694618820694},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/css-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/loaders/stylePostLoader.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/postcss-loader/src/index.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:CgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKCgoKOjp2LWRlZXAgLmVsLWZvcm0taXRlbV9fbGFiZWx7CiAgd2lkdGg6IDEwMHB4Owp9Cg=="},{"version":3,"sources":["addOrUpdata.vue"],"names":[],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAyJA;AACA;AACA","file":"addOrUpdata.vue","sourceRoot":"src/views/modules/CompanyQualificationManagement/CompanyQualificationInquiry","sourcesContent":["<template>\n  <div class=\"mdgContent\">\n    <el-container class=\"el-container__mdgContent\">\n      <el-form :inline=\"true\" :rules=\"dataRule\" :model=\"dataForm\" ref=\"dataForm\">\n        <div>\n          <el-form-item label=\"文件名称\" prop=\"fileName\">\n            <el-input v-model=\"dataForm.fileName\" placeholder=\"请输入文件名称\" clearable :disabled=\"query\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"文件类型\" prop=\"filetype\">\n            <el-autocomplete\n              value-key=\"name\"\n              v-model=\"dataForm.filetype\"\n              placeholder=\"请选择文件类型\"\n              clearable\n              :fetch-suggestions=\"handleSelect\"\n              @select=\"getSelect($event,'filetype')\"\n            >\n              <template slot-scope=\"{ item }\">\n                <div class=\"name\">{{ item.filetype }}</div>\n              </template>\n            </el-autocomplete>\n          </el-form-item>\n          <el-form-item label=\"上传文件\" prop=\"file\" style=\"display:flex;\">\n            <!-- <el-button size=\"small\" type=\"primary\" @click=\"pictureList\" class=\"upButton\">上传文件</el-button> -->\n            <basePicUpload\n              prop-name=\"file\"\n              name=\"word\"\n                :accept=\"'.zip,.rar,.png,.jpg,.xlsx,.doc,.txt,.docx,.xls,.pdf'\"\n              :file-list=\"dataForm.file\"\n              @getFileList=\"getFileList\"></basePicUpload>\n          </el-form-item>\n          <el-form-item label=\"文件说明\" prop=\"fileDescription\">\n            <el-input v-model=\"dataForm.fileDescription\" placeholder=\"请输入文件说明\" clearable></el-input>\n          </el-form-item>\n          <div style=\"margin:20px 0;text-align:center;\">\n            <el-button type=\"success\" @click=\"addOrUpdateHandle()\">提交</el-button>\n            <el-button type=\"danger\" @click=\"cancelDialog()\">取消</el-button>\n          </div>\n          <baseDialog :title=\"titles\" ref=\"pictureListDialog\" :width=\"'700px'\" :height=\"'500px'\">\n            <template>\n              <pictureList @refreshDataList=\"refresh\" ref=\"pictureList\"></pictureList>\n            </template>\n          </baseDialog>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseDialog from '../../base/baseDialog.vue'\nimport basePicUpload from '../../base/basePicUpWord.vue'\nimport pictureList from './picture.vue'\nexport default {\n  data() {\n    return {\n      titles: '',\n      dataForm: {},\n      dataRule: {\n        phone: [\n          { required: false, message: '手机不能为空', trigger: 'blur' }\n        ]\n      }\n    }\n  },\n  components: {\n    baseDialog, pictureList, basePicUpload\n  },\n  methods: {\n    init() {},\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let formData = new FormData();\n      formData.append('fileName', this.dataForm.fileName);\n      formData.append('filetype', this.dataForm.filetype);\n      if(this.dataForm.file && this.dataForm.file.length>0) {\n        formData.append('file', this.dataForm.file[0].raw);\n      }\n      formData.append('fileTypeId', this.dataForm.fileTypeId);\n      formData.append('fileDescription', this.dataForm.fileDescription);\n      if( this.dataForm.id) {\n        formData.append('id', this.dataForm.id);\n      }\n      // formData.append('uploadTime', this.dataForm.uploadTime);\n      // formData.append('uploader', this.dataForm.uploader);\n      this.$http({\n        url: this.$http.adornUrl('/companyqualifications/insert'),\n        method: 'post',\n        headers: {\n          \"content-type\": \"multipart/form-data\",\n        },\n        data: formData\n      }).then(({ data }) => {\n        if (data.success) {\n          this.$emit('refreshDataList')\n          this.$parent.hide()\n          this.$message({\n            message: '操作成功',\n            type: 'success'\n          })\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    pictureList() {\n      this.titles = '上传文件'\n      this.$refs.pictureListDialog.show()\n    },\n    handleSelect(queryString, cb) {\n      this.$http({\n        url: this.$http.adornUrl('/companyqualifications/typeList'),\n        method: 'get',\n        params: this.$http.adornParams({ 'filetype': this.dataForm.filetype })\n      }).then(({ data }) => {\n        if (data && data.code === 200) {\n          cb(data.payload.list)\n        } else {\n          cb([])\n        }\n      })\n    },\n    getSelect(item) {\n      if (this.dataForm.filetype === '') {\n        this.dataForm.filetype = ''\n        this.dataForm.fileTypeId = ''\n      } else {\n        this.dataForm.filetype = item.filetype\n        this.dataForm.fileTypeId = item.typeId\n      }\n    },\n    getFileList(data) {\n      this.dataForm.file = data.file\n    },\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n\n<style scoped>\n  ::v-deep .el-form-item__label{\n    width: 100px;\n  }\n</style>\n"]}]}