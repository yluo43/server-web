el=\"部门ID\" prop=\"id\" >\n            <el-input v-model=\"dataForm.id\"  clearable :disabled=\"true\"></el-input>\n          </el-form-item>\n          <el-form-item label=\"部门名称\" prop=\"phone\">\n            <el-input v-model=\"dataForm.deptName\"  placeholder=\"请输入部门名称\" clearable></el-input>\n          </el-form-item>\n          <el-form-item label=\"部门负责人\" prop=\"managerId\">\n            <el-select  v-model=\"managerId\" placeholder=\"请选择部门负责人\" >\n              <el-option      v-for=\"item in managerList\"\n                              :key=\"item.managerId\"\n                              :label=\"item.managerName\"\n                              :value=\"item.managerId\">\n              </el-option>\n            </el-select>\n          </el-form-item>\n          <el-form-item label=\"上级部门\" prop=\"parentId\">\n            <el-select  v-model=\"parentId\" placeholder=\"请选择上级部门\" >\n              <el-option      v-for=\"item in deptList\"\n                              :key=\"item.id\"\n                              :label=\"item.deptName\"\n                              :value=\"item.id\">\n              </el-option>\n            </el-select>\n          </el-form-item>\n          <div style=\"margin-top:20px;text-align:center;\">\n            <el-form-item>\n              <el-button type=\"primary\" @click=\"addOrUpdateHandle()\">提交</el-button>\n              <el-button  @click=\"cancelDialog()\">取消</el-button>\n            </el-form-item>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    // 邮箱验证\n    var validEmail = (rule, value, callback) => {\n      let reg = /^([A-Za-z0-9_\\-\\.])+\\@([A-Za-z0-9_\\-\\.])+\\.([A-Za-z]{2,4})(,([A-Za-z0-9_\\-\\.])+\\@([A-Za-z0-9_\\-\\.])+\\.([A-Za-z]{2,4}))*$/\n      if (value === '' || value === undefined || value === null) {\n        callback()\n      } else {\n        if (reg.test(value)) {\n          callback()\n        } else {\n          callback(new Error('邮箱格式错误'))\n        }\n      }\n    }\n    return {\n      query: false,\n      managerList:[],\n      deptList:[],\n      managerId:\"\",\n      parentId:\"\",\n      dataForm: {\n        id:'',\n        deptName: '',\n        managerName: '',\n        managerId: '',\n        parentId: ''\n      },\n      dataRule: {\n        deptName: [\n          { required: false, message: '部门名称不能为空', trigger: 'blur' }\n        ],\n        managerId: [\n          { required: false, message: '请选择部门负责人', trigger: 'blur' }\n          ]\n      }\n    }\n  },\n  methods: {\n    init(list, query, managerList) {\n      this.managerList = managerList\n      this.query = query\n      this.dataForm.id = list.id\n      this.dataForm.deptName = list.deptName\n      this.managerId = list.managerId\n      this.parentId = list.parentId\n\n      //初始化deptList\n      this.$http({\n        url: this.$http.adornUrl('/deptInfo/listAll'),\n        method: 'get'\n      }).then(({data}) => {\n        if (data && data.code === 200) {\n          this.deptList = data.payload.list\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n\n\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let url\n      if(this.query){\n        url = '/deptInfo/update'\n      }else{\n        url = '/deptInfo/add'\n      }\n\n\n      this.managerList.forEach(manager =>{\n        if(manager.managerId == this.managerId){\n          this.managerName = manager.managerName\n        }\n      })\n      this.$http({\n        url: this.$http.adornUrl(url),\n        method: 'post',\n        data: this.$http.adornData({\n          'deptName': this.dataForm.deptName,\n          'managerName': this.managerName,\n          'managerId': this.managerId,\n          'parentId': this.parentId,\n        })\n      }).then(({ data }) => {\n        if (data.success) {\n          this.$emit('refreshDataList')\n          this.$parent.hide()\n          this.$message({\n            message: '操作成功',\n            type: 'success'\n          })\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n\n<style scoped>\n  ::v-deep .el-form-item__label{\n    width: 100px;\n  }\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAyCA;EACAA,IAAA,WAAAA,KAAA;IACA;IACA,IAAAC,UAAA,YAAAA,WAAAC,IAAA,EAAAC,KAAA,EAAAC,QAAA;MACA,IAAAC,GAAA;MACA,IAAAF,KAAA,WAAAA,KAAA,KAAAG,SAAA,IAAAH,KAAA;QACAC,QAAA;MACA;QACA,IAAAC,GAAA,CAAAE,IAAA,CAAAJ,KAAA;UACAC,QAAA;QACA;UACAA,QAAA,KAAAI,KAAA;QACA;MACA;IACA;IACA;MACAC,KAAA;MACAC,WAAA;MACAC,QAAA;MACAC,SAAA;MACAC,QAAA;MACAC,QAAA;QACAC,EAAA;QACAC,QAAA;QACAC,WAAA;QACAL,SAAA;QACAC,QAAA;MACA;MACAK,QAAA;QACAF,QAAA,GACA;UAAAG,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA,EACA;QACAT,SAAA,GACA;UAAAO,QAAA;UAAAC,OAAA;UAAAC,OAAA;QAAA;MAEA;IACA;EACA;EACAC,OAAA;IACAC,IAAA,WAAAA,KAAAC,IAAA,EAAAf,KAAA,EAAAC,WAAA;MAAA,IAAAe,KAAA;MACA,KAAAf,WAAA,GAAAA,WAAA;MACA,KAAAD,KAAA,GAAAA,KAAA;MACA,KAAAK,QAAA,CAAAC,EAAA,GAAAS,IAAA,CAAAT,EAAA;MACA,KAAAD,QAAA,CAAAE,QAAA,GAAAQ,IAAA,CAAAR,QAAA;MACA,KAAAJ,SAAA,GAAAY,IAAA,CAAAZ,SAAA;MACA,KAAAC,QAAA,GAAAW,IAAA,CAAAX,QAAA;;MAEA;MACA,KAAAa,KAAA;QACAC,GAAA,OAAAD,KAAA,CAAAE,QAAA;QACAC,MAAA;MACA,GAAAC,IAAA,WAAAC,IAAA;QAAA,IAAA/B,IAAA,GAAA+B,IAAA,CAAA/B,IAAA;QACA,IAAAA,IAAA,IAAAA,IAAA,CAAAgC,IAAA;UACAP,KAAA,CAAAd,QAAA,GAAAX,IAAA,CAAAiC,OAAA,CAAAT,IAAA;QACA;UACAC,KAAA,CAAAS,QAAA,CAAAC,KAAA,CAAAnC,IAAA,CAAAoC,GAAA;QACA;MACA;IAGA;IACAC,SAAA,WAAAA,UAAA;MACA,KAAAC,KAAA,CAAAxB,QAAA,CAAAyB,WAAA;IACA;IACA;IACAC,iBAAA,WAAAA,kBAAA;MAAA,IAAAC,MAAA;MACA,IAAAd,GAAA;MACA,SAAAlB,KAAA;QACAkB,GAAA;MACA;QACAA,GAAA;MACA;MAGA,KAAAjB,WAAA,CAAAgC,OAAA,WAAAC,OAAA;QACA,IAAAA,OAAA,CAAA/B,SAAA,IAAA6B,MAAA,CAAA7B,SAAA;UACA6B,MAAA,CAAAxB,WAAA,GAAA0B,OAAA,CAAA1B,WAAA;QACA;MACA;MACA,KAAAS,KAAA;QACAC,GAAA,OAAAD,KAAA,CAAAE,QAAA,CAAAD,GAAA;QACAE,MAAA;QACA7B,IAAA,OAAA0B,KAAA