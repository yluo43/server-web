etSelect","resetForm","batchAddDialog","show","cancel","_this4","$confirm","confirmButtonText","cancelButtonText","type","resetFields","catch","message"],"sources":["src/views/modules/contractManagement/orderFormToLead/index.vue"],"sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container style=\"height: 100%;\">\n      <el-form :inline=\"true\" :model=\"dataForm\" :rules=\"dataRule\" ref=\"dataForm\">\n<!--        <h1>订单导入</h1>-->\n        <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n          <div class=\"orManagement\" style=\"margin: 0 auto;display: block;width: 56%;\">\n<!--            <h2 style=\"margin-top: 0px\">关联合同</h2>-->\n            <el-form-item label=\"合同编号:\" prop=\"ContractNo\">\n              <el-autocomplete\n                :disabled=\"page==='update'\"\n                value-key=\"name\"\n                v-model=\"dataForm.ContractNo\"\n                placeholder=\"请输入合同编号\"\n                clearable\n                :fetch-suggestions=\"handleSelect\"\n                @select=\"getSelect($event,'ContractNo')\"\n              >\n                <template slot-scope=\"{ item }\">\n                  <div class=\"name\">{{ item.contractNo }}</div>\n                </template>\n              </el-autocomplete>\n            </el-form-item>\n            <el-form-item label=\"合同名称:\" prop=\"contractName\">\n              <el-input v-model=\"dataForm.contractName\" placeholder=\"请输入合同名称\" :disabled=\"true\" clearable></el-input>\n            </el-form-item>\n          </div>\n          <updated ref=\"updatedDialog\"></updated>\n          <div style=\"display: inline-block;margin-top: 30px;margin-bottom: 25px;margin-left: 36%;\">\n            <el-button type=\"primary\" @click=\"refresh()\" icon=\"el-icon-search\" v-loading.fullscreen.lock=\"fullscreenLoading\">提交</el-button>\n            <el-button type=\"danger\" v-if=\"page==='update'\" @click=\"resetForm()\">取消</el-button>\n            <el-button type=\"danger\" v-else @click=\"cancel()\">重置</el-button>\n            <el-button type=\"primary\" v-if=\"page !=='update'\" @click=\"batchAdd()\">批量添加</el-button>\n          </div>\n          <baseDialog :title=\"titles\" ref=\"batchAddDialog\" :width=\"'400px'\">\n            <template>\n              <batchAdd @refreshDataList=\"refresh\" ref=\"batchAdd\"></batchAdd>\n            </template>\n          </baseDialog>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport basepicupload from '../../base/basePicUpload.vue'\nimport baseDialog from '../../base/baseDialog.vue'\nimport updated from './add.vue'\nimport batchAdd from './batchadd.vue'\nexport default {\n  data() {\n    var validateContract = (rule, value, callback) => {\n      if (value === null || value === '' && this.dataForm.ContractNo === '') {\n        callback(new Error('请输入合同编号!'))\n      }\n      callback()\n    }\n    return {\n      fullscreenLoading: false,\n      page: 'add',\n      titles: '',\n      fileList: [],\n      sonList: '',\n      getChildValue: '',\n      dataForm: {\n        contractName: '',\n        ContractNo: ''\n      },\n      dataRule: {\n        ContractNo: [\n          { required: true, validator: validateContract, trigger: 'change' }\n        ]\n      }\n    }\n  },\n  components: {\n    basepicupload, updated, baseDialog, batchAdd\n  },\n  created() {\n    setTimeout(()=>{\n      this.getChildValue = this.dataForm\n    })\n  },\n  methods: {\n    refresh() {\n      let sonList = this.$refs['updatedDialog'].passFath()\n      console.log(sonList);\n      let that = this\n      let formData = new FormData()\n      if (this.dataForm.ContractNo === '') {\n        this.$message.error('请先绑定合同编号')\n        return false\n      }\n      formData.append('belongContractNo', this.dataForm.ContractNo)\n      let go=true\n      for (let i = 0; i < sonList.length; i++) {\n        if (sonList[i].contractName === '') {\n          this.$message.error('订单信息（' + (i + 1) + '）：订单名称不可为空')\n          go = false\n          break\n        }\n        if (sonList[i].contractNo === '') {\n          this.$message.error('订单信息（' + (i + 1) + '）：订单编号不可为空')\n          go = false\n          break\n        }\n        if (sonList[i].contractValue === '') {\n          this.$message.error('订单信息（' + (i + 1) + '）：订单金额（含税）')\n          go = false\n          break\n        }\n        if (sonList[i].notCTaxValue === '') {\n          this.$message.error('订单信息 （' + (i + 1) + '）：订单金额（含税）不可为空')\n          go = false\n          break\n        }\n        if (sonList[i].isSign === '') {\n          this.$message.error('订单信息 （' + (i + 1) + '）：签字为必选')\n          go = false\n          break\n        }\n        if (sonList[i].isStamp === '') {\n          this.$message.error('订单信息 （' + (i + 1) + '）：盖章为必选')\n          go = false\n          break\n        }\n        if (sonList[i].orderType === '') {\n          this.$message.error('订单信息 （' + (i + 1) + '）：订单类型为必选')\n          go = false\n          break\n        }\n        if (sonList[i].signedDate === '') {\n          this.$message.error('订单信息 （' + (i + 1) + '）：签订日期不可为空')\n          go = false\n          break\n        }\n        if(!go)\n          return false\n        formData.append(\"ordersPOS[\"+i+\"].contractName\", sonList[i].contractName)\n        formData.append(\"ordersPOS[\"+i+\"].contractNo\", sonList[i].contractNo)\n        formData.append(\"ordersPOS[\"+i+\"].contractValue\", sonList[i].contractValue)\n        formData.append(\"ordersPOS[\"+i+\"].isSign\", sonList[i].isSign)\n        formData.append(\"ordersPOS[\"+i+\"].isStamp\", sonList[i].isStamp)\n        formData.append(\"ordersPOS[\"+i+\"].notCTaxValue\", sonList[i].notCTaxValue)\n        formData.append(\"ordersPOS[\"+i+\"].orderType\", sonList[i].orderType)\n        formData.append(\"ordersPOS[\"+i+\"].salesManager\", sonList[i].salesManager)\n        formData.append(\"ordersPOS[\"+i+\"].userName\", sonList[i].userName)\n        formData.append(\"ordersPOS[\"+i+\"].signedDate\", sonList[i].signedDate)\n        if (sonList[i].orderMaterials) {\n          let value = sonList[i].orderMaterials\n          for (let a in value) {\n            formData.append(\"ordersPOS[\"+i+\"].orderMaterials\", value[a].raw)\n          }\n        }\n      }\n      if(!go)\n        return false\n      this.$http\n        .post(this.$http.adornUrl('/orderImport/import'), formData)\n        .then(function({ data }) {\n          that.fullscreenLoading = true\n          if (data.success) {\n            that.fullscreenLoading = false\n            that.$message.success('导入成功')\n            that.cancel1()\n            that.$parent.hide()\n          } else {\n            that.cancel1()\n            that.fullscreenLoading = false\n            that.$message.warning(data.msg)\n          }\n        })\n    },\n    init(object) {\n      this.page = 'update'\n      this.dataForm.ContractNo = object.item.contractNo\n      this.dataForm.contractName = object.item.contractName\n      this.$nextTick(() => {\n        this.$refs.updatedDialog.init(object, 'update')\n      })\n    },\n    handleSelect(queryString, cb) {\n      this.$http({\n        url: this.$http.adornUrl('/orderImport/contract'),\n        method: 'get',\n        params: this.$http.adornParams({ 'ContractNo': this.dataForm.ContractNo })\n      }).then(({ data }) => {\n        if (data && data.code === 200) {\n          cb(data.payload)\n        } else {\n          cb([])\n        }\n      })\n    },\n    getSelect(item) {\n      if (this.dataForm.ContractNo === '') {\n        this.dataForm.ContractNo = ''\n        this.dataForm.contractName = ''\n      } else {\n        this.dataForm.ContractNo = item.contractNo\n        this.dataForm.contractName = item.contractName\n      }\n    },\n    resetForm() {\n      this.$parent.hide()\n    },\n    batchAdd() {\n      this.titles = '批量添加'\n      this.$refs.batchAddDialog.show()\n    },\n    cancel() {\n      this.$confirm(`您确定重置吗?`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.$refs['updatedDialog'].resetForm()\n        this.$refs.dataForm.resetFields()\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消重置'\n        })\n      })\n    },\n    cancel1() {\n      this.$refs['updatedDialog'].resetForm()\n      this.$refs.dataForm.resetFields()\n    }\n  }\n}\n</script>\n<style scoped>\n  .el-form--inline>.inputlist>.orManagement>.el-form-item{\n    width: 40%;\n    margin-top: 20px;\n  }\n  .el-form--inline>.inputlist>.orderInformation>.el-form-item{\n    width: 25%;\n  }\n  .el-input{\n    width: 200px\n  }\n  .el-button{\n    width: 90px;\n    height: 40px;\n    margin-right: 50px;\n  }\n  .base-pic-upload .el-upload{\n    text-align: center;\n    display: inline-block;\n  }\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA6CA,OAAAA,aAAA;AACA,OAAAC,UAAA;AACA,OAAAC,OAAA;AACA,OAAAC,QAAA;AACA;EACAC,IAAA,WAAAA,KAAA;IAAA,IAAAC,KAAA;IACA,IAAAC,gBAAA,YAAAA,iBAAAC,IAAA,EAAAC,KAAA,EAAAC,QAAA;MACA,IAAAD,KAAA,aAAAA,KAAA,WAAAH,KAAA,CAAAK,QAAA,CAAAC,UAAA;QACAF,QAAA,KAAAG,KAAA;MACA;MACAH,QAAA;IACA;IACA;MACAI,iBAAA;MACAC,IAAA;MACAC,MAAA;MACAC,QAAA;MACAC,OAAA;MACAC,aAAA;MACAR,QAAA;QACAS,YAAA;QACAR,UAAA;MACA;MACAS,QAAA;QACAT,UAAA,GACA;UAAAU,QAAA;UAAAC,SAAA,EAAAhB,gBAAA;UAAAiB,OAAA;QAAA;MAEA;IACA;EACA;EACAC,UAAA;IACAxB,aAAA,EAAAA,aAAA;IAAAE,OAAA,EAAAA,OAAA;IAAAD,UAAA,EAAAA,UAAA;IAAAE,QAAA,EAAAA;EACA;EACAsB,OAAA,WAAAA,QAAA;IAAA,IAAAC,MAAA;IACAC,UAAA;MACAD,MAAA,CAAAR,aAAA,GAAAQ,MAAA,CAAAhB,QAAA;IACA;EACA;EACAkB,OAAA;IACAC,OAAA,WAAAA,QAAA;MACA,IAAAZ,OAAA,QAAAa,KAAA,kBAAAC,QAAA;MACAC,OAAA,CAAAC,GAAA,CAAAhB,OAAA;MACA,IAAAiB,IAAA;MACA,IAAAC,QAAA,OAAAC,QAAA;MACA,SAAA1B,QAAA,CAAAC,UAAA;QACA,KAAA0B,QAAA,CAAAC,KAAA;QACA;MACA;MACAH,QAAA,CAAAI,MAAA,0BAAA7B,QAAA,CAAAC,UAAA;MACA,IAAA6B,EAAA;MACA,SAAAC,CAAA,MAAAA,CAAA,GAAAxB,OAAA,CAAAyB,MAAA,EAAAD,CAAA;QACA,IAAAxB,OAAA,CAAA