  placeholder=\"请输入项目（事由）名称\" clearable></el-input>\n          </el-form-item>\n\n          <el-form-item label=\"所属部门\" prop=\"deptId\">\n            <el-select  v-model=\"dataForm.deptId\" placeholder=\"请选择所属部门\" >\n              <el-option      v-for=\"item in deptList\"\n                              :key=\"item.id\"\n                              :label=\"item.deptName\"\n                              :value=\"item.id\">\n              </el-option>\n            </el-select>\n          </el-form-item>\n\n<!--          <el-form-item label=\"所属团队\" >-->\n<!--            <el-select   placeholder=\"请选择所属团队\" >-->\n<!--              <option></option>-->\n<!--            </el-select>-->\n<!--          </el-form-item>-->\n\n\n\n\n\n\n          <div style=\"margin-top:20px;text-align:center;\">\n            <el-form-item>\n              <el-button type=\"primary\" @click=\"addOrUpdateHandle()\">提交</el-button>\n              <el-button  @click=\"cancelDialog()\">取消</el-button>\n            </el-form-item>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n\n    return {\n      query: false,\n      deptList:[],\n      dataForm: {\n        id:'',\n        name: '',\n        deptId: '',\n        teamId: '',\n        createTime:'',\n        updateTime:'',\n        createUser:'',\n        updateUser:''\n      }\n    }\n  },\n  methods: {\n    init(list, query, managerList) {\n      this.query = query\n      if(query){\n        this.dataForm = {...list}\n      }\n\n      //初始化deptList\n      this.$http({\n        url: this.$http.adornUrl('/deptInfo/listAll'),\n        method: 'get'\n      }).then(({data}) => {\n        if (data && data.code === 200) {\n          this.deptList = data.payload.list\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n\n\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let url\n      if(this.query){\n        url = '/costItems/update'\n      }else{\n        url = '/costItems/add'\n      }\n\n      console.log(this.dataForm)\n      this.$http({\n        url: this.$http.adornUrl(url),\n        method: 'post',\n        data: this.$http.adornData(\n          this.dataForm\n        )\n      }).then(({ data }) => {\n        if (data.success) {\n          this.$emit('refreshDataList')\n          this.$parent.hide()\n          this.$message({\n            message: '操作成功',\n            type: 'success'\n          })\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n\n<style scoped>\n  ::v-deep .el-form-item__label{\n    width: 140px;\n  }\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA0CA;EACAA,IAAA,WAAAA,KAAA;IAEA;MACAC,KAAA;MACAC,QAAA;MACAC,QAAA;QACAC,EAAA;QACAC,IAAA;QACAC,MAAA;QACAC,MAAA;QACAC,UAAA;QACAC,UAAA;QACAC,UAAA;QACAC,UAAA;MACA;IACA;EACA;EACAC,OAAA;IACAC,IAAA,WAAAA,KAAAC,IAAA,EAAAb,KAAA,EAAAc,WAAA;MAAA,IAAAC,KAAA;MACA,KAAAf,KAAA,GAAAA,KAAA;MACA,IAAAA,KAAA;QACA,KAAAE,QAAA,GAAAc,aAAA,KAAAH,IAAA;MACA;;MAEA;MACA,KAAAI,KAAA;QACAC,GAAA,OAAAD,KAAA,CAAAE,QAAA;QACAC,MAAA;MACA,GAAAC,IAAA,WAAAC,IAAA;QAAA,IAAAvB,IAAA,GAAAuB,IAAA,CAAAvB,IAAA;QACA,IAAAA,IAAA,IAAAA,IAAA,CAAAwB,IAAA;UACAR,KAAA,CAAAd,QAAA,GAAAF,IAAA,CAAAyB,OAAA,CAAAX,IAAA;QACA;UACAE,KAAA,CAAAU,QAAA,CAAAC,KAAA,CAAA3B,IAAA,CAAA4B,GAAA;QACA;MACA;IAGA;IACAC,SAAA,WAAAA,UAAA;MACA,KAAAC,KAAA,CAAA3B,QAAA,CAAA4B,WAAA;IACA;IACA;IACAC,iBAAA,WAAAA,kBAAA;MAAA,IAAAC,MAAA;MACA,IAAAd,GAAA;MACA,SAAAlB,KAAA;QACAkB,GAAA;MACA;QACAA,GAAA;MACA;MAEAe,OAAA,CAAAC,GAAA,MAAAhC,QAAA;MACA,KAAAe,KAAA;QACAC,GAAA,OAAAD,KAAA,CAAAE,QAAA,CAAAD,GAAA;QACAE,MAAA;QACArB,IAAA,OAAAkB,KAAA,CAAAkB,SAAA,CACA,KAAAjC,QACA;MACA,GAAAmB,IAAA,WAAAe,KAAA;QAAA,IAAArC,IAAA,GAAAqC,KAAA,CAAArC,IAAA;QACA,IAAAA,IAAA,CAAAsC,OAAA;UACAL,MAAA,CAAAM,KAAA;UACAN,MAAA,CAAAO,OAAA,CAAAC,IAA