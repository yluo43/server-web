ock;width: 600px;\">\n            <el-form-item label=\"历史关键词:\" prop=\"words\">\n              <el-input v-model=\"dataForm.words\" placeholder=\"请输入关键词\"  clearable></el-input>\n            </el-form-item>\n            <el-form-item label=\"任务状态:\" prop=\"status\">\n              <el-select v-model=\"dataForm.status\" placeholder=\"请选择角色类型\">\n                <el-option label=\"全部\" value=\"\"></el-option>\n                <el-option      v-for=\"item in statusList\"\n                                :key=\"item.id\"\n                                :label=\"item.name\"\n                                :value=\"item.id\">\n                </el-option>\n              </el-select>\n            </el-form-item>\n          </div>\n          <div style=\"display: block;width: 493px; margin: 0 auto\">\n            <el-button type=\"primary\" @click=\"refresh()\" style=\"width: 100px\" icon=\"el-icon-search\" >查询</el-button>\n            <el-button type=\"danger\"  @click=\"cancel()\">重置</el-button>\n            <el-button type=\"primary\"  @click=\"batchAdd()\" style=\"width: 110px\">新增检索任务</el-button>\n          </div>\n        </div>\n      </el-form>\n      </el-header>\n      <baseTable :tableData=\"tableData\" ref=\"table\" :multiSelect=\"true\"  >\n        <template v-slot:clientType=\"row\">\n          <!--类型插槽-->\n          <template>\n            <el-tag type=\"primary\" @click=\"download(row.item)\">下载</el-tag>\n          </template>\n        </template>\n      </baseTable>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"batchAddDialog\" :width=\"'500px'\" :height=\"'300px'\">\n      <template>\n        <batchAdd :refreshDataList=\"refresh\" ref=\"batchAdd\" ></batchAdd>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport baseTable from '../../base/baseTableNoSelect.vue'\nimport baseDialog from '../../base/baseDialog.vue'\nimport batchAdd from \"./add\";\nexport default {\n  data() {\n    return {\n      titles: '',\n    