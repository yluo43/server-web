"append","raw","$http","post","adornUrl","_ref","close","success","payload","invoiceNum","amountInFiguers","totalAmount","array","split","hide","warning","msg","submit","contractNo","datas","go","i","addData"],"sources":["src/views/modules/contractManagement/invoiceToLead/add.vue"],"sourcesContent":["<template>\n  <div style=\"height:420px;overflow: auto;width: 95%; margin: 0 auto\" id=\"contentBar\">\n    <el-container>\n      <el-form :model=\"dataForm\" ref=\"dataForm\">\n        <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n          <div class=\"invoice\">\n            <el-form :model=\"dataForm\" ref=\"dataForm\" label-position=\"right\" size=\"small\">\n              <!--配置内容-->\n              <fieldset v-for=\"(item, index) in dataForm.invoices\" :key=\"index\" style=\"margin-bottom: 20px\">\n                <legend>发票信息 {{ index + 1 }}</legend>\n                <el-form-item label=\"发票代码:\" prop=\"invoiceCode\">\n                  <el-input v-model=\"item.invoiceCode\" maxlength=\"11\"/>\n                </el-form-item>\n                <el-form-item label=\"发票号码:\" prop=\"invoiceNumber\">\n<!--                  <el-input v-model=\"item.invoiceNumber\" maxlength=\"255\" :disabled=\"page==='update'\"/>-->\n                  <el-input v-model=\"item.invoiceNumber\" maxlength=\"255\" />\n                </el-form-item>\n                <el-form-item label=\"发票金额(不含税):\">\n                  <el-input v-model=\"item.invoiceAmountExcludeTax\" oninput=\"if(isNaN(value)) { value = null } {value=value.replace(/[^0-9999999.]/g,'')} if(value.indexOf('.')>0){value=value.slice(0,value.indexOf('.')+3)}\"\n maxlength=\"255\"/>\n                </el-form-item>\n                <el-form-item label=\"发票金额(含税):\">\n                  <el-input v-model=\"item.invoiceAmountIncludeTax\" oninput=\"if(isNaN(value)) { value = null } {value=value.replace(/[^0-9999999.]/g,'')} if(value.indexOf('.')>0){value=value.slice(0,value.indexOf('.')+3)}\"\n maxlength=\"255\"/>\n                </el-form-item>\n                <el-form-item label=\"开票日期:\">\n                  <el-date-picker style=\"width: 175px\" v-model=\"item.invoiceDate\" type=\"date\"\n                                  value-format=\"yyyy-MM-dd\" placeholder=\"选择日期时间\"\n                                 />\n                </el-form-item>\n                <el-form-item label=\"发票核实:\">\n                  <el-select v-model=\"item.isSign\" placeholder=\"请选择\">\n                    <el-option label=\"是\" :value=\"1\"></el-option>\n                    <el-option label=\"否\" :value=\"0\"></el-option>\n                  </el-select>\n                </el-form-item>\n                <el-form-item label=\"发票材料\">\n                  <el-button size=\"small\" type=\"primary\" @click=\"pictureList(index)\">添加图片</el-button>\n                </el-form-item>\n                <!--                  <i class=\"el-icon-error\"  @click=\"del(index)\"   style=\"color: red;-->\n                <!--    position: relative;-->\n                <!--    top: -69px;-->\n                <!--    right: -767px;-->\n                <!--    font-size: 30px;\"></i>-->\n                <!-- <el-button type=\"danger\" style=\"width: 50px\" @click=\"del(index)\" icon=\"el-icon-delete\" ></el-button>-->\n                <el-button v-if=\"page==='add'\" type=\"danger\" style=\"width: 100px;margin-top: 3px\" @click=\"del(index)\" icon=\"el-icon-delete\">\n                  删除发票\n                </el-button>\n              </fieldset>\n\n              <div style=\"text-align: center;\" v-if=\"page==='add'\">\n                <el-button type=\"success\" @click=\"addData()\" style=\"width: 120px;\" icon=\"el-icon-circle-plus\">\n                  增加发票\n                </el-button>\n              </div>\n            </el-form>\n            <div style=\"text-align: center;margin-top: 10px;margin-bottom: 30px\">\n              <el-button class=\"mainButton\" type=\"primary\" @click=\"submit()\" icon=\"el-icon-search\">提交</el-button>\n              <el-button class=\"mainButton\" v-if=\"page==='add'\" type=\"danger\" @click=\"cancel()\">重置</el-button>\n              <el-button class=\"mainButton\" v-if=\"page==='add'\" type=\"primary\" @click=\"batchAdd()\">批量上传</el-button>\n              <el-button class=\"mainButton\" v-else type=\"danger\" @click=\"resetForm()\">取消</el-button>\n\n            </div>\n            <baseDialog :title=\"titles\" ref=\"pictureListDialog\" :width=\"'700px'\">\n              <template>\n                <pictureList @refreshDataList=\"refresh\" ref=\"picture\" @uploadFile=\"uploadFile\"\n                             ></pictureList>\n              </template>\n            </baseDialog>\n            <baseDialog :title=\"titles\" ref=\"batchAddDialog\" :width=\"'400px'\">\n              <template>\n                <batchAdd @refreshDataList=\"refresh\" ref=\"batchAdd\" url=\"/invoice/import-invoices\"></batchAdd>\n              </template>\n            </baseDialog>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport pictureList from './picture.vue'\nimport baseDialog from \"@/views/modules/base/baseDialog\";\nimport batchAdd from './batchadd.vue'\nexport default {\n  data() {\n    return {\n      titles: '',\n      checkboxList: [],\n      dialogImageUrl: '',\n      dialogVisible: false,\n      dataForm: {\n        invoices: [{\n          invoiceId: '',\n          invoiceDate: '',\n          invoiceCode: '',\n          invoiceNumber: '',\n          invoiceAmountExcludeTax: '',\n          invoiceAmountIncludeTax: '',\n          invoiceImage: '',\n          invoiceImageFile: undefined,\n          isSign: 0\n        }\n        ]\n      }\n    }\n  },\n  components: {\n    pictureList, baseDialog, batchAdd\n  },\n  props: {\n    page: {\n      type: String,\n      default: 'add'\n    },\n    dataFormFather: {\n      type: Object,\n      default: {}\n    }\n  },\n  mounted() {\n    if (this.dataFormFather !== null) {\n      this.dataForm.invoices.length = 0;\n      this.dataForm.invoices.push(this.dataFormFather)\n    }\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    resetForm() {\n      this.$emit('addupdata', false)\n    },\n    batchAdd() {\n      this.titles = '批量添加'\n      this.$refs.batchAddDialog.show()\n    },\n    cancel() {\n      this.$confirm(`您确定重置吗?`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.$emit('resetForm', true)\n        Object.assign(this.$data, this.$options.data())\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消重置'\n        })\n      })\n    },\n    cancel1() {\n      this.$emit('resetForm', true)\n      Object.assign(this.$data, this.$options.data())\n    },\n    del(index) {\n      if (this.dataForm.invoices.length <= 1) {\n        this.$message.error(\"发票只剩一张！\")\n        return\n      }\n      this.dataForm.invoices.splice(index, 1)\n    },\n    pictureList(index) {\n      this.titles = '上传图片'\n      this.$refs.pictureListDialog.show()\n      this.$nextTick(() => {\n        this.$refs.picture.init(this.dataForm.invoices[index].invoiceImageFile,index)\n      })\n    },\n    uploadFile(file,index) {\n      this.dataForm.invoices[index].invoiceImageFile = file\n      if(!file){\n        this.clearForm(index)\n        return\n      }\n      let loading = this.$loading({\n        lock: true, // lock的修改符--默认是false\n        text: '发票识别中，请稍候...', // 显示在加载图标下方的加载文案\n        background: 'rgba(0,0,0,0.8)', // 遮罩层颜色\n        spinner: 'el-icon-loading' // 自定义加载图标类名\n      })\n      let formData = new FormData();\n      let that = this\n      formData.append('uploadFile',this.dataForm.invoices[index].invoiceImageFile.raw)\n      this.$http\n        .post(this.$http.adornUrl('/invoice/analysis'), formData)\n        .then(function ({data}) {\n          loading.close()\n          if (data && data.success) {\n            that.$message.success('识别成功')\n            that.dataForm.invoices[index].invoiceCode = data.payload.invoiceCode\n            that.dataForm.invoices[index].invoiceNumber = data.payload.invoiceNum\n            that.dataForm.invoices[index].invoiceAmountIncludeTax = data.payload.amountInFiguers\n            that.dataForm.invoices[index].invoiceAmountExcludeTax = data.payload.totalAmount\n            let array = data.payload.invoiceDate.split(/年|月|日/)\n            that.dataForm.invoices[index].invoiceDate = array[0]+'-'+array[1]+'-'+array[2]\n            that.$refs.pictureListDialog.hide()\n          } else {\n            that.clearForm(index)\n            that.$message.warning(data.msg)\n          }\n        })\n        .catch(function(error) {\n          that.$message.error('识别失败')\n          loading.close()\n        })\n\n    },\n    clearForm(index){\n      this.dataForm.invoices[index].invoiceCode = ''\n      this.dataForm.invoices[index].invoiceNumber = ''\n      this.dataForm.invoices[index].invoiceAmountIncludeTax = ''\n      this.dataForm.invoices[index].invoiceAmountExcludeTax = ''\n      this.dataForm.invoices[index].invoiceDate = ''\n    },\n    submit() {\n      if(this.dataForm.invoices[0].contractNo==\"\"){\n        this.$message.error(\"请先绑定合同\")\n        return false;\n      }\n      const datas = this.dataForm.invoices;\n      var go = true;\n      for(let i = 0; i < datas.length; i++) {\n        if(datas[i].invoiceCode==\"\"){\n          this.$message.error(\"发票信息（\"+(i+1)+\"）：发票代码不可为空\")\n          go  = false;\n          break\n        }\n        if(datas[i].invoiceNumber==\"\"){\n          this.$message.error(\"发票信息（\"+(i+1)+\"）：票号码不可为空\")\n          go  = false;\n          break\n        }\n        if(datas[i].invoiceAmountExcludeTax==\"\"){\n          this.$message.error(\"发票信息（\"+(i+1)+\"）：发票金额（不含税）不可为空\")\n          go  = false;\n          break\n        }\n        if(datas[i].invoiceAmountIncludeTax==\"\"){\n          this.$message.error(\"发票信息（\"+(i+1)+\"）：发票金额（含税）不可为空\")\n          go  = false;\n          break\n        }\n        if(datas[i].invoiceDate==\"\"){\n          this.$message.error(\"发票信息（\"+(i+1)+\"）：开票日期不可为空\")\n          go  = false;\n          break\n        }\n      }\n      if(!go)\n        return false;\n\n      this.$emit(\"submit\", this.dataForm.invoices)\n    },\n    // 添加行数据\n    addData() {\n      this.dataForm.invoices.push({\n        invoiceId: '',\n        invoiceDate: '',\n        invoiceCode: '',\n        invoiceNumber: '',\n        invoiceAmountExcludeTax: '',\n        invoiceAmountIncludeTax: '',\n        invoiceImage: '',\n        invoiceImageFile: undefined,\n        isSign: 0\n      })\n    }\n  }\n}\n</script>\n<style scoped>\n.el-form--inline > .inputlist > .orManagement > .el-form-item {\n  width: 20%;\n}\n\n/*.el-input--small .el-input__inner*/\n::v-deep .mainButton {\n  width: 90px;\n  height: 40px;\n}\n\n.base-pic-upload .el-upload {\n  text-align: center;\n  display: inline-block;\n}\n\n.el-form-item__content {\n  margin-left: 0 !important;\n  width: 50% !important;\n}\n\n::v-deep .el-form-item__label {\n  font-weight: 400;\n}\n\n#contentBar::-webkit-scrollbar { /*滚动条整体样式*/\n  width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n  height: 8px;\n}\n\n#contentBar::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n  border-radius: 10px;\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  background: #e1f1f1;\n}\n\n#contentBar::-webkit-scrollbar-track { /*滚动条里面轨道*/\n  -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n  border-radius: 10px;\n  background: #fff;\n}\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAiFA,OAAAA,WAAA;AACA,OAAAC,UAAA;AACA,OAAAC,QAAA;AACA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,MAAA;MACAC,YAAA;MACAC,cAAA;MACAC,aAAA;MACAC,QAAA;QA