n              name=\"uploadFile\"\n              ref=\"uploadFile\"\n              :accept=\"'.xls,.xlsx'\"\n              :file-list=\"uploadFile\"\n              :hideAllBtn=\"true\"\n            ></baseUpload>\n          </el-form-item>\n          <div style=\"margin-top:20px;text-align:center;\">\n            <el-form-item>\n              <el-button type=\"success\" @click=\"addOrUpdateHandle()\">提交</el-button>\n              <el-button type=\"danger\" @click=\"cancelDialog()\">取消</el-button>\n            </el-form-item>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseDialog from '../../base/baseDialog.vue'\nimport baseUpload from '../../base/baseUpload.vue'\nexport default {\n  data() {\n    return {\n      textarea: '',\n      status: '',\n      titles: '',\n      amend: '',\n      uploadFile: [],\n      dataForm: {\n      }\n    }\n  },\n  components: { baseDialog, baseUpload },\n  methods: {\n    init(amend) {\n      this.amend = amend\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    buildFormData(dom) {\n      let formData = new FormData(dom)\n      for (let i = 0; i < dom.length; i++) {\n        let element = dom[i]\n        if (element['type'] === 'uploadFile' && element.files.length === 0) {\n          formData.delete(element.name)\n        }\n      }\n      return formData\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let formData = this.buildFormData(this.$refs.dataForm.$el)\n      this.$refs.dataForm.validate((valid) => {\n        this.$http({\n          url: this.$http.adornUrl(this.amend ? '/contractManager/partyAContactInfo' : '/clbatch/batchimport'),\n          method: 'post',\n          data: formData\n        }).then(({ data }) => {\n          if (data.success) {\n            if (this.amend) {\n              this.$message({\n                message: '成功导入',\n                type: 'success'\n              })\n            } else {\n              this.$message({\n                message: '上传成功，成功导入' + data.payload + '个',\n                type: 'success'\n              })\n            }\n            this.$parent.hide()\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    },\n\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n<style scoped>\n  ::v-deep .el-form-item{\n    width: 100%;\n  }\n  ::v-deep .el-form{\n    width: 100%;\n  }\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;AA2BA,OAAAA,UAAA;AACA,OAAAC,UAAA;AACA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA;MACAC,MAAA;MACAC,MAAA;MACAC,KAAA;MACAC,UAAA;MACAC,QAAA,GACA;IACA;EACA;EACAC,UAAA;IAAAT,UAAA,EAAAA,UAAA;IAAAC,UAAA,EAAAA;EAAA;EACAS,OAAA;IACAC,IAAA,WAAAA,KAAAL,KAAA;MACA,KAAAA,KAAA,GAAAA,KAAA;IACA;IACAM,SAAA,WAAAA,UAAA;MACA,KAAAC,KAAA,CAAAL,QAAA,CAAAM,WAAA;IACA;IACAC,aAAA,WAAAA,cAAAC,GAAA;MACA,IAAAC,QAAA,OAAAC,QAAA,CAAAF,GAAA;MACA,SAAAG,CAAA,MAAAA,CAAA,GAAAH,GAAA,CAAAI,MAAA,EAAAD,CAAA;QACA,IAAAE,OAAA,GAAAL,GAAA,CAAAG,CAAA;QACA,IAAAE,OAAA,6BAAAA,OAAA,CAAAC,KAAA,CAAAF,MAAA;UACAH,QAAA,CAAAM,MAAA,CAAAF,OAAA,CAAAG,IAAA;QACA;MACA;MACA,OAAAP,QAAA;IACA;IACA;IACAQ,iBAAA,WAAAA,kBAAA;MAAA,IAAAC,KAAA;MACA,IAAAT,QAAA,QAAAF,aAAA,MAAAF,KAAA,CAAAL,QAAA,CAAAmB,GAAA;MACA,KAAAd,KAAA,CAAAL,QAAA,CAAAoB,QAAA,WAAAC,KAAA;QACAH,KAAA,CAAAI,KAAA;UACAC,GAAA,EAAAL,KAAA,CAAAI,KAAA,CAAAE,QAAA,CAAAN,KAAA,CAAApB,KAAA;UACA2B,MAAA;UACA/B,IAAA,EAAAe;QACA,GAAAiB,IAAA,WAAAC,IAAA;UAAA,IAAAjC,IAAA,GAAAiC,IAAA,CAAAjC,IAAA;UACA,IAAAA,IAAA,CAAAkC,OAAA;YACA,IAAAV,KAAA,CAAApB,KAAA;cACAoB,KAAA,CAAAW,QAAA;gBACAC,OAAA;gBACAC,IAAA;cACA;YACA;cACAb,KAAA,CAAAW,QAAA;gBACAC,OAAA,gBAAApC,IAAA,CAAAsC,OAAA;gBACAD,IAAA;cACA;YACA;YACAb,KAAA,CAAAe,OAAA,CAAAC,IAAA;UACA;YACAhB,KAAA,CAAAW,QAAA,CAAAM,KAAA,CAAAzC,IAAA,CAAA0C,GAAA;UACA;QACA;MACA;IACA;IAEA;IACAC,YAAA,WAAAA,aAAA;MACA,KAAAJ,OAAA,CAAAC,IAAA;IACA;EACA;AACA"}]}