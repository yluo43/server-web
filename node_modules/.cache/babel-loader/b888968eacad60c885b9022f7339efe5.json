ndlePictureCardPreview\"\n      :on-change=\"handleOnChange\"\n      :on-remove=\"handleOnRemove\"\n      :file-list=\"nowFileList\"\n    >\n      <el-button slot=\"trigger\" size=\"small\" type=\"primary\">添加图片</el-button>\n      <el-button style=\"margin-left: 10px;height: 30px;margin-top: 34px;width: 75px\" size=\"small\" type=\"danger\" @click=\"submitUpload\">关闭</el-button>\n    </el-upload>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      dialogImageUrl: '',\n      dialogVisible: false,\n      disabled: false,\n      isChanged: false,\n      index: 0,\n      nowFileList: []\n    }\n  },\n  props: {\n    name: {\n      type: String,\n      default: 'file'\n    },\n    onValid: {\n      type: Function\n    },\n    file: {\n      type: Object\n    },\n    accept: {\n      type: String,\n      default: '.jpg,.png,.JPG,.PNG,.Png,.PNg,.pNG,.Jpg,.JPg,.JpG,.jPG'\n    },\n    hideAllBtn: {\n      type: Boolean,\n      default: false\n    }\n  },\n  methods: {\n    init(file,index) {\n      if(file) {\n        this.nowFileList = [file]\n      }\n      this.index = index\n    },\n    handlePictureCardPreview(file) {\n      this.dialogImageUrl = file.url\n      this.dialogVisible = true\n    },\n    cancelFiles() {\n      if (this.getFileList().length > 0) {\n        this.$refs.upload.clearFiles()\n        this.isChanged = true\n      }\n    },\n    handleOnChange(file, fileList) {\n      let filetype = file.name.substr(file.name.lastIndexOf('.') + 1, file.name.length)\n      let flag = true\n      if (this.accept) {\n        let types = this.accept.replaceAll('.', '').split(',')\n        types.forEach((item, i) => {\n          if (item === filetype) {\n            flag = false\n          }\n        })\n      } else {\n        flag = false\n      }\n      if (flag) {\n        fileList.pop()\n        this.$message.warning('图片格式不正确')\n        return\n      } else {\n        if (this.onValid != null && !this.onValid(file, fileList)) {\n          fileList.pop()\n          // fileList.splice(0, fileList.length)\n          return\n        }\n      }\n      this.isChanged = true\n      this.nowFileList = [fileList[fileList.length - 1]]\n      this.$emit('uploadFile',this.nowFileList[0],this.index)\n    },\n    submitUpload() {\n      this.$parent.hide()\n    },\n    handleOnRemove(file, fileList) {\n      this.isChanged = true\n      this.nowFileList = fileList\n      this.$emit('uploadFile',fileList[0],this.index)\n    },\n    hasFile() {\n      return this.$refs.upload.uploadFiles.length > 0\n    },\n    getFileList() {\n      return this.$refs.upload.uploadFiles\n    }\n  }\n}\n</script>\n<style scoped>\n/* 取消eb-upload默认的按钮栏样式，用于按钮隐藏多余突出白块 */\n.base-pic-upload .el-upload{\n  display: block;\n  text-align: left;\n}\n::v-deep .el-dialog__body{\n  height: 130px;\n}\n  .base-pic-upload{\n    height: 130px;\n  }\n::v-deep .el-upload-list__item:first-child{\n  margin-top: 38px;\n  width: 300px;\n}\n::v-deep .el-upload-list--text{\n  display: inline-grid;\n  width: 150px;\n}\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;AAmBA;EACAA,IAAA,WAAAA,KAAA;IACA;MACAC,cAAA;MACAC,aAAA;MACAC,QAAA;MACAC,SAAA;MACAC,KAAA;MACAC,WAAA;IACA;EACA;EACAC,KAAA;IACAC,IAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAC,OAAA;MACAH,IAAA,EAAAI;IACA;IACAC,IAAA;MACAL,IAAA,EAAAM;IACA;IACAC,MAAA;MACAP,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAM,UAAA;MACAR,IAAA,EAAAS,OAAA;MACAP,OAAA;IACA;EACA;EACAQ,OAAA;IACAC,IAAA,WAAAA,KAAAN,IAAA,EAAAT,KAAA;MACA,IAAAS,IAAA;QACA,KAAAR,WAAA,IAAAQ,IAAA;MACA;MACA,KAAAT,KAAA,GAAAA,KAAA;IACA;IACAgB,wBAAA,WAAAA,yBAAAP,IAAA;MACA,KAAAb,cAAA,GAAAa,IAAA,CAAAQ,GAAA;MACA,KAAApB,aAAA;IACA;IACAqB,WAAA,WAAAA,YAAA;MACA,SAAAC,WAAA,GAAAC,MAAA;QACA,KAAAC,KAAA,CAAAC,MAAA,CAAAC,UAAA;QACA,KAAAxB,SAAA;MACA;IACA;IACAyB,cAAA,WAAAA,eAAAf,IAAA,EAAAgB,QAAA;MACA,IAAAC,QAAA,GAAAjB,IAAA,CAAAN,IAAA,CAAAwB,MAAA,CAAAlB,IAAA,CAAAN,IAAA,CAAAyB,WAAA,WAAAnB,IAAA,CAAAN,IAAA,CAAAiB,MAAA;MACA,IAAAS,IAAA;MACA,SAAAlB,MAAA;QACA,IAAAmB,KAAA,QAAAnB,MAAA,CAAAoB,UA