\n}\n\n.title-component {\n  position: relative;\n}\n\n.title-component::before {\n  content: \"\";\n  position: absolute;\n  width: 8px;\n  height: 12px;\n  top: 45%;\n  transform: translateY(-50%);\n  left: -15px;\n  background: linear-gradient(90deg, #68EAE8 0%, #296DFF 100%);\n}\n\n.in-div-cont {\n  border: 2px solid #e8edf4;\n  height: 100%;\n  border-radius: 3px;\n}\n\n.in-div-top {\n  height: 30px;\n  border-bottom: #5a5e66;\n  position: relative;\n  margin-bottom: 15px;\n}\n\n/*标题下方的横线*/\n.in-div-top::after {\n  content: '';\n  top: 35px;\n  position: absolute;\n  height: 1px;\n  width: 102%;\n  left: -16px;\n  background-color: #E4E4E4;\n}\n</style>\n"],"mappings":";;;;;;;;AAQA;EACAA,IAAA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA,MAAAC,GAAA;MACAC,SAAA;IACA;EACA;EACAC,KAAA;IACA;IACA;IACA;IACAC,IAAA;MACAC,IAAA,EAAAC;IACA;IACAC,OAAA;MACAF,IAAA,EAAAC;IACA;EACA;EACAE,OAAA,WAAAA,QAAA;IACA,SAAAR,QAAA,CAAAS,GAAA,MAAAF,OAAA,KAAAG,SAAA;MACA,KAAAR,SAAA,QAAAF,QAAA,CAAAS,GAAA,MAAAF,OAAA,EAAAI,KAAA;IACA;EACA;AACA"}]}