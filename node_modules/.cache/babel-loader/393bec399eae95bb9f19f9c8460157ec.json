\n      :on-remove=\"handleOnRemove\"\n      :file-list=\"fileList\"\n      :accept=\"accept\"\n      ref=\"upload\"\n    >\n      <div v-if=\"hideAllBtn\" class=\"test\">\n        <el-button slot=\"trigger\" size=\"small\" type=\"primary\" @click=\"selectFiles()\">选择文件</el-button>\n        <el-button size=\"small\" type=\"danger\" @click.stop=\"cancelFiles()\">删除文件</el-button>\n      </div>\n    </el-upload>\n    <el-dialog :visible.sync=\"dialogVisible\" title=\"查看图片\" :modal=\"false\">\n      <div style=\"overflow: auto; padding: 20px;\">\n        <img  :src=\"dialogImageUrl\" alt=\"\" style=\"display: block;margin: 0 auto;\"/>\n      </div>\n    </el-dialog>\n  </div>\n</template>\n<script>\nexport default {\n  data() {\n    return {\n      dialogImageUrl: '',\n      dialogVisible: false,\n      disabled: false,\n      isChanged: false,\n      nowFileList: this.fileList,\n      cancal: true,\n      remove: true\n    }\n  },\n  props: {\n    name: {\n      type: String,\n      defualt: 'file'\n    },\n    onValid: {\n      type: Function\n    },\n    fileList: {\n      type: Array,\n      default: function() {\n        return []\n      }\n    },\n    accept: {\n      type: String,\n      default: '.jpg,.png,.JPG,.PNG,.gif'\n    },\n    hideAllBtn: {\n      type: Boolean,\n      default: false\n    }\n  },\n  methods: {\n    handlePictureCardPreview(file) {\n      this.dialogImageUrl = file.url\n      this.dialogVisible = true\n    },\n    cancelFiles() {\n      this.remove = true\n      this.$emit('element', this.remove)\n      if (this.getFileList().length > 0) {\n        this.$refs.upload.clearFiles()\n        this.isChanged = true\n      }\n    },\n    selectFiles() {\n      this.cancal = true\n      this.$emit('selectFile', this.cancal)\n    },\n    handleOnChange(file, fileList) {\n      let filetype = file.name.substr(file.name.lastIndexOf('.') + 1, file.name.length)\n      let flag = true\n      if (this.accept) {\n        let types = this.accept.replaceAll('.', '').split(',')\n        types.forEach((item, i) => {\n          if (item === filetype) {\n            flag = false\n          }\n        })\n      } else {\n        flag = false\n      }\n      if (flag) {\n        fileList.pop()\n        this.$message.warning('图片格式不正确')\n        return\n      } else {\n        if (this.onValid != null && !this.onValid(file, fileList)) {\n          fileList.pop()\n          // fileList.splice(0, fileList.length)\n          return\n        }\n      }\n      if (fileList.length > 1) {\n        fileList.shift()\n      }\n      this.isChanged = true\n      this.nowFileList = fileList\n    },\n    handleOnRemove(file, fileList) {\n      this.isChanged = true\n      this.$emit('rement', this.isChanged)\n      this.nowFileList = fileList\n    },\n    hasFile() {\n      return this.$refs.upload.uploadFiles.length > 0\n    },\n    getFileList() {\n      return this.$refs.upload.uploadFiles\n    }\n  }\n}\n</script>\n<style>\n/* 取消eb-upload默认的按钮栏样式，用于按钮隐藏多余突出白块 */\n.base-pic-upload .el-upload{\n  display: block;\n  text-align: left;\n}\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;AA2BA;EACAA,IAAA,WAAAA,KAAA;IACA;MACAC,cAAA;MACAC,aAAA;MACAC,QAAA;MACAC,SAAA;MACAC,WAAA,OAAAC,QAAA;MACAC,MAAA;MACAC,MAAA;IACA;EACA;EACAC,KAAA;IACAC,IAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAC,OAAA;MACAH,IAAA,EAAAI;IACA;IACAT,QAAA;MACAK,IAAA,EAAAK,KAAA;MACAC,OAAA,WAAAC,SAAA;QACA;MACA;IACA;IACAC,MAAA;MACAR,IAAA,EAAAC,MAAA;MACAK,OAAA;IACA;IACAG,UAAA;MACAT,IAAA,EAAAU,OAAA;MACAJ,OAAA;IACA;EACA;EACAK,OAAA;IACAC,wBAAA,WAAAA,yBAAAC,IAAA;MACA,KAAAvB,cAAA,GAAAuB,IAAA,CAAAC,GAAA;MACA,KAAAvB,aAAA;IACA;IACAwB,WAAA,WAAAA,YAAA;MACA,KAAAlB,MAAA;MACA,KAAAmB,KAAA,iBAAAnB,MAAA;MACA,SAAAoB,WAAA,GAAAC,MAAA;QACA,KAAAC,KAAA,CAAAC,MAAA,CAAAC,UAAA;QACA,KAAA5B,SAAA;MACA;IACA;IACA6B,WAAA,WAAAA,YAAA;MACA,KAAA1B,MAAA;MACA,KAAAoB,KAAA,oBAAApB,MAAA;IACA;IACA2B,cAAA,WAAAA,eAAAV,IAAA,EAAAlB,QAAA;MACA,IAAA6B,QAAA,GAAAX,IAAA,CAAAd,IAAA,CAAA0B,MAAA,CAAAZ,IAAA,CAAAd,IAAA,CAAA2B,WAAA,