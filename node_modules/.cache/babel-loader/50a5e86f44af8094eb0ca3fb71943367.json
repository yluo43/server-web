ta","FormData","append","i","invoiceImageFile","raw","put","_ref4","success","cancel1","$emit","post","_ref5","beforeUpload","file","size","error"],"sources":["src/views/modules/contractManagement/invoiceToLead/index.vue"],"sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container style=\"height: 100%;\">\n      <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\" style=\"width:100%;\">\n<!--        <h1>发票导入</h1>-->\n        <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n          <div class=\"orManagement\" style=\"    padding-top: 20px;\" >\n<!--            <h2>关联合同</h2>-->\n            <el-row class=\"elRow\">\n            <el-form-item label=\"合同编号:\" prop=\"contractNo\" >\n              <el-autocomplete\n                value-key=\"contractNo\"\n                v-model=\"dataForm.contractNo\"\n                placeholder=\"请输入合同编号\"\n                clearable\n                style=\"width: 100%;\"\n                :fetch-suggestions=\"handleSelect\"\n                @select=\"getSelect($event,'contractNo')\"\n              >\n                <template slot-scope=\"{ item }\">\n                  <div class=\"name\">{{ item.contractNo }}</div>\n                </template>\n              </el-autocomplete>\n            </el-form-item>\n            </el-row>\n            <el-row class=\"elRow\">\n            <el-form-item label=\"合同名称:\" prop=\"contractName\" >\n              <el-autocomplete\n                value-key=\"contractName\"\n                v-model=\"dataForm.contractName\"\n                :disabled=\"true\"\n                placeholder=\"请输入合同名称\"\n                clearable\n                :fetch-suggestions=\"handleSelect\"\n                style=\"width: 100%\"\n                @select=\"getSelect($event,'contractName')\"\n              >\n                <template slot-scope=\"{ item }\">\n                  <div class=\"name\">{{ item.contractName }}</div>\n                </template>\n              </el-autocomplete>\n            </el-form-item>\n            </el-row>\n          </div>\n          <div class=\"orManagement\" >\n<!--            <h2>关联订单</h2>-->\n            <el-row class=\"elRow\">\n            <el-form-item label=\"订单编号:\" prop=\"orderContractNo\">\n              <el-autocomplete\n                :disabled=\"page==='update'\"\n                value-key=\"name\"\n                v-model=\"dataForm.orderContractNo\"\n                clearable\n                :fetch-suggestions=\"handleSelect1\"\n                @select=\"getSelect1($event,index)\">\n                <template slot-scope=\"{ item }\">\n                  <div class=\"name\">{{ item.contractNo }}</div>\n                </template>\n              </el-autocomplete>\n            </el-form-item>\n            </el-row>\n            <el-row class=\"elRow\">\n            <el-form-item label=\"订单名称:\" prop=\"orderContractName\"  >\n              <el-input\n                :disabled=\"true\"\n                v-model=\"dataForm.orderContractName\"\n                style=\"width: 108%\"\n              >\n              </el-input>\n            </el-form-item>\n            </el-row>\n          </div>\n          <addupdata :page=\"page\" :dataFormFather=\"dataForm\" @submit=\"submit\" @addupdata=\"addupdata\" @resetForm=\"resetForm\" ref=\"addupdata\"></addupdata>\n\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport basepicupload from '../../base/basePicUpload.vue'\nimport addupdata from './add.vue'\nexport default {\n  data() {\n    return {\n      page:\"add\",\n      fileList: [],\n      dataList: [],\n      dataForm: {\n        contractNo:'',\n        contractName: '',\n        orderContractNo:'',\n        orderContractName:'',\n        invoiceAmountExcludeTax: '',\n        invoiceAmountIncludeTax:'',\n        invoiceId: '',\n        invoiceCode:'',\n        invoiceDate:'',\n        invoiceNumber:'',\n        isSign: 0\n      },\n      dataForm1: {\n        name: '',\n        no: ''\n      }\n    }\n  },\n  components: {\n    basepicupload,\n    addupdata\n  },\n  mounted() {\n    let searchParams = {\n      name: '',\n      no: ''\n    }\n    // this.$http({\n    //   method: 'get',\n    //   url: this.$http.adornUrl('/invoice/contracts'),\n    //   params: this.$http.adornParams(Object.assign(this.dataForm, searchParams))\n    // }).then(({ data }) => {\n    //   if (data && data.code === 200) {\n    //     this.tableData.dataList.length = 0\n    //     this.tableData.dataList.push(...data.payload.list.list);\n    //     this.$refs.table.options.count = data.payload.list.totalCount\n    //     this.$refs.table.options.pageSize = data.payload.list.pageSize\n    //   } else {\n    //     this.$message.warning(data.msg)\n    //   }\n    // })\n    // this.$refs.table.refresh(this.dataForm)\n  },\n  methods: {\n    init(object) {\n      this.page= \"update\"\n      Object.assign(this.dataForm,object)\n\n    },\n    refresh() {\n      let that = this\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$http({\n          method: 'get',\n          url: that.$http.adornUrl('contractManager/list'),\n          params: that.$http.adornParams(Object.assign(this.dataForm, searchParams))\n        }).then(({ data }) => {\n          if (data && data.code === 200) {\n            this.tableData.dataList.length=0\n            that.tableData.dataList.push(...data.payload.list.list);\n            that.$refs.table.options.count=data.payload.list.totalCount\n            that.$refs.table.options.pageSize=data.payload.list.pageSize\n          } else {\n            that.$message.warning(data.msg)\n          }\n        })\n      })\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    handleSelect(queryString, cb) {\n      this.$http({\n        url: this.$http.adornUrl('/invoice/contracts'),\n        method: 'get',\n        params: this.$http.adornParams({ 'name': this.dataForm.contractName, 'no': this.dataForm.contractNo })\n      }).then(({ data }) => {\n        if (data && data.code === 200) {\n          cb(data.payload.splice(0,20))\n        } else {\n          cb([])\n        }\n      })\n    },\n    getSelect(item) {\n      if (this.dataForm.contractNo === '' && this.dataForm.contractName === '') {\n        this.dataForm.contractName = ''\n        this.dataForm.contractNo = ''\n      } else {\n        this.dataForm.contractNo = item.contractNo\n        this.dataForm.contractName = item.contractName\n      }\n    },\n    getSelect1(item) {\n      if (this.dataForm.orderContractNo === '' && this.dataForm.contractName === '') {\n        this.dataForm.orderContractName = ''\n        this.dataForm.orderContractNo = ''\n      } else {\n        this.dataForm.orderContractNo = item.contractNo\n        this.dataForm.orderContractName = item.contractName\n      }\n    },\n    handleSelect1(queryString, cb) {\n      this.$http({\n        url: this.$http.adornUrl('/invoice/orders'),\n        method: 'get',\n        params: this.$http.adornParams({ 'no': this.dataForm.contractNo })\n      }).then(({ data }) => {\n        if (data && data.code === 200) {\n          cb(data.payload)\n        } else {\n          cb([])\n        }\n      })\n    },\n    addupdata() {\n      this.$parent.hide()\n    },\n    submit(invoices) {\n      let that = this\n      let formData = new FormData();\n      formData.append(\"contractNo\", this.dataForm.contractNo)\n      formData.append(\"orderNo\", this.dataForm.orderContractNo)\n      for (let i=0;i<invoices.length;i++) {\n        formData.append(\"invoices[\"+i+\"].id\", invoices[i].invoiceId)\n        formData.append(\"invoices[\"+i+\"].invoiceCode\", invoices[i].invoiceCode)\n        formData.append(\"invoices[\"+i+\"].invoiceNumber\", invoices[i].invoiceNumber)\n        formData.append(\"invoices[\"+i+\"].invoiceAmountIncludeTax\", invoices[i].invoiceAmountIncludeTax)\n        formData.append(\"invoices[\"+i+\"].invoiceAmountExcludeTax\", invoices[i].invoiceAmountExcludeTax)\n        formData.append(\"invoices[\"+i+\"].invoiceDate\", invoices[i].invoiceDate)\n        formData.append(\"invoices[\"+i+\"].isSign\", invoices[i].isSign)\n        if(invoices[i].invoiceImageFile) {\n          formData.append(\"invoices[\" + i + \"].invoiceImageFile\", invoices[i].invoiceImageFile.raw)\n        }\n      }\n      if(this.page==='update') {\n        this.$http\n          .put(this.$http.adornUrl('/invoice/invoices'), formData)\n          .then(function ({data}) {\n            if (data && data.success) {\n              that.$message.success('修改成功')\n              that.$refs.dataForm.resetFields()\n              that.$refs.addupdata.cancel1()\n              that.$parent.hide()\n              that.$emit(\"refreshDataList\");\n            } else {\n              that.$message.warning(data.msg)\n            }\n          });\n      }else{\n        this.$http\n          .post(this.$http.adornUrl('/invoice/invoices'), formData)\n          .then(function ({data}) {\n            if (data && data.success) {\n              that.$message.success('新增成功')\n              that.$refs.dataForm.resetFields()\n              that.$refs.addupdata.cancel1()\n              that.$parent.hide()\n            } else {\n              that.$message.warning(data.msg)\n            }\n          });\n      }\n    },\n    // 上传图片前条件判断\n    beforeUpload(file) {\n      if (file.size / 1024 / 1024 >= 2) {\n        this.$message.error('图片不能超过2M')\n        return false\n      }\n      return true\n    }\n  }\n}\n</script>\n<style scoped>\n  .el-input{\n    width: 200px\n  }\n  .el-button{\n    width: 90px;\n    height: 40px;\n    margin-right: 50px;\n  }\n  .base-pic-upload .el-upload{\n    text-align: center;\n    display: inline-block;\n  }\n  .orManagement{\n    margin: 0 auto;\n    display: block;\n    width: 56%;\n  }\n  .elRow{\n    width: 40%;\n    float: left;\n  }\n</style>\