>\n                  <el-form-item label=\"订单名称:\" :prop=\"'ordersPOS.' + index + '.contractName'\">\n                    <el-col :span=\"12\">\n<!--                      <el-input v-model=\"item.contractName\" :disabled=\"page==='update'\" maxlength=\"255\"></el-input>-->\n                      <el-input v-model=\"item.contractName\" maxlength=\"255\" />\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"销售负责人:\" :prop=\"'ordersPOS.' + index + '.userName'\">\n                    <el-col :span=\"12\">\n                      <el-autocomplete\n                        value-key=\"name\"\n                        v-model=\"item.userName\"\n                        clearable\n                        :fetch-suggestions=\"handleSelect1\"\n                        @select=\"getSelect1($event,index)\"\n                      >\n                        <template slot-scope=\"{ item }\">\n                          <div class=\"name\">{{ item.userName }}</div>\n                        </template>\n                      </el-autocomplete>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"签订日期:\" :prop=\"'ordersPOS.' + index + '.signedDate'\">\n                    <el-col :span=\"12\">\n                      <el-date-picker class=\"dateInput\"  v-model=\"item.signedDate\" type=\"date\" value-format=\"yyyy-MM-dd\" :editable=\"false\" style=\"width:200px;\">\n                      </el-date-picker>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"订单金额（含税）:\" :prop=\"'ordersPOS.' + index + '.contractValue'\">\n                    <el-col :span=\"12\">\n                      <el-input v-model=\"item.contractValue\" oninput=\"if(isNaN(value)) { value = null } {value=value.replace(/[^0-9999999.]/g,'')} if(value.indexOf('.')>0){value=value.slice(0,value.indexOf('.')+3)}\"\n maxlength=\"255\"></el-input>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"订单金额（不含税）:\" :prop=\"'ordersPOS.' + index + '.notCTaxValue'\">\n                    <el-col :span=\"12\">\n                      <el-input v-model=\"item.notCTaxValue\" oninput=\"if(isNaN(value)) { value = null } {value=value.replace(/[^0-9999999.]/g,'')} if(value.indexOf('.')>0){value=value.slice(0,value.indexOf('.')+3)}\"\n maxlength=\"255\"></el-input>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"是否签字:\" :prop=\"'ordersPOS.' + index + '.isSign'\">\n                    <el-col :span=\"12\">\n                      <el-select v-model=\"item.isSign\" placeholder=\"请选择\">\n                        <el-option label=\"是\" value=\"0\"></el-option>\n                        <el-option label=\"否\" value=\"1\"></el-option>\n                      </el-select>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"是否盖章:\" :prop=\"'ordersPOS.' + index + '.isStamp'\">\n                    <el-col :span=\"12\">\n                      <el-select v-model=\"item.isStamp\" placeholder=\"请选择\">\n                        <el-option label=\"是\" value=\"0\"></el-option>\n                        <el-option label=\"否\" value=\"1\"></el-option>\n                      </el-select>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"类型:\" :prop=\"'ordersPOS.' + index + '.orderType'\">\n                    <el-col :span=\"12\">\n                      <el-select v-model=\"item.orderType\" placeholder=\"请选择\">\n                        <el-option label=\"订单\" value=\"0\"></el-option>\n                        <el-option label=\"结算单\" value=\"1\"></el-option>\n                      </el-select>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"订单材料\" :prop=\"'ordersPOS.' + index + '.orderMaterials'\">\n                    <el-col :span=\"24\">\n                      <el-button size=\"small\" type=\"primary\" @click=\"pictureList(item,index)\" class=\"upButton\">点击上传</el-button>\n<!--                      <span>只能上传'.jpg,.png,.JPG,.PNG'文件</span>-->\n                    </el-col>\n                  </el-form-item>\n<!--                  <el-form-item style=\"width:100%;text-align:right;\">-->\n<!--                    <el-col :span=\"12\" align=\"right\">-->\n<!--                      <el-button type=\"danger\" @click=\"deleteData(index)\">删除</el-button>-->\n<!--                    </el-col>-->\n<!--                  </el-form-item>-->\n                </fieldset>\n              </el-form-item>\n            </el-form>\n            <div style=\"margin-left: 40%\">\n              <el-button type=\"success\" @click=\"addData(index)\" v-if=\"page==='add'\" icon=\"el-icon-circle-plus\">增加订单</el-button>\n            </div>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"pictureListDialog\" :width=\"'700px'\" :height=\"'500px'\">\n      <template>\n        <pictureList @refreshDataList=\"refresh\" ref=\"pictureList\" @uploadFile=\"uploadFile\"></pictureList>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport baseDialog from '../../base/baseDialog.vue'\nimport pictureList from './picture.vue'\nexport default {\n  data() {\n    return {\n      page: 'add',\n      titles: '',\n      fileList: [],\n      badList: '',\n      checkboxList: [],\n      index: null,\n      dialogImageUrl: '',\n      dialogVisible: false,\n      dataForm: {\n        ordersPOS: [\n          {\n            contractNo: '', contractName: '', userName: '', salesManager: '',\n            signedDate: '', contractValue: '', notCTaxValue: '',\n            isSign: '', isStamp: '', orderType: '', orderMaterials: undefined\n          }\n        ]\n      }\n    }\n  },\n  components: {\n    baseDialog, pictureList\n  },\n  props: {\n    getChildValue: {\n      type: '',\n      default: ''\n    }\n  },\n  mounted() {\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    resetForm() {\n      Object.assign(this.$data, this.$options.data())\n    },\n    init(Object, item) {\n      let list = Object.item\n      this.page = item\n      if (list.userName !== undefined && list.userName !== '') {\n        this.dataForm.ordersPOS[0].userName = list.userName\n      } else {\n        this.dataForm.ordersPOS[0].userName = ''\n      }\n      if (list.orderNo !== undefined && list.orderNo !== '') {\n        this.dataForm.ordersPOS[0].contractNo = list.orderNo\n      } else {\n        this.dataForm.ordersPOS[0].contractNo = ''\n      }\n      if (list.orderName !== undefined && list.orderName !== '') {\n        this.dataForm.ordersPOS[0].contractName = list.orderName\n      } else {\n        this.dataForm.ordersPOS[0].contractName = ''\n      }\n      if (list.salesperson !== undefined && list.salesperson !== '') {\n        this.dataForm.ordersPOS[0].salesManager = list.salesperson\n      } else {\n        this.dataForm.ordersPOS[0].salesManager = ''\n      }\n      if (list.signedDate !== undefined && list.signedDate !== '') {\n        this.dataForm.ordersPOS[0].signedDate = list.signedDate\n      } else {\n        this.dataForm.ordersPOS[0].signedDate = ''\n      }\n      if (list.contractvalue !== undefined && list.contractvalue !== '') {\n        this.dataForm.ordersPOS[0].contractValue = list.contractvalue\n      } else {\n        this.dataForm.ordersPOS[0].contractValue = ''\n      }\n      if (list.notctaxvalue !== undefined && list.notctaxvalue !== '') {\n        this.dataForm.ordersPOS[0].notCTaxValue = list.notctaxvalue\n      } else {\n        this.dataForm.ordersPOS[0].notCTaxValue = ''\n      }\n      if (list.isSign !== undefined && list.isSign !== '') {\n        this.dataForm.ordersPOS[0].isSign = list.isSign\n      } else {\n        this.dataForm.ordersPOS[0].isSign = ''\n      }\n      if (list.isStamp !== undefined && list.isStamp !== '') {\n        this.dataForm.ordersPOS[0].isStamp = list.isStamp\n      } else {\n        this.dataForm.ordersPOS[0].isStamp = ''\n      }\n      if (list.orderType !== undefined && list.orderType !== '') {\n        this.dataForm.ordersPOS[0].orderType = list.orderType\n      } else {\n        this.dataForm.ordersPOS[0].orderType = ''\n      }\n      if (list.orderMaterials !== undefined && list.orderMaterials !== '') {\n        this.dataForm.ordersPOS[0].orderMaterials = list.orderMaterials\n      } else {\n        this.dataForm.ordersPOS[0].orderMaterials = ''\n      }\n      if (list.userName !== undefined && list.userName !== '') {\n        this.dataForm.ordersPOS[0].userName = list.userName\n      } else {\n        this.dataForm.ordersPOS[0].userName = ''\n      }\n    },\n    handleSelect(queryString, cb) {\n      if (this.badList !== '' && this.badList !== undefined) {\n        this.$http({\n          url: this.$http.adornUrl('/orderImport/order'),\n          method: 'get',\n          params: this.$http.adornParams({ 'OrderNo': queryString ? queryString : '','ContractNo': this.badList})\n        }).then(({ data }) => {\n          if (data && data.code === 200) {\n            cb(data.payload)\n          } else {\n            cb([])\n          }\n        })\n      } else {\n        this.$message.warning('请填写合同编号')\n      }\n    },\n    getSelect(item, index) {\n      if (item.contractNo === '') {\n        this.dataForm.ordersPOS[index].contractNo = ''\n        this.dataForm.ordersPOS[index].contractName = ''\n      } else {\n        this.dataForm.ordersPOS[index].contractNo = item.contractNo\n        this.dataForm.ordersPOS[index].contractName = item.contractName\n        this.dataForm.ordersPOS[index].userName = item.userName\n        this.dataForm.ordersPOS[index].salesManager = item.salesperson\n        this.dataForm.ordersPOS[index].signedDate = item.signedDate\n        this.dataForm.ordersPOS[index].contractValue = item.contractValue\n        this.dataForm.ordersPOS[index].notCTaxValue = item.notCTaxValue\n      }\n    },\n    handleSelect1(queryString, cb) {\n      this.$http({\n        url: this.$http.adornUrl('/orderImport/salesperson'),\n        method: 'get',\n        params: this.$http.adornParams({ 'SalesManager': queryString ? queryString : '' })\n      }).then(({ data }) => {\n        if (data.success) {\n          cb(data.payload)\n        } else {\n          cb([])\n        }\n      })\n    },\n    getSelect1(item, index) {\n      if (item.userName === '') {\n        this.dataForm.ordersPOS[index].userName = ''\n      } else {\n        this.dataForm.ordersPOS[index].userName = item.userName\n        this.dataForm.ordersPOS[index].salesManager = item.userId\n      }\n    },\n    pictureList(item, index) {\n      this.index = index\n      this.titles = '上传图片'\n      this.$refs.pictureListDialog.show()\n      if (this.dataForm.ordersPOS[index].orderMaterials) {\n        this.$nextTick(() => {\n          this.$refs.pictureList.init(this.dataForm.ordersPOS[index].orderMaterials, index)\n        })\n      }\n    },\n    passFath() {\n      return this.dataForm.ordersPOS\n    },\n    uploadFile(file) {\n      this.dataForm.ordersPOS[this.index].orderMaterials = file\n    },\n    // 删除行数据\n    deleteData(index) {\n      if (this.dataForm.ordersPOS.length <= 1) {\n        this.$message.error('订单数量已达最低值！')\n        return\n      }\n      this.$confirm(`确认要删除当前内容吗？`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.dataForm.ordersPOS.splice(index, 1)\n      })\n    },\n    handle() {\n      this.badList = this.$parent._props.model.ContractNo\n    },\n    // 添加行数据\n    addData(index) {\n      this.dataForm