{"remainingRequest":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js!/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js??ref--0-0!/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/iot-ui/src/views/modules/authorityManagement/downloadRecord/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/iot-ui/src/views/modules/authorityManagement/downloadRecord/index.vue","mtime":1694618820697},{"path":"/Users/mac/Documents/code/iot/iot-ui/babel.config.js","mtime":1694618820647},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/iot-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["baseTable","data","dataForm","applicationAccount","approvalStatus","tableData","theads","label","prop","slotName","width","url","components","mounted","$refs","table","refresh","methods","notice","$message","error","_this","validate","valid","batchPass","row","_this2","list","getSelectRow","applicationIds","item","applicationid","$http","adornUrl","method","then","_ref","code","message","type","msg","ids","map","push","length","datas","join","_ref2","choice","_this3","_ref3","resetForm","resetFields"],"sources":["src/views/modules/authorityManagement/downloadRecord/index.vue"],"sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container style=\"height: 100%; border: 1px solid #eee\">\n      <el-header style=\"height: auto;\">\n        <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n          <div class=\"inputlist\" style=\"background: #ecf5ff;\">\n            <el-form-item label=\"申请账号:\" prop=\"applicationAccount\" style=\"margin-left: 20%\">\n              <el-input v-model=\"dataForm.applicationAccount\" placeholder=\"请输入账号\" clearable></el-input>\n            </el-form-item>\n            <el-form-item label=\"审批状态:\" prop=\"approvalStatus\">\n              <el-select v-model=\"dataForm.approvalStatus\" placeholder=\"请选择\">\n                <el-option label=\"全部\" value=\"\"></el-option>\n                <el-option label=\"未审批\" value=\"0\"></el-option>\n                <el-option label=\"审批通过\" value=\"1\"></el-option>\n                <el-option label=\"审批不通过\" value=\"2\"></el-option>\n              </el-select>\n            </el-form-item>\n            <div>\n              <el-button type=\"primary\" @click=\"refresh()\" icon=\"el-icon-search\"style=\"margin-right: 30px\">查询</el-button>\n              <el-button type=\"primary\" @click=\"resetForm()\" icon=\"el-icon-search\">重置</el-button>\n            </div>\n          </div>\n        </el-form>\n      </el-header>\n      <div style=\"background: rgb(236, 245, 255);\">\n        <el-button type=\"primary\" @click=\"batchPass()\" style=\"width: 80px;height: 30px;margin-bottom: 2px;margin-left: 2px\">批量通过</el-button>\n      </div>\n      <baseTable :tableData=\"tableData\" ref=\"table\" :multiSelect=\"true\">\n        <template v-slot:approvalStatus=\"row\">\n          <template v-if=\"row.item.approvalStatus == 0\">\n            <el-tag type=\"success\">待审批中</el-tag>\n          </template>\n          <template v-if=\"row.item.approvalStatus == 1\">\n            <el-tag type=\"primary\">审批通过</el-tag>\n          </template>\n          <template v-if=\"row.item.approvalStatus == 2\">\n            <el-tag type=\"danger\">审批驳回</el-tag>\n          </template>\n        </template>\n        <template v-slot:clientType1=\"row\">\n          <!--类型插槽-->\n          <template v-if=\"row.item.approvalStatus == 0\">\n            <el-tag type=\"primary\" @click=\"batchPass(row)\" style=\"margin-right:15px;\">通过</el-tag>\n            <el-tag type=\"primary\" @click=\"choice(row)\">不通过</el-tag>\n          </template>\n          <template v-if=\"row.item.approvalStatus == 1 || row.item.approvalStatus == 2\">\n            <el-tag type=\"info\" @click=\"notice()\" style=\"margin-right:15px;\">通过</el-tag>\n            <el-tag type=\"info\" @click=\"notice()\" >不通过</el-tag>\n          </template>\n        </template>\n      </baseTable>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseTable from '../../base/baseTable.vue'\nexport default {\n  data() {\n    return {\n      dataForm: {\n        applicationAccount: '',\n        approvalStatus: ''\n      },\n      tableData: {\n        theads: [\n          { label: '申请账号', prop: 'applicationAccount' },\n          { label: '申请人手机号', prop: 'phone' },\n          { label: '申请人邮箱', prop: 'email' },\n          { label: '申请时间', prop: 'applicationTime' },\n          { label: '下载内容', prop: 'downloadContent' },\n          { label: '申请理由', prop: 'applicationReason' },\n          { label: '合同编号', prop: 'contractNumber' },\n          { label: '审核状态', prop: 'approvalStatus', slotName: 'approvalStatus' },\n          { label: '操作', prop: 'modifyTime', slotName: 'clientType1', width: 90 }\n        ],\n        // dataList: []\n        url: '/approve/approveList'\n      }\n    }\n  },\n  components: {\n    baseTable\n  },\n  mounted() {\n    this.$refs.table.refresh(this.dataForm)\n  },\n  methods: {\n    notice(){\n      this.$message.error('当前记录已审批，无需重复操作');\n    },\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    batchPass(row) {\n      let list = this.$refs.table.getSelectRow()\n      if (row) {\n        var data = {\n          applicationIds: row.item.applicationid,\n          approvalStatus: 1\n        }\n        this.$http({\n          url: this.$http.adornUrl('/approve/approve'),\n          method: 'post',\n          data: data\n        }).then(({ data }) => {\n          if (data && data.code === 200) {\n            this.$message({\n              message: '该用户审核已通过',\n              type: 'success'\n            })\n            //this.$parent.hide()\n            this.refresh();\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      } else {\n        var ids = []\n        list.map((item)=>{\n          if(item.approvalStatus=='0')\n            ids.push(item.applicationid)\n        })\n        if(ids.length<=0)\n          this.$message.error(\"不包含未审批数据，请重新选择\");\n        else{\n          var datas = {\n            applicationIds: ids.join(),\n            approvalStatus: 1\n          }\n          this.$http({\n            url: this.$http.adornUrl('/approve/approve'),\n            method: 'post',\n            data: datas\n          }).then(({ data }) => {\n            if (data && data.code === 200) {\n              this.$message({\n                message: '该用户审核已通过',\n                type: 'success'\n              })\n              //this.$parent.hide()\n              this.refresh();\n            } else {\n              this.$message.error(data.msg)\n            }\n          })\n        }\n      }\n    },\n    choice(row) {\n      var data = {\n        applicationIds: row.item.applicationid,\n        approvalStatus: 2\n      }\n      this.$http({\n        url: this.$http.adornUrl('/approve/approve'),\n        method: 'post',\n        data: data\n      }).then(({ data }) => {\n        if (data && data.code === 200) {\n          this.$message({\n            message: '该用户审核已不通过',\n            type: 'success'\n          })\n          //this.$parent.hide()\n          this.refresh();\n        } else {\n          this.$message.error(data.msg)\n        }\n      })\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    }\n  }\n}\n</script>\n<style scoped>\n  .el-header {\n    color: #333;\n    padding: 0 0;\n  }\n  .el-form--inline>.inputlist{\n    padding-top: 20px;\n    padding-left: 20px;\n    display: flex;\n  }\n  .el-form--inline>.inputlist>.el-form-item{\n    width: 25%;\n    margin-bottom: 20px;\n  }\n  .el-form-item__content{\n    width: 200px;\n  }\n  .el-button{\n    width: 90px;\n    height: 40px;\n  }\n</style>\n<style>\n  ::-webkit-scrollbar { /*滚动条整体样式*/\n    width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n    height: 8px;\n  }\n  ::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n    border-radius: 10px;\n    -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n    background: #e1f1f1;\n  }\n  ::-webkit-scrollbar-track { /*滚动条里面轨道*/\n    -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n    border-radius: 10px;\n    background: #fff;\n  }\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAuDA,OAAAA,SAAA;AACA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA;QACAC,kBAAA;QACAC,cAAA;MACA;MACAC,SAAA;QACAC,MAAA,GACA;UAAAC,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;UAAAC,QAAA;QAAA,GACA;UAAAF,KAAA;UAAAC,IAAA;UAAAC,QAAA;UAAAC,KAAA;QAAA,EACA;QACA;QACAC,GAAA;MACA;IACA;EACA;EACAC,UAAA;IACAZ,SAAA,EAAAA;EACA;EACAa,OAAA,WAAAA,QAAA;IACA,KAAAC,KAAA,CAAAC,KAAA,CAAAC,OAAA,MAAAd,QAAA;EACA;EACAe,OAAA;IACAC,MAAA,WAAAA,OAAA;MACA,KAAAC,QAAA,CAAAC,KAAA;IACA;IACAJ,OAAA,WAAAA,QAAA;MAAA,IAAAK,KAAA;MACA,KAAAP,KAAA,CAAAZ,QAAA,CAAAoB,QAAA,WAAAC,KAAA;QACA,KAAAA,KAAA;UACA;QACA;QACAF,KAAA,CAAAP,KAAA,CAAAC,KAAA,CAAAC,OAAA,CAAAK,KAAA,CAAAnB,QAAA;MACA;IACA;IACAsB,SAAA,WAAAA,UAAAC,GAAA;MAAA,IAAAC,MAAA;MACA,IAAAC,IAAA,QAAAb,KAAA,CAAAC,KAAA,CAAAa,YAAA;MACA,IAAAH,GAAA;QACA,IAAAxB,IAAA;UACA4B,cAAA,EAAAJ,GAAA,CAAAK,IAAA,CAAAC,aAAA;UACA3B,cAAA;QACA;QACA,KAAA4B,KAAA;UACArB,GAAA,OAAAqB,KAAA,CAAAC