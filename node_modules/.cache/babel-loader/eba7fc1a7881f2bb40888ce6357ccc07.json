()\"\n      >确定</el-button\n      >\n      <el-button type=\"danger\" @click=\"cancelBtn\">取消</el-button>\n    </div>\n  </div>\n</template>\n\n\n<script>\n\nexport default {\n  data() {\n    return {\n      isSubmit:false\n    }\n  },\n  props:{\n    value: {\n      type: Object,\n      default:()=>{}\n    },\n    labelList: {\n      type: Object,\n      default:()=>{}\n    },\n  },\n  components: {\n  },\n  methods: {\n    init(object){\n      this.value=object\n    },\n    btnSubmit(){\n      this.$emit('input',this.value)\n      this.isSubmit=true\n      this.$emit('submit')\n      this.$parent.hide()\n    },\n    cancelBtn(){\n      this.$emit('input',this.value)\n      this.isSubmit=false\n      this.$parent.hide()\n      return false;\n    },\n    getSubmitValue(){\n      return this.isSubmit;\n    }\n  }\n}\n</script>\n<style scoped>\n\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;AAwBA;EACAA,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA;IACA;EACA;EACAC,KAAA;IACAC,KAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA,WAAAC,SAAA;IACA;IACAC,SAAA;MACAJ,IAAA,EAAAC,MAAA;MACAC,OAAA,WAAAC,SAAA;IACA;EACA;EACAE,UAAA,GACA;EACAC,OAAA;IACAC,IAAA,WAAAA,KAAAC,MAAA;MACA,KAAAT,KAAA,GAAAS,MAAA;IACA;IACAC,SAAA,WAAAA,UAAA;MACA,KAAAC,KAAA,eAAAX,KAAA;MACA,KAAAF,QAAA;MACA,KAAAa,KAAA;MACA,KAAAC,OAAA,CAAAC,IAAA;IACA;IACAC,SAAA,WAAAA,UAAA;MACA,KAAAH,KAAA,eAAAX,KAAA;MACA,KAAAF,QAAA;MACA,KAAAc,OAAA,CAAAC,IAAA;MACA;IACA;IACAE,cAAA,WAAAA,eAAA;MACA,YAAAjB,QAAA;IACA;EACA;AACA"}]}