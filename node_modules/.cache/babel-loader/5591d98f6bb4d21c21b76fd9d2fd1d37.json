aseDialog>\n    <baseDialog :title=\"titles\" ref=\"batchAddDialog\" :width=\"'400px'\">\n      <template>\n        <batchAdd @refreshDataList=\"refresh\" ref=\"batchAdd\"></batchAdd>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport labelshow from './labelshow.vue'\nimport baseDialog from '../base/baseDialog.vue'\nimport addOrUpdate from './add.vue'\nimport batchAdd from './batchadd.vue'\nexport default {\n  data() {\n    return {\n      titles: '',\n      tagTypeList: [],\n      sortsList: [],\n      labelsList: [],\n      dataForm: {\n        keyword: '',\n        sortId: ''\n      }\n    }\n  },\n  components: {\n    labelshow,\n    baseDialog,\n    addOrUpdate,\n    batchAdd\n  },\n  props: {\n    dialogName: {\n      type: String\n    },\n    parentRefresh: {\n      type: Function\n    }\n    },\n  mounted() {\n    this.$http({\n      url: this.$http.adornUrl('/label/sorts'),\n      method: 'get'\n    }).then(({ data }) => {\n      this.tagTypeList = data.payload\n      this.tagTypeList.forEach((item) => {\n        this.sortsList.push({ id: item.id, name: item.name })\n      })\n    })\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$http({\n          url: this.$http.adornUrl('/label/labels'),\n          method: 'get',\n          params: this.$http.adornParams({ 'keyword': this.dataForm.keyword, 'sortId': this.dataForm.sortId })\n        }).then(({ data }) => {\n          console.log(data);\n          if (data && data.code === 200) {\n            this.labelsList = data.payload\n            this.$nextTick(() => {\n              this.$refs.labelshow.init(this.labelsList)\n            })\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    },\n    reftoo() {\n      this.refresh()\n    },\n    addTagType() {\n      this.titles = '添加标签'\n      this.$refs.addOrUpdateDialog.show()\n    },\n    batchAdd() {\n      this.titles = '批量添加'\n      this.$refs.batchAddDialog.show()\n    },\n    sortslist(value) {\n      this.dataForm.sorts = value\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    exportlist() {\n      this.$http.download(this.$http.adornUrl('/clbatch/deriveLabel'), this.$http.adornParams(this.dataForm), this)\n    }\n  }\n}\n</script>\n<style scoped>\n  .el-header {\n    color: #333;\n    padding: 0 0;\n  }\n  .el-form--inline>.inputlist{\n    padding-top: 20px;\n    padding-left: 20px;\n    display: flex;\n  }\n  .el-form--inline>.inputlist>.el-form-item{\n    width: 340px;\n    margin-bottom: 20px;\n  }\n  .el-form-item__content{\n    width: 200px;\n  }\n  .el-button{\n    width: 90px;\n    height: 40px;\n  }\n\n\n</style>\n<style>\n  ::-webkit-scrollbar { /*滚动条整体样式*/\n    width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n    height: 8px;\n  }\n  ::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n    border-radius: 10px;\n    -webkit-box-shadow: inset 0 0 0 rgba(0, 0, 0, 0.2);\n    background: #e1f1f1;\n  }\n  ::-webkit-scrollbar-track { /*滚动条里面轨道*/\n    -webkit-box-shadow: inset 0 0 0 rgba(0, 0, 0, 0.2);\n    border-radius: 10px;\n    background: #fff;\n  }\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAoDA,OAAAA,SAAA;AACA,OAAAC,UAAA;AACA,OAAAC,WAAA;AACA,OAAAC,QAAA;AACA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,MAAA;MACAC,WAAA;MACAC,SAAA;MACAC,UAAA;MACAC,QAAA;QACAC,OAAA;QACAC,MAAA;MACA;IACA;EACA;EACAC,UAAA;IACAZ,SAAA,EAAAA,SAAA;IACAC,UAAA,EAAAA,UAAA;IACAC,WAAA,EAAAA,WAAA;IACAC,QAAA,EAAAA;EACA;EACAU,KAAA;IACAC,UAAA;MACAC,IAAA,EAAAC;IACA;IACAC,aAAA;MACAF,IAAA,EAAAG;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IAAA,IAAAC,KAAA;IACA,KAAAC,KAAA;MACAC,GAAA,OAAAD,KAAA,CAAAE,QAAA;MACAC,MAAA;IACA,GAAAC,IAAA,WAAAC,IAAA;MAAA,IAAAtB,IAAA,GAAAsB,IAAA,CAAAtB,IAAA;MACAgB,KAAA,CAAAd,WAAA,GAAAF,IAAA,CAAAuB,OAAA;MACAP,KAAA,CAAAd,WAAA,CAAAsB,OAAA,WAAAC,IAAA;QACAT,KAAA,CAAAb,SAAA,CAAAuB,IAAA;UAAAC,EAAA,EAAAF,IAAA,CAAAE,EAAA;UAAAC,IAAA,EA