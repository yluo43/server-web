    <baseUpload\n              name=\"uploadFile\"\n              ref=\"uploadFile\"\n              :accept=\"'.xls,.xlsx'\"\n              :file-list=\"uploadFile\"\n              :hideAllBtn=\"true\"\n            ></baseUpload>\n          </el-form-item>\n<!--          <el-form-item label=\"下载模板\" prop=\"bookThreshold\">-->\n<!--            <el-button type=\"primary\" @click=\"download\">下载文件</el-button>-->\n<!--          </el-form-item>-->\n          <div style=\"margin-top:20px;text-align:center;\">\n            <el-form-item>\n              <el-button type=\"success\" @click=\"addOrUpdateHandle()\">提交</el-button>\n              <el-button type=\"danger\" @click=\"cancelDialog()\">取消</el-button>\n            </el-form-item>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseDialog from '../base/baseDialog.vue'\nimport baseUpload from '../base/baseUpload.vue'\nexport default {\n  data() {\n    return {\n      textarea: '',\n      status: '',\n      titles: '',\n      uploadFile: [],\n      dataForm: {\n      }\n    }\n  },\n  components: { baseDialog, baseUpload },\n  methods: {\n    init() {\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    buildFormData(dom) {\n      let formData = new FormData(dom)\n      for (let i = 0; i < dom.length; i++) {\n        let element = dom[i]\n        if (element['type'] === 'uploadFile' && element.files.length === 0) {\n          formData.delete(element.name)\n        }\n      }\n      return formData\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let formData = this.buildFormData(this.$refs.dataForm.$el)\n      this.$refs.dataForm.validate((valid) => {\n        this.$http({\n          url: this.$http.adornUrl('/label/upload'),\n          method: 'post',\n          data: formData\n        }).then(({ data }) => {\n          if (data.success) {\n            this.$message({\n              dangerouslyUseHTMLString: true,\n              message: '上传成功，总计：'+data.payload.total +'个，成功：'+data.payload.success+ '个，跳过：'+data.payload.fail+'个，<br/><br/>'+'系统已存在如下标签：'+data.payload.skip,\n              type: 'success'\n            })\n            this.$parent.hide()\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    },\n    download() {\n      this.$http.download(this.$http.adornUrl('/label/download'))\n      //window.location.href = 'http://10.1.32.44:8081/label/download'\n    },\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n<style scoped>\n  /*::v-deep .el-form-item{*/\n  /*  width: 100%;*/\n  /*}*/\n  ::v-deep .el-form{\n    width: 100%;\n  }\n\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AA8BA,OAAAA,UAAA;AACA,OAAAC,UAAA;AACA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA;MACAC,MAAA;MACAC,MAAA;MACAC,UAAA;MACAC,QAAA,GACA;IACA;EACA;EACAC,UAAA;IAAAR,UAAA,EAAAA,UAAA;IAAAC,UAAA,EAAAA;EAAA;EACAQ,OAAA;IACAC,IAAA,WAAAA,KAAA,GACA;IACAC,SAAA,WAAAA,UAAA;MACA,KAAAC,KAAA,CAAAL,QAAA,CAAAM,WAAA;IACA;IACAC,aAAA,WAAAA,cAAAC,GAAA;MACA,IAAAC,QAAA,OAAAC,QAAA,CAAAF,GAAA;MACA,SAAAG,CAAA,MAAAA,CAAA,GAAAH,GAAA,CAAAI,MAAA,EAAAD,CAAA;QACA,IAAAE,OAAA,GAAAL,GAAA,CAAAG,CAAA;QACA,IAAAE,OAAA,6BAAAA,OAAA,CAAAC,KAAA,CAAAF,MAAA;UACAH,QAAA,CAAAM,MAAA,CAAAF,OAAA,CAAAG,IAAA;QACA;MACA;MACA,OAAAP,QAAA;IACA;IACA;IACAQ,iBAAA,WAAAA,kBAAA;MAAA,IAAAC,KAAA;MACA,IAAAT,QAAA,QAAAF,aAAA,MAAAF,KAAA,CAAAL,QAAA,CAAAmB,GAAA;MACA,KAAAd,KAAA,CAAAL,QAAA,CAAAoB,QAAA,WAAAC,KAAA;QACAH,KAAA,CAAAI,KAAA;UACAC,GAAA,EAAAL,KAAA,CAAAI,KAAA,CAAAE,QAAA;UACAC,MAAA;UACA9B,IAAA,EAAAc;QACA,GAAAiB,IAAA,WAAAC,IAAA;UAAA,IAAAhC,IAAA,GAAAgC,IAAA,CAAAhC,IAAA;UACA,IAAAA,IAAA,CAAAiC,OAAA;YACAV,KAAA,CAAAW,QAAA;cACAC,wBAAA;cACAC,OAAA,eAAApC,IAAA,CAAAqC,OAAA,CAAAC,KAAA,aAAAtC,IAAA,CAAAqC,OAAA,CAAAJ,OAAA,aAAAjC,IAAA,CAAAqC,OAAA,CAAAE,IAAA,mCAAAvC,IAAA,CAAAqC,OAAA,CAAAG,IAAA;cACAC,IAAA;YACA;YACAlB,KAAA,CAAAmB,OAAA,CAAAC,IAAA;UACA;YACApB,KAAA,CAAAW,QAAA,CAAAU,KAAA,CAAA5C,IAAA,CAAA6C,GAAA;UAC