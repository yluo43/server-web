var date = new Date();\n        var time = date.getFullYear() + '-' + (date.getMonth() + 1) + '-' + date.getDate() + ' ' + date.getHours() + ':' + date.getMinutes() + ':' + date.getSeconds();\n        this.newTime = time;\n      },\n      //根据自己的需求，看要不要在时间不大于10的时候在前面补0，如果需要直接this.addZero(date.getMinutes()),其它与之相同，如果不需要删掉addZero（）方法即可。\n      //小于10的拼接上0字符串\n      addZero(s) {\n        return s < 10 ? ('0' + s) : s;\n      },\n\n    }\n  }\n</script>\n"],"mappings":";;;;;;;;;;AAWA;EACAA,IAAA,WAAAA,KAAA;IACA;MACAC,OAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA;IAAA,IAAAC,KAAA;IACA,KAAAC,UAAA;IACAC,aAAA,CAAAC,aAAA;IACA,IAAAA,aAAA,GAAAC,WAAA;MACAJ,KAAA,CAAAC,UAAA;IACA;EACA;EACAI,OAAA;IACAJ,UAAA,WAAAA,WAAA;MACA,IAAAK,IAAA,OAAAC,IAAA;MACA,IAAAC,IAAA,GAAAF,IAAA,CAAAG,WAAA,YAAAH,IAAA,CAAAI,QAAA,gBAAAJ,IAAA,CAAAK,OAAA,WAAAL,IAAA,CAAAM,QAAA,WAAAN,IAAA,CAAAO,UAAA,WAAAP,IAAA,CAAAQ,UAAA;MACA,KAAAhB,OAAA,GAAAU,IAAA;IACA;IACA;IACA;IACAO,OAAA,WAAAA,QAAAC,CAAA;MACA,OAAAA,CAAA,cAAAA,CAAA,GAAAA,CAAA;IACA;EAEA;AACA"}]}