\" prop=\"status\">\n            <baseUpload\n              name=\"uploadFile\"\n              ref=\"uploadFile\"\n              :accept=\"'.zip'\"\n              :file-list=\"uploadFile\"\n              :hideAllBtn=\"true\"\n            ></baseUpload>\n          </el-form-item>\n          <div style=\"margin-top:20px;text-align:center;\">\n            <el-form-item>\n              <el-button type=\"success\" @click=\"addOrUpdateHandle()\">提交</el-button>\n              <el-button type=\"danger\" @click=\"cancelDialog()\">取消</el-button>\n            </el-form-item>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n  </div>\n</template>\n<script>\nimport baseDialog from '../../base/baseDialog.vue'\nimport baseUpload from '../../base/baseUpload.vue'\nexport default {\n  data() {\n    return {\n      textarea: '',\n      status: '',\n      titles: '',\n      uploadFile: [],\n      dataForm: {\n      }\n    }\n  },\n  components: { baseDialog, baseUpload },\n  methods: {\n    init() {\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    },\n    buildFormData(dom) {\n      let formData = new FormData(dom)\n      for (let i = 0; i < dom.length; i++) {\n        let element = dom[i]\n        if (element['type'] === 'uploadFile' && element.files.length === 0) {\n          formData.delete(element.name)\n        }\n      }\n      return formData\n    },\n    // 新增\n    addOrUpdateHandle() {\n      let loading = this.$loading({\n        lock: true, // lock的修改符--默认是false\n        text: '拼命上传中，请稍候...', // 显示在加载图标下方的加载文案\n        background: 'rgba(0,0,0,0.8)', // 遮罩层颜色\n        spinner: 'el-icon-loading' // 自定义加载图标类名\n      })\n      let formData = this.buildFormData(this.$refs.dataForm.$el)\n      this.$refs.dataForm.validate((valid) => {\n        this.$http({\n          url: this.$http.adornUrl('/orderImport/insertBatchOrder'),\n          method: 'post',\n          data: formData\n        }).then(({ data }) => {\n          if (data.success) {\n            loading.close()\n            this.$message({\n              message: '上传成功',\n              type: 'success'\n            })\n            this.$parent.hide()\n          } else {\n            loading.close()\n            this.$message.error(data.msg)\n          }\n        })\n      })\n    },\n\n    // 取消\n    cancelDialog() {\n      this.$parent.hide()\n    }\n  }\n}\n</script>\n<style scoped>\n  /*::v-deep .el-form-item{*/\n  /*  width: 100%;*/\n  /*}*/\n  ::v-deep .el-form{\n    width: 100%;\n  }\n\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;AA2BA,OAAAA,UAAA;AACA,OAAAC,UAAA;AACA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,QAAA;MACAC,MAAA;MACAC,MAAA;MACAC,UAAA;MACAC,QAAA,GACA;IACA;EACA;EACAC,UAAA;IAAAR,UAAA,EAAAA,UAAA;IAAAC,UAAA,EAAAA;EAAA;EACAQ,OAAA;IACAC,IAAA,WAAAA,KAAA,GACA;IACAC,SAAA,WAAAA,UAAA;MACA,KAAAC,KAAA,CAAAL,QAAA,CAAAM,WAAA;IACA;IACAC,aAAA,WAAAA,cAAAC,GAAA;MACA,IAAAC,QAAA,OAAAC,QAAA,CAAAF,GAAA;MACA,SAAAG,CAAA,MAAAA,CAAA,GAAAH,GAAA,CAAAI,MAAA,EAAAD,CAAA;QACA,IAAAE,OAAA,GAAAL,GAAA,CAAAG,CAAA;QACA,IAAAE,OAAA,6BAAAA,OAAA,CAAAC,KAAA,CAAAF,MAAA;UACAH,QAAA,CAAAM,MAAA,CAAAF,OAAA,CAAAG,IAAA;QACA;MACA;MACA,OAAAP,QAAA;IACA;IACA;IACAQ,iBAAA,WAAAA,kBAAA;MAAA,IAAAC,KAAA;MACA,IAAAC,OAAA,QAAAC,QAAA;QACAC,IAAA;QAAA;QACAC,IAAA;QAAA;QACAC,UAAA;QAAA;QACAC,OAAA;MACA;;MACA,IAAAf,QAAA,QAAAF,aAAA,MAAAF,KAAA,CAAAL,QAAA,CAAAyB,GAAA;MACA,KAAApB,KAAA,CAAAL,QAAA,CAAA0B,QAAA,WAAAC,KAAA;QACAT,KAAA,CAAAU,KAAA;UACAC,GAAA,EAAAX,KAAA,CAAAU,KAAA,CAAAE,QAAA;UACAC,MAAA;UACApC,IAAA,EAAAc;QACA,GAAAuB,IAAA,WAAAC,IAAA;UAAA,IAAAtC,IAAA,GAAAsC,IAAA,CAAAtC,IAAA;UACA,IAAAA,IAAA,CAAAuC,OAAA;YACAf,OAAA,CAAAgB,KAAA;YACAjB,KAAA,CAAAkB,QAAA;cACAC,OAAA;cACAC,IAAA;YACA;YACApB,KAAA,CAAAqB,OAAA,CAAAC,IAAA;UACA;YACArB,OAAA,CAAAgB,KAAA;YACAjB,KAAA,CAAAkB,QAAA,CAAAK,KAAA,CAAA9C,IAAA,CAAA+C,GAAA;UACA;QACA;MACA;IACA;IAEA;IACAC,YAAA,WAAAA,aAAA;MACA,KAAAJ,OAAA,CAAAC,IAAA;IACA;EACA;AACA"}]}