{"remainingRequest":"/Users/mac/Documents/code/iot/pms-ui/node_modules/babel-loader/lib/index.js!/Users/mac/Documents/code/iot/pms-ui/node_modules/cache-loader/dist/cjs.js??ref--0-0!/Users/mac/Documents/code/iot/pms-ui/node_modules/vue-loader/lib/index.js??vue-loader-options!/Users/mac/Documents/code/iot/pms-ui/src/views/modules/resourceManagement/itemsManagement/index.vue?vue&type=script&lang=js&","dependencies":[{"path":"/Users/mac/Documents/code/iot/pms-ui/src/views/modules/resourceManagement/itemsManagement/index.vue","mtime":1704351505449},{"path":"/Users/mac/Documents/code/iot/pms-ui/babel.config.js","mtime":1694618820647},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/babel-loader/lib/index.js","mtime":456789000000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/cache-loader/dist/cjs.js","mtime":499162500000},{"path":"/Users/mac/Documents/code/iot/pms-ui/node_modules/vue-loader/lib/index.js","mtime":499162500000}],"contextDependencies":[],"result":[{"type":"Buffer","data":"base64:"},{"version":3,"names":["baseTable","baseDialog","addOrUpdate","data","titles","dataForm","name","deptList","tableData","theads","label","prop","slotName","url","components","mounted","_this","$refs","table","refresh","$http","adornUrl","method","then","_ref","code","payload","list","$message","error","msg","methods","changeDept","row","forEach","dept","id","item","deptId","deptName","_this2","validate","valid","addOrAlter","_this3","addOrUpdateDialog","show","$nextTick","init","managerList","alter","_this4","deleteList","_this5","$confirm","confirmButtonText","cancelButtonText","type","_ref2","message","location","reload","catch","resetForm","resetFields"],"sources":["src/views/modules/resourceManagement/itemsManagement/index.vue"],"sourcesContent":["<template>\n  <div style=\"height: 100%;\">\n    <el-container >\n      <el-header >\n        <el-form :inline=\"true\" :model=\"dataForm\" ref=\"dataForm\">\n          <div class=\"inputlist\" >\n            <el-form-item label=\"部门名称:\" prop=\"account\">\n              <el-input v-model=\"dataForm.name\" placeholder=\"请输入部门名称\" clearable></el-input>\n            </el-form-item>\n<!--            <el-form-item label=\"部门负责人:\" prop=\"phone\">-->\n<!--              <el-input v-model=\"dataForm.managerName\" placeholder=\"请输入部门负责人\" clearable></el-input>-->\n<!--            </el-form-item>-->\n\n\n\n            <div style=\"display: contents;\">\n              <el-button type=\"primary\" @click=\"refresh()\" icon=\"el-icon-search\" style=\"margin-right: 20px\">查询\n              </el-button>\n              <el-button type=\"primary\" @click=\"resetForm()\" icon=\"el-icon-search\">重置</el-button>\n            </div>\n          </div>\n        </el-form>\n      </el-header>\n      <div style=\"padding:20px 0 10px 2px;\">\n        <el-button class=\"el-button-func\" type=\"primary\" @click=\"addOrAlter()\" style=\"width: 125px\">添加项目（事由）</el-button>\n      </div>\n      <baseTable :tableData=\"tableData\" ref=\"table\" :multiSelect=\"true\" >\n        <template v-slot:clientType=\"row\">\n          <!--类型插槽-->\n          <template>\n            <svg-icon :icon-class=\"'delete'\" style=\"height:1.5em;width:1.5em; margin-right: 2em;\"\n                      @click=\"deleteList(row)\"/>\n            <svg-icon :icon-class=\"'amend'\" style=\"height:1.5em;width:1.5em;\" @click=\"alter(row)\"/>\n          </template>\n        </template>\n\n        <template v-slot:deptId=\"row\">\n          <template >\n            {{changeDept(row)}}\n          </template>\n        </template>\n\n\n      </baseTable>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"addOrUpdateDialog\" :width=\"'450px'\" :height=\"'600px'\">\n      <template>\n        <addOrUpdate @refreshDataList=\"refresh\" ref=\"addOrUpdate\"></addOrUpdate>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport baseTable from '../../base/baseTable.vue'\nimport baseDialog from '../../base/baseDialog'\nimport addOrUpdate from './addOrUpdata.vue'\n\nexport default {\n  data() {\n    return {\n      titles: '',\n      dataForm: {\n        name: '',\n      },\n      deptList:[],\n\n      tableData: {\n        theads: [\n          // {label: 'ID', prop: 'id',width:'100px'},\n          {label: '项目名称', prop: 'name'},\n          {label: '所属部门', prop: 'deptId',slotName:'deptId'},\n          {label: '团队(暂无)', prop: 'teamId'},\n          {label: '创建时间', prop: 'createTime'},\n          {label: '更新时间', prop: 'updateTime'},\n          {label: '创建人', prop: 'createUser'},\n          {label: '更新人', prop: 'updateUser'},\n          {label: '操作', prop: 'clientType',slotName: 'clientType'}\n        ],\n        url: '/costItems/list'\n      }\n    }\n  },\n  components: {\n    baseTable, baseDialog, addOrUpdate\n  },\n  mounted() {\n    this.$refs.table.refresh(this.dataForm)\n    //初始化deptList\n    this.$http({\n      url: this.$http.adornUrl('/deptInfo/listAll'),\n      method: 'get'\n    }).then(({data}) => {\n      if (data && data.code === 200) {\n        this.deptList = data.payload.list\n      } else {\n        this.$message.error(data.msg)\n      }\n    })\n  },\n  methods: {\n    changeDept(row){\n      let name\n      this.deptList.forEach(dept =>{\n        if(dept.id === row.item.deptId){\n          name =  dept.deptName\n        }\n      })\n\n      return name;\n    },\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    addOrAlter() {\n      this.titles = '添加项目（事由）'\n      this.$refs.addOrUpdateDialog.show()\n      this.$nextTick(() => {\n        this.$refs.addOrUpdate.init('add', false,this.managerList)\n      })\n    },\n    alter(row) {\n      this.titles = '修改项目（事由）'\n      this.$refs.addOrUpdateDialog.show()\n      this.$nextTick(() => {\n        this.$refs.addOrUpdate.init(row.item, true,this.managerList)\n      })\n    },\n    deleteList(row) {\n      let id = ''\n      id = row.item.id\n\n      this.$confirm(`您确定删除吗?`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.$http({\n          url: this.$http.adornUrl('/costItems/delete?id='+id),\n          method: 'post',\n        }).then(({data}) => {\n          if (data && data.code === 200) {\n            this.$message({\n              message: '删除成功',\n              type: 'success'\n            })\n            location.reload()\n          } else {\n            this.$message.error(data.msg)\n          }\n        })\n      }).catch(() => {\n        this.$message({\n          type: 'info',\n          message: '已取消删除'\n        });\n      });\n    },\n    resetForm() {\n      this.$refs.dataForm.resetFields()\n    }\n  }\n}\n</script>\n<style scoped>\n.el-header {\n  color: #333;\n  padding: 0 0;\n}\n\n.el-form--inline > .inputlist {\n  padding-top: 20px;\n  padding-left: 20px;\n  display: flex;\n}\n\n.el-form--inline > .inputlist > .el-form-item {\n  width: 26%;\n  margin-bottom: 20px;\n}\n\n.el-form-item__content {\n  width: 200px;\n}\n\n.el-button {\n  width: 80px;\n  height: 35px;\n}\n\n.el-button-func {\n  width: 86px;\n  height: 30px;\n  text-align: center;\n}\n::v-deep .el-table__cell{\n  text-align: center;\n}\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAqDA,OAAAA,SAAA;AACA,OAAAC,UAAA;AACA,OAAAC,WAAA;AAEA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,MAAA;MACAC,QAAA;QACAC,IAAA;MACA;MACAC,QAAA;MAEAC,SAAA;QACAC,MAAA;QACA;QACA;UAAAC,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;UAAAC,QAAA;QAAA,GACA;UAAAF,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;QAAA,GACA;UAAAD,KAAA;UAAAC,IAAA;UAAAC,QAAA;QAAA,EACA;QACAC,GAAA;MACA;I