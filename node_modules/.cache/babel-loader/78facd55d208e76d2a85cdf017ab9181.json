return variables\n    },\n    isCollapse() {\n      return !this.sidebar.opened\n    },\n    onRoutes() {\n      if (this.$route.path.indexOf('projectHome') >= 0) {\n        // eslint-disable-next-line vue/no-side-effects-in-computed-properties\n        this.$store.state.lastMenu = this.$route.path\n        return this.$route.path\n      } else {\n        return this.$store.state.lastMenu\n      }\n    }\n  }\n}\n</script>\n\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAqCA,SAAAA,UAAA;AACA,OAAAC,IAAA;AACA,OAAAC,WAAA;AACA,OAAAC,UAAA;AACA;;AAEA,IAAAC,WAAA;AACA;EACAC,UAAA;IAAAH,WAAA,EAAAA,WAAA;IAAAD,IAAA,EAAAA;EAAA;EACAK,QAAA,EAAAC,aAAA,CAAAA,aAAA,KACAP,UAAA;IACA;IACAQ,iBAAA,WAAAA,kBAAA;MACA;MACA;MACA;MACA;MACA,YAAAC,OAAA,CAAAC,OAAA,CAAAC,MAAA;IACA;IACAC,UAAA,WAAAA,WAAA;MACA,IAAAC,KAAA,QAAAC,MAAA;MACA,IAAAC,IAAA,GAAAF,KAAA,CAAAE,IAAA;QAAAC,IAAA,GAAAH,KAAA,CAAAG,IAAA;MACA;MACA,IAAAD,IAAA,CAAAH,UAAA;QACA,OAAAG,IAAA,CAAAH,UAAA;MACA;MACA,OAAAI,IAAA;IACA;IACAC,QAAA,WAAAA,SAAA;MACA,YAAAC,MAAA,CAAAC,KAAA,CAAAC,QAAA,CAAAC,WAAA;IACA;IACAlB,SAAA,WAAAA,UAAA;MACA,OAAAA,UAAA;IACA;IACAmB,UAAA,WAAAA,WAAA;MACA,aAAAC,OAAA,CAAAC,MAAA;IACA;IACAC,QAAA,WAAAA,SAAA;MACA,SAAAX,MAAA,CAAAE,IAAA,CAAAU,OAAA;QACA;QACA,KAAAR,MAAA,CAAAC,KAAA,CAAAQ,QAAA,QAAAb,MAAA,CAAAE,IAAA;QACA,YAAAF,MAAA,CAAAE,IAAA;MACA;QACA,YAAAE,MAAA,CAAAC,KAAA,CAAAQ,QAAA;MACA;IACA;EAAA;AAEA"}]}