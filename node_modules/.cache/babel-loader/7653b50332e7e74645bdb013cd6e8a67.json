                   <el-input v-model=\"item.partyName\"></el-input>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"甲方证明说明:\" :prop=\"'materialPOS.' + index + '.partyDescription'\" v-if=\"item.materialType==2\">\n                    <el-col :span=\"12\">\n                      <el-input v-model=\"item.partyDescription\"></el-input>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"\" :prop=\"'materialPOS.' + index + '.orderPic'\" v-if=\"item.materialType!=1\">\n                    <el-col :span=\"24\">\n                      <el-button size=\"small\" type=\"primary\" @click=\"pictureList(item,index)\" class=\"upButton\">上传图片</el-button>\n                    </el-col>\n                  </el-form-item>\n                  <el-form-item label=\"绑定图片:\" :prop=\"'materialPOS.' + index + '.personalImgList'\" v-else>\n                    <base-input v-model=\"item.personalImgList\" style=\"width: 225px\"></base-input>\n                  </el-form-item>\n                  <el-form-item label=\"\" :prop=\"'materialPOS.' + index + '.orderExcel'\" v-if=\"item.materialType!=3\">\n                    <el-col :span=\"24\">\n                      <el-button size=\"small\" type=\"primary\" @click=\"excelList(item,index)\" class=\"upButton\">上传文件</el-button>\n                    </el-col>\n                  </el-form-item>\n                </fieldset>\n              </el-form-item>\n            </el-form>\n            <div style=\"margin-left: 40%\">\n              <el-button type=\"success\" @click=\"addData(index)\" icon=\"el-icon-circle-plus\">增加材料</el-button>\n            </div>\n          </div>\n        </div>\n      </el-form>\n    </el-container>\n    <baseDialog :title=\"titles\" ref=\"pictureListDialog\" :width=\"'700px'\" :height=\"'500px'\">\n      <template>\n        <pictureList @refreshDataList=\"refresh\" ref=\"pictureList\" @uploadPic=\"uploadPic\"></pictureList>\n      </template>\n    </baseDialog>\n    <baseDialog :title=\"titles\" ref=\"excelListDialog\" :width=\"'700px'\" :height=\"'500px'\">\n      <template>\n        <excelList @refreshDataList=\"refresh\" ref=\"excelList\" @uploadExcel=\"uploadExcel\"></excelList>\n      </template>\n    </baseDialog>\n  </div>\n</template>\n<script>\nimport baseDialog from '../../base/baseDialog.vue'\nimport baseInput from '../../base/baseInput.vue'\nimport pictureList from './picture.vue'\nimport excelList from './excel.vue'\nexport default {\n  data() {\n    return {\n      titles: '',\n      fileList: [],\n      badList: '',\n      typeObject:{},\n      typeList:[],\n      checkboxList: [],\n      index: null,\n      dialogImageUrl: '',\n      dialogVisible: false,\n      dataForm: {\n        materials:[],\n        materialPOS: [\n          {\n            contractNo: '', contractName: '', partyName:'',personalImgList:[],partyDescription:'', materialType: '', orderPic: undefined, orderExcel: undefined\n          }\n        ]\n      }\n    }\n  },\n  components: {\n    baseDialog, pictureList ,excelList,baseInput\n  },\n  props: {\n    getChildValue: {\n      type: '',\n      default: ''\n    }\n  },\n  mounted() {\n  },\n  methods: {\n    refresh() {\n      this.$refs.dataForm.validate((valid) => {\n        if (!valid) {\n          return false\n        }\n        this.$refs.table.refresh(this.dataForm)\n      })\n    },\n    resetForm() {\n      Object.assign(this.$data, this.$options.data())\n    },\n    init(Object, item) {\n      let list = Object.item\n\n      if (list.orderType !== undefined && list.orderType !== '') {\n        this.dataForm.materialPOS[0].orderType = list.orderType\n      } else {\n        this.dataForm.materialPOS[0].orderType = ''\n      }\n      if (list.partyName !== undefined && list.partyName !== '') {\n        this.dataForm.materialPOS[0].partyName = list.partyName\n      } else {\n        this.dataForm.materialPOS[0].partyName = ''\n      }\n      if (list.orderPic !== undefined && list.orderPic !== '') {\n        this.dataForm.materialPOS[0].orderPic = list.orderPic\n      } else {\n        this.dataForm.materialPOS[0].orderPic = undefined\n      }\n      if (list.orderExcel !== undefined && list.orderExcel !== '') {\n        this.dataForm.materialPOS[0].orderExcel = list.orderExcel\n      } else {\n        this.dataForm.materialPOS[0].orderExcel = undefined\n      }\n      if(list.partyDescription !==undefined && list.partyDescription!==''){\n        this.dataForm.materialPOS[0].partyDescription = list.partyDescription\n      }else{\n        this.dataForm.materialPOS[0].partyDescription = undefined\n      }\n      if(list.personalImgList !==undefined && list.personalImgList!==[]){\n        this.dataForm.materialPOS[0].personalImgList = list.personalImgList\n      }else{\n        this.dataForm.materialPOS[0].personalImgList = undefined\n      }\n    },\n    pictureList(item, index) {\n      this.index = index\n      this.titles = '上传图片'\n      this.$refs.pictureListDialog.show()\n/*      let max =null\n      if(item.materialType==1||item.materialType==2){\n        max=1\n      }*/\n      // if (this.dataForm.materialPOS[index].orderPic) {\n        this.$nextTick(() => {\n          this.$refs.pictureList.init(this.dataForm.materialPOS[index].orderPic, index)\n        })\n      // }\n    },\n    excelList(item, index) {\n      this.index = index\n      this.titles = '上传人员清单Excel'\n      this.$refs.excelListDialog.show()\n      let max =null\n      if(item.materialType==1||item.materialType==2){\n        max=1\n      }\n      // if (this.dataForm.materialPOS[index].orderExcel) {\n        this.$nextTick(() => {\n          this.$refs.excelList.init(this.dataForm.materialPOS[index].orderExcel, index,max)\n        })\n      // }\n    },\n    passFath() {\n      console.log(this.dataForm.materials)\n      return this.dataForm.materialPOS\n    },\n    uploadPic(file) {\n      this.dataForm.materialPOS[this.index].orderPic = file\n    },\n    uploadExcel(file) {\n      this.dataForm.materialPOS[this.index].orderExcel = file\n    },\n    // 删除行数据\n    deleteData(index) {\n      if (this.dataForm.materialPOS.length <= 1) {\n        this.$message.error('材料数量已达最低值！')\n        return\n      }\n      this.$confirm(`确认要删除当前内容吗？`, '提示', {\n        confirmButtonText: '确定',\n        cancelButtonText: '取消',\n        type: 'warning'\n      }).then(() => {\n        this.dataForm.materialPOS.splice(index, 1)\n      })\n    },\n    handle() {\n      this.badList = this.$parent._props.model.ContractNo\n    },\n    // 添加行数据\n    addData(index) {\n      this.dataForm.materialPOS.push({\n        contractNo: '',\n        contractName: '',\n        partyName:'',\n        materialType: '',\n        orderPic: undefined,\n        orderExcel: undefined\n      })\n    },\n    changeContent(event,index){\n      this.dataForm.materialPOS[index].orderPic=[]\n      this.dataForm.materialPOS[index].orderExcel=[]\n      this.typeList[index]=event\n      let typeList=this.typeList\n      this.typeObject={}\n      let result =true\n      for (const i of typeList) {\n        console.log(i)\n        if(i==1||i==3){\n          result=false\n          this.typeObject['type'+i]=i\n        }\n      }\n      if(result){\n        this.typeObject={}\n      }\n\n    }\n  }\n}\n</script>\n<style scoped>\n  .el-form--inline>.inputlist>.orManagement>.el-form-item{\n    width: 20%;\n  }\n  ::v-deep .el-input__inner{\n    width: 110px;\n    padding-left: 10px;\n    padding-right: 0px;\n  }\n  ::v-deep .el-form-item__label{\n    font-weight: 400;\n  }\n  .dateInput{\n    width: 110px !important;\n  }\n  .base-pic-upload .el-upload{\n    text-align: center;\n    display: inline-block;\n  }\n  #contentBar>.el-container>.el-form{\n    width: 100%;\n  }\n  .fieldlist>.el-input--small .el-input__inner{\n    width: 200px;\n  }\n  .upButton{\n    width: 82px;\n    height: 25px;\n    text-align: center;\n  }\n  ::v-deep .el-form-item .el-form-item{\n    margin-bottom: 0px;\n  }\n  #contentBar::-webkit-scrollbar { /*滚动条整体样式*/\n    width: 8px; /*高宽分别对应横竖滚动条的尺寸*/\n    height: 0px;\n  }\n  #contentBar::-webkit-scrollbar-thumb { /*滚动条里面小方块*/\n    border-radius: 10px;\n    -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n    background: #e1f1f1;\n  }\n  #contentBar::-webkit-scrollbar-track { /*滚动条里面轨道*/\n    -webkit-box-shadow: inset 0 0 5px rgba(0, 0, 0, 0.2);\n    border-radius: 10px;\n    background: #fff;\n  }\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;;AAmEA,OAAAA,UAAA;AACA,OAAAC,SAAA;AACA,OAAAC,WAAA;AACA,OAAAC,SAAA;AACA;EACAC,IAAA,WAAAA,KAAA;IACA;MACAC,MAAA;MACAC,QAAA;MACAC,OAAA;MACAC,UAAA;MACAC,QAAA;MACAC,YAAA;MACAC,KAAA;MACAC,cAAA;MACAC,aAAA;MACAC,QAAA;QACAC,SAAA;QACAC,WAAA,GACA;UACAC,UAAA;UAAAC,YAAA;UAAAC,SAAA;UAAAC,eAAA;UAAAC,gBAAA;UAAAC,YAAA;UAAAC,QAAA,EAAAC,SAAA;UAAAC,UAAA,EAAAD;QACA;MAEA;IACA;EACA;EACAE,UAAA;IACA1B,UAAA,EAAAA,UAAA;IAAAE,WAAA,EAAAA,WAAA;IAAAC,SAAA,EAAAA,SAAA;IAAAF,SAAA,EAAAA;EACA;EACA0B,KAAA;IACAC,aAAA;MACAC,IAAA;MACAC,OAAA;IACA;EACA;EACAC,OAAA,WAAAA,QAAA,GACA;EACAC,OAAA;IACAC,OAAA,WAAAA,QAAA;MAAA,IAAAC,KAAA;MACA,KAAAC,KAAA,CAAArB,QAAA,CAAAsB,QAAA,WAAAC,KAAA;QACA,KAAAA,KAAA;UACA;QACA;QACAH,KAAA,CAAAC,KAAA,CAAAG,KAAA,CAAAL,OAAA,CAAAC,KAAA,CAAApB,QAAA;MACA;IACA;IACAyB,SAAA,WAAAA,UAAA;MACAC,MAAA,CAAAC,MAAA,MAAAC,KAAA,OAAAC,QAAA,CAAAvC,IAAA;IACA;IACAwC,IAAA,WAAAA,KAAAJ,MAAA,EAAAK,IAAA;MACA,IAAAC,IAAA,GAAAN,MAAA,CAAAK,IAAA;MAEA,IAAAC,IAAA,CAAAC,SAAA,KAAAvB,SAAA,IAAAsB,IAAA,CAAAC,SAAA;QACA,KAAAjC,QAAA,CAAAE,WAAA,IAAA+B,SAAA,GAAAD,IAAA,CAAAC,SAAA;MACA;QACA,KAAAjC,QAAA,CAAAE,WAAA,IAAA+B,SAAA;MACA;MACA,IAAAD,IAAA,CAAA3B,SAAA,KAAAK,SAAA,IAAAsB,IAAA,CAAA3B,SAAA;QACA,KAAAL,QAAA,CAAAE,WAAA,IAAAG,SAAA,GAAA2B,IAAA,CAAA3B,SAAA;MACA;QACA,KAAAL,QAAA,CAAAE,WAAA,IAAAG,SAAA;MACA;MACA,IAAA2B,IAAA,CAAAvB,QAAA,KAAAC,SAAA,IAAAsB,IAAA,CAAAvB,QAAA;QACA,KAAAT,QAAA,CAAAE,WAAA,IAAAO,QAAA,GAAAuB,IAAA,CAAAvB,QAAA;MACA;QACA,KAAAT,QAAA,CAA