e\n      this.nowFileList = fileList\n      this.getFileList()\n    },\n    hasFile() {\n      return this.$refs.upload.uploadFiles.length > 0\n    },\n    getFileList() {\n      let data = {propName:this.propName,file:this.nowFileList}\n      this.$emit(\"getFileList\",data)\n      // this.$refs.upload.fileList=this.nowFileList\n      // this.fileList=this.nowFileList\n      return this.nowFileList\n    }\n  }\n}\n</script>\n<style>\n/* 取消eb-upload默认的按钮栏样式，用于按钮隐藏多余突出白块 */\n/*.base-pic-upload .el-upload{*/\n/*  display: block;*/\n/*  text-align: center;*/\n/*}*/\n</style>\n"],"mappings":";;;;;;;;;;;;;;;;;AAiBA;EACAA,IAAA,WAAAA,KAAA;IACA;MACAC,cAAA;MACAC,aAAA;MACAC,QAAA;MACAC,SAAA;MACAC,WAAA,OAAAC;IACA;EACA;EACAC,KAAA;IACAC,IAAA;MACAC,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAC,OAAA;MACAH,IAAA,EAAAI;IACA;IACAP,QAAA;MACAG,IAAA,EAAAK,KAAA;MACAC,OAAA,WAAAC,SAAA;QACA;MACA;IACA;IACAC,MAAA;MACAR,IAAA,EAAAC,MAAA;MACAK,OAAA;IACA;IACAG,QAAA;MACAT,IAAA,EAAAC,MAAA;MACAC,OAAA;IACA;IACAQ,UAAA;MACAV,IAAA,EAAAW,OAAA;MACAL,OAAA;IACA;EACA;EACAM,OAAA;IACAC,wBAAA,WAAAA,yBAAAC,IAAA;MACA,KAAAtB,cAAA,GAAAsB,IAAA,CAAAC,GAAA;MACA,KAAAtB,aAAA;IACA;IACAuB,WAAA,WAAAA,YAAA;MACA,SAAAC,WAAA,GAAAC,MAAA;QACA,KAAAC,KAAA,CAAAC,MAAA,CAAAC,UAAA;QACA,KAAA1B,SAAA;MACA;IACA;IACA2B,cAAA,WAAAA,eAAAR,IAAA,EAAAjB,QAAA;MACA,IAAA0B,QAAA,GAAAT,IAAA,CAAAf,IAAA,CAAAyB,MAAA,CAAAV,IAAA,CAAAf,IAAA,CAAA0B,WAAA,WAAAX,IAAA,CAAAf,IAAA,CAAAmB,MAAA;MACA,IAAAQ,IAAA;MACA,SAAAlB,MAAA;QACA,IAAAmB,KAAA,QAAAnB,MAAA,CAAAoB,UAAA,UAAAC,KAAA;QACAF,KAAA,CAAAG,OAAA,WAAAC,IAAA,EAAAC,CAAA;UACA,IAAAD,IAAA,KAAAR,QAAA;YACAG,IAAA;UACA;QACA;MACA;QACAA,IAAA;MACA;MACA,IAAAA,IAAA;QACA7B,QAAA,CAAAoC,GAAA;QACA,KAAAC,QAAA,CAAAC,OAAA;QACA;MACA;QACA,SAAAhC,OAAA,kBAAAA,OAAA,CAAAW,IAAA,EAAAjB,QAAA;UACAA,QAAA,CAAAoC,GAAA;UACA;UACA;QACA;MACA;MACA,KAAAtC,SAAA;MACA,KAAAC,WAAA,GAAAC,QAAA;MACA,KAAAoB,WAAA;IACA;IACAmB,cAAA,WAAAA,eAAAtB,IAAA,EAAAjB,QAAA;MACA,KAAAF,SAAA;MACA,KAAAC,WAAA,GAAAC,QAAA;MACA,KAAAoB,WAAA;IACA;IACAoB,OAAA,WAAAA,QAAA;MACA,YAAAlB,KAAA,CAAAC,MA